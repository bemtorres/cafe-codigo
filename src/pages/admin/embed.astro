---
import Layout from '../../layouts/Layout.astro';
import { courses } from '../../data/courses';
---

<Layout title="Admin · Embed builder" description="Generador interno de URLs de embed (GET params).">
  <article class="content-section admin-embed w-full max-w-full min-w-0">
    <header class="admin-embed-head mb-3">
      <h1 class="!mb-0 !text-xl sm:!text-2xl">/admin/embed</h1>
      <p class="!mb-0 !mt-1 !text-xs sm:!text-sm !leading-snug text-textSecondary font-[650]">
        Parámetros GET + tabla de URLs por lección (ancho completo abajo).
      </p>
    </header>

    <!-- Formulario compacto (una sola tarjeta) -->
    <div
      class="admin-embed-form rounded-xl border-2 border-border bg-primary/15 p-2 sm:p-3 shadow-[3px_3px_0_var(--border)] space-y-2"
    >
      <!-- Filtros + presets -->
      <div class="flex flex-col gap-2 lg:flex-row lg:items-end lg:gap-3">
        <div class="grid min-w-0 flex-1 grid-cols-1 gap-2 sm:grid-cols-2">
          <label class="ae-field">
            <span class="ae-lbl">Curso</span>
            <select id="embCourse" class="ae-input">
              <option value="">Todos</option>
              {courses
                .filter((c) => (c.lessons?.length ?? 0) > 0)
                .map((c) => (
                  <option value={c.slug}>{c.name}</option>
                ))}
            </select>
          </label>
          <label class="ae-field">
            <span class="ae-lbl">Buscar</span>
            <input id="embSearch" class="ae-input" placeholder="slug, título, ruta…" />
          </label>
        </div>
        <div class="flex flex-wrap gap-1 lg:shrink-0 lg:justify-end">
          <button type="button" class="ae-chip" data-preset="clean">Limpio</button>
          <button type="button" class="ae-chip" data-preset="noquiz">Sin quiz</button>
          <button type="button" class="ae-chip" data-preset="pdf">PDF</button>
          <button type="button" class="ae-chip" data-preset="student">+ alumno</button>
        </div>
      </div>

      <!-- Flags en línea -->
      <div class="ae-divider flex flex-wrap items-center gap-x-4 gap-y-1 pt-1">
        <span class="ae-lbl !mb-0 w-full sm:w-auto">Flags</span>
        <label class="ae-inline">
          <input id="pEmbed" type="checkbox" class="ae-cb" checked />
          <span>embed</span>
        </label>
        <label class="ae-inline">
          <input id="pQuiz" type="checkbox" class="ae-cb" checked />
          <span>quiz</span>
        </label>
        <label class="ae-inline">
          <input id="pPdf" type="checkbox" class="ae-cb" />
          <span>pdf</span>
        </label>
        <span class="text-[10px] font-bold text-textMuted">quiz off = <code class="rounded bg-black/5 px-1">quiz=false</code></span>
      </div>

      <!-- Cabecera embed: title, name, email -->
      <div class="grid grid-cols-1 gap-2 md:grid-cols-3">
        <label class="ae-field">
          <span class="ae-lbl">title</span>
          <input id="pTitle" class="ae-input" placeholder="Institución" />
        </label>
        <label class="ae-field">
          <span class="ae-lbl">name</span>
          <input id="pName" class="ae-input" placeholder="Alumno" />
        </label>
        <label class="ae-field">
          <span class="ae-lbl">email</span>
          <input id="pEmail" class="ae-input" placeholder="correo" />
        </label>
      </div>

      <!-- Branding -->
      <div class="grid grid-cols-1 gap-2 lg:grid-cols-4">
        <label class="ae-field">
          <span class="ae-lbl">logo</span>
          <input id="pLogo" class="ae-input" placeholder="https://…/logo.png" />
        </label>
        <div class="ae-field">
          <span class="ae-lbl">background (fondo página)</span>
          <input id="pBackground" type="hidden" />
          <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            <label class="ae-field !m-0">
              <span class="sr-only">Background URL</span>
              <input id="pBackgroundUrl" class="ae-input" placeholder="URL imagen…" />
            </label>
            <label class="ae-field !m-0">
              <span class="sr-only">Background color</span>
              <div class="flex items-center gap-2">
                <input type="color" id="pBackgroundColor" class="ae-color" value="#ffffff" title="Color de fondo (background=)" />
                <span id="pBackgroundHex" class="font-mono text-[10px] font-bold text-textMuted" aria-live="polite">#ffffff</span>
              </div>
            </label>
          </div>
        </div>
        <label class="ae-field">
          <span class="ae-lbl">cabecera (fondo)</span>
          <div class="flex items-center gap-2">
            <input
              type="color"
              id="pColor"
              class="ae-color"
              value="#2b1d1b"
              title="Color de fondo de la cabecera embed (?color=)"
            />
            <span id="pColorHex" class="font-mono text-[10px] font-bold text-textMuted" aria-live="polite">#2b1d1b</span>
          </div>
        </label>
        <label class="ae-field">
          <span class="ae-lbl">cabecera (texto)</span>
          <div class="flex items-center gap-2">
            <input
              type="color"
              id="pText"
              class="ae-color"
              value="#fdf6e9"
              title="Color de texto de la cabecera embed (?text=)"
            />
            <span id="pTextHex" class="font-mono text-[10px] font-bold text-textMuted" aria-live="polite">#fdf6e9</span>
          </div>
        </label>
      </div>

      <!-- Preview mini -->
      <div class="ae-divider grid grid-cols-1 gap-2 pt-1 sm:grid-cols-3">
        <div>
          <span class="ae-lbl mb-1 block">Preview logo</span>
          <div class="flex items-center gap-2 rounded-lg border border-border bg-white px-2 py-1.5">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-xl border border-border bg-primary/30">
              <img id="logoPrev" alt="" class="hidden h-full w-full object-contain p-0.5" />
              <span id="logoPrevFallback" class="text-sm">🏫</span>
            </div>
            <div class="min-w-0 text-[11px] leading-tight">
              <div class="truncate font-black">Institución</div>
              <div class="truncate font-bold text-textMuted">Lección</div>
            </div>
          </div>
        </div>
        <div>
          <span class="ae-lbl mb-1 block">Preview cabecera</span>
          <div id="headerPrev" class="rounded-lg border border-border px-3 py-2 text-[11px] font-black shadow-neo bg-[#2b1d1b]" style="color:#fdf6e9">
            Cabecera embed
          </div>
        </div>
        <div>
          <span class="ae-lbl mb-1 block">Preview fondo página</span>
          <div id="pageBgPrev" class="rounded-lg border border-border px-3 py-2 text-[11px] font-black text-textPrimary shadow-neo bg-white">
            Fondo de página
          </div>
        </div>
      </div>
    </div>

    <!-- Listado col-12: ancho completo del contenedor -->
    <section class="admin-embed-table-section mt-4 w-full min-w-0" aria-label="Tabla de URLs">
      <div class="mb-2 flex flex-wrap items-baseline justify-between gap-2">
        <h2 class="!m-0 !text-sm font-nunito font-black text-textPrimary">URLs por lección</h2>
        <span id="listMeta" class="font-nunito text-[11px] font-bold text-textMuted"></span>
      </div>
      <div class="w-full min-w-0 overflow-x-auto rounded-lg border-2 border-border bg-white">
        <table class="admin-embed-table w-full min-w-0 table-fixed border-collapse text-left">
          <colgroup>
            <col class="w-[14%]" />
            <col class="w-[20%]" />
            <col />
            <col class="w-[5.5rem]" />
          </colgroup>
          <thead class="bg-primary/40">
            <tr>
              <th class="ae-th">Curso</th>
              <th class="ae-th">Lección</th>
              <th class="ae-th">URL</th>
              <th class="ae-th">Acción</th>
            </tr>
          </thead>
          <tbody id="lessonsList"></tbody>
        </table>
      </div>
      <p class="!mb-0 !mt-2 !text-[10px] font-bold text-textMuted">
        Ruta interna; no es autenticación real.
      </p>
    </section>
  </article>

  <script>
    import '../../lib/embed/adminEmbedClient.ts';
  </script>

  <style is:inline>
    .admin-embed h1 {
      margin-bottom: 0.25rem;
    }
    .admin-embed .ae-lbl {
      display: block;
      font-size: 0.65rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted, #6b7280);
      margin-bottom: 0.2rem;
    }
    .admin-embed .ae-input,
    .admin-embed .ae-field select {
      width: 100%;
      border-radius: 0.5rem;
      border: 2px solid var(--border);
      background: #fff;
      padding: 0.28rem 0.45rem;
      font-size: 0.75rem;
      font-weight: 700;
      font-family: ui-sans-serif, system-ui, sans-serif;
    }
    .admin-embed input[type='color'].ae-color {
      height: 2rem;
      width: 2.75rem;
      padding: 0.15rem;
      border-radius: 0.5rem;
      border: 2px solid var(--border);
      background: #fff;
      cursor: pointer;
    }
    .admin-embed input[type='color'].ae-color::-webkit-color-swatch-wrapper {
      padding: 0;
    }
    .admin-embed input[type='color'].ae-color::-webkit-color-swatch {
      border-radius: 0.25rem;
      border: none;
    }
    .admin-embed .ae-chip {
      border-radius: 0.5rem;
      border: 2px solid var(--border);
      background: #fff;
      padding: 0.2rem 0.45rem;
      font-size: 0.65rem;
      font-weight: 900;
      line-height: 1.2;
      box-shadow: 2px 2px 0 var(--border);
    }
    .admin-embed .ae-chip:hover {
      transform: translateY(-1px);
    }
    .admin-embed .ae-divider {
      border-top: 1px solid rgba(30, 18, 16, 0.12);
    }
    .admin-embed .ae-inline {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.7rem;
      font-weight: 800;
    }
    .admin-embed .ae-cb {
      height: 0.95rem;
      width: 0.95rem;
    }
    .admin-embed .ae-th {
      padding: 0.35rem 0.5rem;
      font-size: 0.65rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-muted, #6b7280);
      border-bottom: 2px solid var(--border);
    }
    .admin-embed-table-section {
      grid-column: 1 / -1;
    }
  </style>

  <script
    type="application/json"
    id="coursesJson"
    is:inline
    set:html={JSON.stringify(courses.map((c) => ({ slug: c.slug, name: c.name, lessons: c.lessons ?? [] })))}
  />
</Layout>
