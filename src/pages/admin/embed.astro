---
import Layout from '../../layouts/Layout.astro';
import { courses } from '../../data/courses';
---

<Layout title="Admin · Embed builder" description="Generador interno de URLs de embed (GET params)." >
  <article class="content-section">
    <h1>/admin/embed</h1>
    <p class="text-textSecondary font-[650] leading-relaxed">
      Panel interno (oculto por URL) para armar enlaces de embed por lección con parámetros GET.
    </p>

    <section class="mb-10">
      <h2>Listado de lecciones</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        <label class="flex flex-col gap-1">
          <span class="font-nunito font-black text-textPrimary">Filtrar por curso (opcional)</span>
          <select id="embCourse" class="rounded-xl border-2 border-border bg-white px-3 py-2 font-nunito font-bold">
            <option value="">Todos los cursos</option>
            {courses
              .filter((c) => (c.lessons?.length ?? 0) > 0)
              .map((c) => (
                <option value={c.slug}>{c.name}</option>
              ))}
          </select>
        </label>
        <label class="flex flex-col gap-1">
          <span class="font-nunito font-black text-textPrimary">Buscar (opcional)</span>
          <input
            id="embSearch"
            class="rounded-xl border-2 border-border bg-white px-3 py-2 font-nunito font-bold"
            placeholder="python, joins, introducción…"
          />
        </label>
      </div>
    </section>

    <section class="mb-10">
      <h2>Parámetros (GET)</h2>

      <div class="flex flex-wrap gap-2 mb-4">
        <button type="button" class="rounded-xl border-2 border-border bg-white px-3 py-1.5 font-nunito font-black shadow-neo hover:-translate-y-0.5 transition-transform" data-preset="clean">Embed limpio</button>
        <button type="button" class="rounded-xl border-2 border-border bg-white px-3 py-1.5 font-nunito font-black shadow-neo hover:-translate-y-0.5 transition-transform" data-preset="noquiz">Embed sin quiz</button>
        <button type="button" class="rounded-xl border-2 border-border bg-white px-3 py-1.5 font-nunito font-black shadow-neo hover:-translate-y-0.5 transition-transform" data-preset="pdf">Embed PDF</button>
        <button type="button" class="rounded-xl border-2 border-border bg-white px-3 py-1.5 font-nunito font-black shadow-neo hover:-translate-y-0.5 transition-transform" data-preset="student">Embed con datos alumno</button>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border-2 border-border bg-white p-4 shadow-[4px_4px_0_var(--border)]">
          <h3 class="font-nunito font-black text-lg m-0 mb-3">Flags</h3>
          <label class="flex items-center justify-between gap-3 py-2">
            <span class="font-nunito font-extrabold">embed</span>
            <input id="pEmbed" type="checkbox" class="h-5 w-5" checked />
          </label>
          <label class="flex items-center justify-between gap-3 py-2">
            <span class="font-nunito font-extrabold">quiz</span>
            <span class="text-textMuted font-nunito font-bold text-sm">desmarcar → quiz=false</span>
            <input id="pQuiz" type="checkbox" class="h-5 w-5" checked />
          </label>
          <label class="flex items-center justify-between gap-3 py-2">
            <span class="font-nunito font-extrabold">pdf</span>
            <input id="pPdf" type="checkbox" class="h-5 w-5" />
          </label>
        </div>

        <div class="rounded-2xl border-2 border-border bg-white p-4 shadow-[4px_4px_0_var(--border)]">
          <h3 class="font-nunito font-black text-lg m-0 mb-3">Datos</h3>
          <div class="grid gap-3">
            <label class="flex flex-col gap-1">
              <span class="font-nunito font-extrabold">title (institución)</span>
              <input id="pTitle" class="rounded-xl border-2 border-border bg-white px-3 py-2 font-nunito font-bold" placeholder="Institución…" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="font-nunito font-extrabold">name (alumno)</span>
              <input id="pName" class="rounded-xl border-2 border-border bg-white px-3 py-2 font-nunito font-bold" placeholder="Nombre…" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="font-nunito font-extrabold">email (alumno)</span>
              <input id="pEmail" class="rounded-xl border-2 border-border bg-white px-3 py-2 font-nunito font-bold" placeholder="correo@…" />
            </label>
          </div>
        </div>
      </div>

      <div class="grid gap-4 mt-4 lg:grid-cols-2">
        <div class="rounded-2xl border-2 border-border bg-white p-4 shadow-[4px_4px_0_var(--border)]">
          <h3 class="font-nunito font-black text-lg m-0 mb-3">Branding (cabecera embed)</h3>
          <div class="grid gap-3">
            <label class="flex flex-col gap-1">
              <span class="font-nunito font-extrabold">logo (url)</span>
              <input id="pLogo" class="rounded-xl border-2 border-border bg-white px-3 py-2 font-nunito font-bold" placeholder="https://…/logo.png" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="font-nunito font-extrabold">background (url o color)</span>
              <input id="pBackground" class="rounded-xl border-2 border-border bg-white px-3 py-2 font-nunito font-bold" placeholder="#f3f3f3 o https://…/bg.jpg" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="font-nunito font-extrabold">color (solo cabecera)</span>
              <input id="pColor" class="rounded-xl border-2 border-border bg-white px-3 py-2 font-nunito font-bold" placeholder="#2b1d1b" />
            </label>
          </div>

          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            <div>
              <div class="font-nunito font-black text-sm text-textMuted mb-1">Preview logo</div>
              <div class="rounded-xl border-2 border-border bg-primary p-3 flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl border border-border bg-white/80 flex items-center justify-center overflow-hidden shadow-neo">
                  <img id="logoPrev" alt="" class="w-full h-full object-contain p-1 hidden" />
                  <span id="logoPrevFallback">🏫</span>
                </div>
                <div class="min-w-0">
                  <div class="font-nunito font-black truncate">Institución</div>
                  <div class="font-nunito font-bold text-textMuted text-sm truncate">Título de lección</div>
                </div>
              </div>
            </div>
            <div>
              <div class="font-nunito font-black text-sm text-textMuted mb-1">Preview background</div>
              <div id="bgPrev" class="rounded-xl border-2 border-border p-4 shadow-neo-lg bg-[#2b1d1b] text-white font-nunito font-black">
                Cabecera embed
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border-2 border-border bg-white p-4 shadow-[4px_4px_0_var(--border)]">
          <h3 class="font-nunito font-black text-lg m-0 mb-3">Enlaces listos para copiar</h3>
          <div id="listMeta" class="text-textMuted font-nunito text-xs font-bold mb-3"></div>
          <div id="lessonsList" class="space-y-3"></div>
          <p class="mt-4 mb-0 text-textMuted font-nunito text-xs font-bold">
            Nota: esta ruta no es segura (solo “oculta” por URL).
          </p>
        </div>
      </div>
    </section>
  </article>

  <script type="module" is:inline>
    import { buildEmbedUrl } from '../../lib/embed/buildEmbedUrl';

    const courses = /** @type {const} */ (JSON.parse(document.getElementById('coursesJson').textContent));

    const $ = (id) => /** @type {HTMLElement} */ (document.getElementById(id));

    const courseSel = /** @type {HTMLSelectElement} */ ($('embCourse'));
    const searchInp = /** @type {HTMLInputElement} */ ($('embSearch'));

    const pEmbed = /** @type {HTMLInputElement} */ ($('pEmbed'));
    const pQuiz = /** @type {HTMLInputElement} */ ($('pQuiz'));
    const pPdf = /** @type {HTMLInputElement} */ ($('pPdf'));
    const pTitle = /** @type {HTMLInputElement} */ ($('pTitle'));
    const pName = /** @type {HTMLInputElement} */ ($('pName'));
    const pEmail = /** @type {HTMLInputElement} */ ($('pEmail'));
    const pLogo = /** @type {HTMLInputElement} */ ($('pLogo'));
    const pBackground = /** @type {HTMLInputElement} */ ($('pBackground'));
    const pColor = /** @type {HTMLInputElement} */ ($('pColor'));

    const lessonsList = $('lessonsList');
    const listMeta = $('listMeta');

    const logoPrev = /** @type {HTMLImageElement} */ ($('logoPrev'));
    const logoPrevFallback = $('logoPrevFallback');
    const bgPrev = $('bgPrev');

    function norm(s) {
      return String(s || '')
        .normalize('NFD')
        .replace(/\\p{M}/gu, '')
        .toLowerCase();
    }

    function applyPreview() {
      const logo = pLogo.value.trim();
      if (logo) {
        logoPrev.classList.add('hidden');
        if (logoPrevFallback) logoPrevFallback.textContent = '🏫';
        logoPrev.onload = () => {
          logoPrev.classList.remove('hidden');
          if (logoPrevFallback) logoPrevFallback.textContent = '';
        };
        logoPrev.onerror = () => {
          logoPrev.classList.add('hidden');
          if (logoPrevFallback) logoPrevFallback.textContent = '🏫';
        };
        logoPrev.src = logo;
      } else {
        logoPrev.classList.add('hidden');
        if (logoPrevFallback) logoPrevFallback.textContent = '🏫';
      }

      const bg = pBackground.value.trim();
      const color = pColor.value.trim();
      bgPrev.style.backgroundImage = '';
      bgPrev.style.backgroundColor = '';

      if (color) bgPrev.style.backgroundColor = color;
      if (bg) {
        const isColor = /^#([0-9a-fA-F]{3,8})$/.test(bg) || /^rgba?\(/i.test(bg) || /^hsla?\(/i.test(bg);
        if (isColor) {
          bgPrev.style.backgroundColor = bg;
        } else {
          bgPrev.style.backgroundImage = `url(\"${bg}\")`;
          bgPrev.style.backgroundSize = 'cover';
          bgPrev.style.backgroundPosition = 'center';
          bgPrev.style.backgroundRepeat = 'no-repeat';
        }
      }
    }

    function buildParams() {
      return {
        embed: pEmbed.checked,
        quiz: pQuiz.checked,
        pdf: pPdf.checked,
        title: pTitle.value,
        name: pName.value,
        email: pEmail.value,
        logo: pLogo.value,
        background: pBackground.value,
        color: pColor.value,
      };
    }

    function escapeAttr(s) {
      return String(s).replace(/&/g, '&amp;').replace(/\"/g, '&quot;').replace(/</g, '&lt;');
    }

    function renderList() {
      const origin = window.location.origin;
      const params = buildParams();
      const courseFilter = courseSel.value || '';
      const q = norm(searchInp.value || '');

      lessonsList.innerHTML = '';
      let count = 0;

      for (const c of courses) {
        if (courseFilter && c.slug !== courseFilter) continue;
        const lessons = Array.isArray(c.lessons) ? c.lessons : [];
        const rows = [];

        for (const l of lessons) {
          const hay = norm(`${c.slug} ${c.name} ${l.title} ${l.href}`);
          if (q && !hay.includes(q)) continue;
          const url = buildEmbedUrl(origin, l.href, params);
          rows.push({ title: l.title, href: l.href, url });
        }

        if (rows.length === 0) continue;

        const header = document.createElement('div');
        header.className = 'rounded-xl border-2 border-border bg-primary px-3 py-2 shadow-neo';
        header.innerHTML = `<div class=\"font-nunito font-black text-textPrimary\">${escapeAttr(c.name)} <span class=\"text-textMuted font-extrabold text-xs\">(${escapeAttr(c.slug)})</span></div>`;
        lessonsList.appendChild(header);

        for (const row of rows) {
          count++;
          const wrap = document.createElement('div');
          wrap.className = 'rounded-xl border-2 border-border bg-white p-3 shadow-[3px_3px_0_var(--border)]';
          wrap.innerHTML = `
            <div class=\"flex flex-col gap-2\">
              <div class=\"flex items-start justify-between gap-3\">
                <div class=\"min-w-0\">
                  <div class=\"font-nunito font-black text-textPrimary truncate\">${escapeAttr(row.title)}</div>
                  <div class=\"font-nunito font-bold text-textMuted text-xs truncate\">${escapeAttr(row.href)}</div>
                </div>
                <button
                  type=\"button\"
                  class=\"copyRowBtn shrink-0 rounded-xl border-2 border-border bg-success text-white px-3 py-1.5 font-nunito font-black shadow-neo hover:-translate-y-0.5 transition-transform\"
                  data-copy=\"${escapeAttr(row.url)}\"
                >Copiar</button>
              </div>
              <input class=\"w-full rounded-lg border-2 border-border bg-white px-2.5 py-2 font-mono text-[12px]\" value=\"${escapeAttr(row.url)}\" readonly />
            </div>
          `;
          lessonsList.appendChild(wrap);
        }
      }

      listMeta.textContent = count ? `${count} enlace(s) generado(s).` : 'No hay lecciones para ese filtro.';
    }

    function setPreset(kind) {
      // defaults
      pEmbed.checked = true;
      pQuiz.checked = true;
      pPdf.checked = false;
      if (kind === 'noquiz') pQuiz.checked = false;
      if (kind === 'pdf') pPdf.checked = true;
      if (kind === 'student') {
        pTitle.value ||= 'INSTITUCIÓN';
        pName.value ||= 'NOMBRE';
        pEmail.value ||= 'CORREO';
      }
    }

    document.addEventListener('click', (e) => {
      const b = e.target.closest('[data-preset]');
      if (!b) return;
      setPreset(b.getAttribute('data-preset'));
      applyPreview();
      renderList();
    });

    courseSel.addEventListener('change', renderList);
    searchInp.addEventListener('input', renderList);

    [pEmbed, pQuiz, pPdf, pTitle, pName, pEmail, pLogo, pBackground, pColor].forEach((el) => {
      el.addEventListener('input', () => {
        applyPreview();
        renderList();
      });
      el.addEventListener('change', () => {
        applyPreview();
        renderList();
      });
    });

    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('.copyRowBtn');
      if (!btn) return;
      const text = btn.getAttribute('data-copy') || '';
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = 'Copiado';
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
        btn.textContent = 'Copiado';
      }
      setTimeout(() => (btn.textContent = 'Copiar'), 900);
    });

    // init
    applyPreview();
    renderList();
  </script>

  <script type="application/json" id="coursesJson" is:inline>
    {JSON.stringify(courses.map((c) => ({ slug: c.slug, name: c.name, lessons: c.lessons ?? [] })))}
  </script>
</Layout>

