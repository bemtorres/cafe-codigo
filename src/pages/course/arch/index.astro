---
import Layout from '../../../layouts/Layout.astro';
import { courses } from '../../../data/courses';

const archCourse = courses.find(c => c.slug === 'arch');
if (!archCourse) {
  throw new Error("No se encontró el curso 'arch' en el archivo de datos.");
}
---

<Layout title="Arquitectura 4+1: El Modelo de Vistas" description="Aprende a describir sistemas complejos usando el estándar de Kruchten: Vistas Lógica, de Desarrollo, de Proceso y Física." courseSlug="arch">
  <div class="course-container">
    <header class="course-index-header">
      <h1 class="course-big-title" style={`--course-color: ${archCourse.color}`}>
         𓋹 {archCourse.name}
      </h1>
      <p class="course-description">
         <strong>"El Código de los Faraones"</strong> — {archCourse.description}
      </p>

      <div class="tools-links">
        <span class="tools-label">📜 Herramientas del Arquitecto:</span>
        <div class="tools-grid">
          <a href="https://www.drawio.com/" target="_blank" rel="noopener">𓁑 Draw.io</a>
          <a href="https://miro.com/es/plantillas/diagramas-de-flujo/" target="_blank" rel="noopener">𓊝 Miro</a>
          <a href="https://excalidraw.com/" target="_blank" rel="noopener">𓋹 Excalidraw</a>
        </div>
      </div>
    </header>

    <div class="cards-grid">
      {archCourse.lessons?.map((lesson, index) => (
        <a href={lesson.href} class="lesson-card">
          <div class="lesson-card__number">{index + 1}</div>
          <div class="lesson-card__content">
            <h3 class="lesson-card__title">𓃠 {lesson.title}</h3>
            <span class="lesson-card__cta">Descifrar pergamino →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .course-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .course-index-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .course-big-title {
    font-size: clamp(2rem, 7vw, 3.5rem);
    font-weight: 900;
    color: var(--course-color, #475569);
    margin-bottom: 1rem;
    line-height: 1;
    font-family: 'Nunito', sans-serif;
    text-shadow: 4px 4px 0px var(--border);
  }

  .course-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    font-weight: 700;
  }

  .tools-links {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .tools-label {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 800;
    font-size: 0.9rem;
    color: #475569;
  }

  .tools-grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tools-grid a {
    background: white;
    border: 2px solid var(--border);
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    text-decoration: none;
    color: #1a1a1b;
    font-weight: 900;
    font-size: 0.95rem;
    box-shadow: 3px 3px 0px var(--border);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .tools-grid a:hover {
    transform: translate(-1px, -1px);
    box-shadow: 4px 4px 0px var(--border);
    border-color: #64748b;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .lesson-card {
    display: flex;
    gap: 1rem;
    background: white;
    border: 3px solid var(--border);
    border-radius: 20px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 4px 4px 0px var(--border);
    align-items: center;
  }

  .lesson-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0px var(--border);
  }

  .lesson-card__number {
    font-size: 2rem;
    font-weight: 900;
    color: #e2e8f0;
    line-height: 1;
  }

  .lesson-card__title {
    font-size: 1.15rem;
    font-weight: 900;
    margin: 0 0 0.25rem;
  }

  .lesson-card__cta {
    font-size: 0.9rem;
    font-weight: 800;
    color: #475569;
  }
</style>
