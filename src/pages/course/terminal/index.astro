---
import Layout from '../../../layouts/Layout.astro';
import { courses } from '../../../data/courses';

const termCourse = courses.find(c => c.slug === 'terminal');
if (!termCourse) {
  throw new Error("No se encontró el curso 'terminal' en el archivo de datos.");
}
---

<Layout title="Curso de Terminal Unix/Bash: La Base del Programador" description="Domina el CLI: comandos básicos, navegación, manipulación de archivos, procesos y redes en Linux." courseSlug="terminal">
  <div class="course-container">
    <header class="course-index-header">
      <h1 class="course-big-title" style={`--course-color: ${termCourse.color}`}>
        <span class="prompt-sym">$</span> {termCourse.name}
      </h1>
      <p class="course-description">
        {termCourse.description}
      </p>
    </header>

    <div class="cards-grid">
      {termCourse.lessons?.map((lesson, index) => (
        <a href={lesson.href} class="lesson-card">
          <div class="lesson-card__number">{index + 1}</div>
          <div class="lesson-card__content">
            <h3 class="lesson-card__title">{lesson.title}</h3>
            <span class="lesson-card__cta">Ejecutar comando →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .course-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .course-index-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .course-big-title {
    font-size: clamp(2rem, 7vw, 3.5rem);
    font-weight: 900;
    color: #1a1a1b;
    margin-bottom: 1rem;
    line-height: 1;
    font-family: 'JetBrains Mono', monospace;
    text-shadow: 4px 4px 0px var(--border);
  }

  .prompt-sym { color: #8b5cf6; }

  .course-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    font-weight: 700;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .lesson-card {
    display: flex;
    gap: 1rem;
    background: white;
    border: 3px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 4px 4px 0px var(--border);
    align-items: center;
  }

  .lesson-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0px var(--border);
    background: #f8fafc;
  }

  .lesson-card__number {
    font-size: 2rem;
    font-weight: 900;
    color: var(--border);
    opacity: 0.15;
    line-height: 1;
    font-family: 'JetBrains Mono', monospace;
  }

  .lesson-card__title {
    font-size: 1.15rem;
    font-weight: 900;
    margin: 0 0 0.25rem;
  }

  .lesson-card__cta {
    font-size: 0.9rem;
    font-weight: 800;
    color: #1a1a1b;
    font-family: 'Courier New', monospace;
  }
</style>
