---
import Layout from '../../../layouts/Layout.astro';
import { courses } from '../../../data/courses';

const curso = courses.find((c) => c.slug === 'estructuras-datos');
if (!curso) {
  throw new Error("No se encontró el curso 'estructuras-datos'.");
}
---

<Layout title="Estructuras de datos (Java)" description={curso.description} courseSlug="estructuras-datos">
  <div class="course-container">
    <header class="course-index-header">
      <h1 class="course-big-title" style={`--course-color: ${curso.color}`}>
        {curso.name}
      </h1>
      <p class="course-description">{curso.description}</p>
      <p class="course-tagline">
        En Java, los <strong>nodos</strong> se conectan con <strong>referencias</strong> (<code>nodo.siguiente = otro;</code>): no hay punteros
        explícitos, pero el efecto es el mismo en memoria.
      </p>
    </header>

    <div class="cards-grid">
      {curso.lessons?.map((lesson, index) => (
        <a href={lesson.href} class="lesson-card">
          <div class="lesson-card__number">{index + 1}</div>
          <div class="lesson-card__content">
            <h3 class="lesson-card__title">{lesson.title}</h3>
            <span class="lesson-card__cta">Entrar al módulo →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .course-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .course-index-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .course-big-title {
    font-size: clamp(2rem, 7vw, 3.5rem);
    font-weight: 900;
    color: var(--course-color, #0d9488);
    margin-bottom: 1rem;
    line-height: 1;
    font-family: 'Nunito', sans-serif;
    text-shadow: 4px 4px 0px var(--border);
  }
  .course-description {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 680px;
    margin: 0 auto 1rem;
    font-weight: 700;
  }
  .course-tagline {
    font-size: 1rem;
    max-width: 640px;
    margin: 0 auto;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.5;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .lesson-card {
    display: flex;
    gap: 1rem;
    background: white;
    border: 3px solid var(--border);
    border-radius: 20px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 4px 4px 0px var(--border);
    align-items: center;
  }
  .lesson-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0px var(--border);
  }
  .lesson-card__number {
    font-size: 2rem;
    font-weight: 900;
    color: #e2e8f0;
    line-height: 1;
  }
  .lesson-card__title {
    font-size: 1.05rem;
    font-weight: 900;
    margin: 0 0 0.25rem;
  }
  .lesson-card__cta {
    font-size: 0.9rem;
    font-weight: 800;
    color: #0d9488;
  }
</style>
