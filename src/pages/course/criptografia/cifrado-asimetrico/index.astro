const pythonCode = `from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives import hashes

# 1. Generar par de claves RSA de 2048 bits
private_key = rsa.generate_private_key(
    public_exponent=65537,
    key_size=2048
)
public_key = private_key.public_key()

message = b"Mensaje secreto para cifrado asimetrico"

# 2. Cifrar con la clave publica usando padding OAEP y SHA-256
ciphertext = public_key.encrypt(
    message,
    padding.OAEP(
        mgf=padding.MGF1(algorithm=hashes.SHA256()),
        algorithm=hashes.SHA256(),
        label=None
    )
)
print(f"Cifrado (hex): {ciphertext.hex()[:60]}...")

# 3. Descifrar con la clave privada
decrypted = private_key.decrypt(
    ciphertext,
    padding.OAEP(
        mgf=padding.MGF1(algorithm=hashes.SHA256()),
        algorithm=hashes.SHA256(),
        label=None
    )
)
print(f"Descifrado: {decrypted.decode('utf-8')}")`;

const javaCode = `import javax.crypto.Cipher;
import java.security.KeyPair;
import java.security.KeyPairGenerator;
import java.security.spec.MGF1ParameterSpec;
import javax.crypto.spec.OAEPParameterSpec;
import javax.crypto.spec.PSource;
import java.util.Base64;

public class EncriptacionAsimetrica {
    public static void main(String[] args) throws Exception {
        // 1. Generar par de claves RSA
        KeyPairGenerator keyGen = KeyPairGenerator.getInstance("RSA");
        keyGen.initialize(2048);
        KeyPair pair = keyGen.generateKeyPair();

        String message = "Mensaje secreto para cifrado asimetrico";

        // 2. Configurar padding OAEP con SHA-256
        OAEPParameterSpec oaepSpec = new OAEPParameterSpec(
            "SHA-256", "MGF1", MGF1ParameterSpec.SHA256, PSource.PSpecified.DEFAULT
        );

        // 3. Cifrar con clave publica
        Cipher cipher = Cipher.getInstance("RSA/ECB/OAEPWithSHA-256AndMGF1Padding");
        cipher.init(Cipher.ENCRYPT_MODE, pair.getPublic(), oaepSpec);
        byte[] ciphertext = cipher.doFinal(message.getBytes("UTF-8"));
        System.out.println("Cifrado (Base64): " + Base64.getEncoder().encodeToString(ciphertext).substring(0, 60) + "...");

        // 4. Descifrar con clave privada
        cipher.init(Cipher.DECRYPT_MODE, pair.getPrivate(), oaepSpec);
        byte[] decrypted = cipher.doFinal(ciphertext);
        System.out.println("Descifrado: " + new String(decrypted, "UTF-8"));
    }
}`;

const phpCode = `<?php
// 1. Generar un nuevo par de claves RSA de 2048 bits
$config = [
    "digest_alg" => "sha256",
    "private_key_bits" => 2048,
    "private_key_type" => OPENSSL_KEYTYPE_RSA,
];
$pkey = openssl_pkey_new($config);
openssl_pkey_export($pkey, $private_key);

$details = openssl_pkey_get_details($pkey);
$public_key = $details["key"];

$message = "Mensaje secreto para cifrado asimetrico";

// 2. Cifrar con clave publica usando padding OAEP (SHA-256)
openssl_public_encrypt($message, $ciphertext, $public_key, OPENSSL_PKCS1_OAEP_PADDING);
echo "Cifrado (hex): " . bin2hex(substr($ciphertext, 0, 30)) . "...\n";

// 3. Descifrar con clave privada
openssl_private_decrypt($ciphertext, $decrypted, $private_key, OPENSSL_PKCS1_OAEP_PADDING);
echo "Descifrado: " . $decrypted . "\n";
?>`;

const jsCode = `const crypto = require('crypto');

// 1. Generar par de claves RSA de 2048 bits
const { publicKey, privateKey } = crypto.generateKeyPairSync('rsa', {
    modulusLength: 2048,
    publicKeyEncoding: { type: 'spki', format: 'pem' },
    privateKeyEncoding: { type: 'pkcs8', format: 'pem' }
});

const message = Buffer.from("Mensaje secreto para cifrado asimetrico");

// 2. Cifrar con clave publica usando OAEP con SHA-256
const ciphertext = crypto.publicEncrypt({
    key: publicKey,
    padding: crypto.constants.RSA_PKCS1_OAEP_PADDING,
    oaepHash: "sha256"
}, message);
console.log(\`Cifrado (hex): \${ciphertext.toString('hex').substring(0, 60)}...\`);

// 3. Descifrar con clave privada
const decrypted = crypto.privateDecrypt({
    key: privateKey,
    padding: crypto.constants.RSA_PKCS1_OAEP_PADDING,
    oaepHash: "sha256"
}, ciphertext);
console.log(\`Descifrado: \${decrypted.toString('utf8')}\`);`;

const csharpCode = `using System;
using System.Security.Cryptography;
using System.Text;

public class EncriptacionAsimetrica {
    public static void Main() {
        // 1. Generar par de claves RSA de 2048 bits
        using (RSA rsa = RSA.Create(2048)) {
            string message = "Mensaje secreto para cifrado asimetrico";
            byte[] messageBytes = Encoding.UTF8.GetBytes(message);

            // 2. Cifrar con la clave publica usando padding OAEP y SHA-256
            byte[] ciphertext = rsa.Encrypt(messageBytes, RSAEncryptionPadding.OaepSHA256);
            Console.WriteLine("Cifrado (hex): " + Convert.ToHexString(ciphertext).Substring(0, 60) + "...");

            // 3. Descifrar con la clave privada
            byte[] decryptedBytes = rsa.Decrypt(ciphertext, RSAEncryptionPadding.OaepSHA256);
            string decrypted = Encoding.UTF8.GetString(decryptedBytes);
            Console.WriteLine("Descifrado: " + decrypted);
        }
    }
}`;
