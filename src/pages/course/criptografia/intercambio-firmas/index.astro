const pythonCode = `from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives import hashes

# 1. Generar claves
private_key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
public_key = private_key.public_key()

mensaje = b"Documento oficial de transferencia"

# 2. Firmar el mensaje con la clave privada
firma = private_key.sign(
    mensaje,
    padding.PSS(
        mgf=padding.MGF1(hashes.SHA256()),
        salt_length=padding.PSS.MAX_LENGTH
    ),
    hashes.SHA256()
)
print(f"Firma (hex): {firma.hex()[:60]}...")

# 3. Verificar la firma con la clave publica
try:
    public_key.verify(
        firma,
        mensaje,
        padding.PSS(
            mgf=padding.MGF1(hashes.SHA256()),
            salt_length=padding.PSS.MAX_LENGTH
        ),
        hashes.SHA256()
    )
    print("Firma VALIDA y verificada con éxito.")
except Exception:
    print("Firma INVALIDA. El mensaje ha sido alterado.")`;

const javaCode = `import java.security.*;
import java.util.Base64;

public class FirmasDigitales {
    public static void main(String[] args) throws Exception {
        // 1. Generar par de claves RSA
        KeyPairGenerator keyGen = KeyPairGenerator.getInstance("RSA");
        keyGen.initialize(2048);
        KeyPair pair = keyGen.generateKeyPair();

        byte[] mensaje = "Documento oficial de transferencia".getBytes("UTF-8");

        // 2. Firmar usando la clave privada y SHA256withRSA
        Signature privateSignature = Signature.getInstance("SHA256withRSA");
        privateSignature.initSign(pair.getPrivate());
        privateSignature.update(mensaje);
        byte[] firma = privateSignature.sign();
        System.out.println("Firma (Base64): " + Base64.getEncoder().encodeToString(firma).substring(0, 60) + "...");

        // 3. Verificar usando la clave publica
        Signature publicSignature = Signature.getInstance("SHA256withRSA");
        publicSignature.initVerify(pair.getPublic());
        publicSignature.update(mensaje);
        boolean esValida = publicSignature.verify(firma);
        System.out.println("¿Firma valida?: " + esValida);
    }
}`;

const phpCode = `<?php
// 1. Generar par de claves
$config = [
    "digest_alg" => "sha256",
    "private_key_bits" => 2048,
    "private_key_type" => OPENSSL_KEYTYPE_RSA,
];
$pkey = openssl_pkey_new($config);
openssl_pkey_export($pkey, $private_key);

$details = openssl_pkey_get_details($pkey);
$public_key = $details["key"];

$mensaje = "Documento oficial de transferencia";

// 2. Firmar el mensaje con la clave privada usando SHA-256
openssl_sign($mensaje, $firma, $private_key, OPENSSL_ALGO_SHA256);
echo "Firma (hex): " . bin2hex(substr($firma, 0, 30)) . "...\n";

// 3. Verificar la firma con la clave publica
$resultado = openssl_verify($mensaje, $firma, $public_key, OPENSSL_ALGO_SHA256);
if ($resultado === 1) {
    echo "Firma VALIDA.\n";
} else {
    echo "Firma INVALIDA o alterada.\n";
}
?>`;

const jsCode = `const crypto = require('crypto');

// 1. Generar par de claves
const { publicKey, privateKey } = crypto.generateKeyPairSync('rsa', {
    modulusLength: 2048,
    publicKeyEncoding: { type: 'spki', format: 'pem' },
    privateKeyEncoding: { type: 'pkcs8', format: 'pem' }
});

const mensaje = Buffer.from("Documento oficial de transferencia");

// 2. Firmar con la clave privada y SHA-256
const sign = crypto.createSign('SHA256');
sign.update(mensaje);
const firma = sign.sign(privateKey);
console.log("Firma (hex):", firma.toString('hex').substring(0, 60) + "...");

// 3. Verificar con la clave publica
const verify = crypto.createVerify('SHA256');
verify.update(mensaje);
const esValida = verify.verify(publicKey, firma);
console.log("¿Firma valida?:", esValida);`;

const csharpCode = `using System;
using System.Security.Cryptography;
using System.Text;

public class FirmasDigitales {
    public static void Main() {
        // 1. Generar par de claves RSA de 2048 bits
        using (RSA rsa = RSA.Create(2048)) {
            byte[] mensaje = Encoding.UTF8.GetBytes("Documento oficial de transferencia");

            // 2. Firmar usando la clave privada y SHA-256
            byte[] firma = rsa.SignData(mensaje, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1);
            Console.WriteLine("Firma (Base64): " + Convert.ToBase64String(firma).Substring(0, 60) + "...");

            // 3. Verificar usando la clave publica
            bool esValida = rsa.VerifyData(mensaje, firma, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1);
            Console.WriteLine("¿Firma valida?: " + esValida);
        }
    }
}`;
