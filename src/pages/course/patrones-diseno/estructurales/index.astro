---
import Layout from '../../../../layouts/Layout.astro';
import PatternSection from '../../../../components/patterns/PatternSection.astro';
import { REFACTORING_GURU_DESIGN_PATTERNS_ES, patronesEstructurales } from '../../../../data/designPatterns';
---

<Layout
  title="Patrones estructurales"
  description="Adapter, Bridge, Composite, Decorator, Facade, Flyweight y Proxy con ejemplos multilenguaje."
  courseSlug="patrones-diseno"
>
  <article class="content-section">
    <h1>3. Patrones estructurales</h1>

    <section class="mb-10">
      <p>
        Explican <strong>cómo componer</strong> clases y objetos para obtener estructuras más grandes: adaptar interfaces,
        añadir comportamiento por capas, unificar árboles, simplificar fachadas o compartir estado intrínseco.
      </p>
      <p class="font-bold text-[var(--text-secondary)]">
        <a href={REFACTORING_GURU_DESIGN_PATTERNS_ES} target="_blank" rel="noopener noreferrer">
          Catálogo en Refactoring.Guru ↗
        </a>
      </p>
    </section>

    {patronesEstructurales.map((p) => (
      <PatternSection pattern={p} />
    ))}

    <nav class="nav-bottom">
      <a href="/course/patrones-diseno/creacionales/" class="prev">← Creacionales</a>
      <a href="/course/patrones-diseno/comportamiento/" class="next">Comportamiento →</a>
    </nav>
  </article>
</Layout>
