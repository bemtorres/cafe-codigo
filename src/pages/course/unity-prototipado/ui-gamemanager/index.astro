const gameManagerCode = `using UnityEngine;
using TMPro; // Libreria necesaria para manejar TextMeshPro

public class GameManager : MonoBehaviour
{
    // Instancia unica (Singleton) accesible por cualquier script
    public static GameManager Instance { get; private set; }

    [Header("UI References")]
    [SerializeField] private TextMeshProUGUI scoreText;
    [SerializeField] private TextMeshProUGUI timerText;
    [SerializeField] private TextMeshProUGUI winLoseText;

    [Header("Game Settings")]
    [SerializeField] private int totalCoinsToWin = 5;
    [SerializeField] private float timeLimit = 30f;

    private int score = 0;
    private float timeRemaining;
    private bool isGameOver = false;

    void Awake()
    {
        // Configuracion del patron Singleton
        if (Instance == null) { Instance = this; }
        else { Destroy(gameObject); }
    }

    void Start()
    {
        timeRemaining = timeLimit;
        UpdateUI();
        winLoseText.text = ""; // Limpiamos el texto al iniciar
    }

    void Update()
    {
        if (isGameOver) return;

        // Cuenta regresiva del tiempo
        if (timeRemaining > 0)
        {
            timeRemaining -= Time.deltaTime;
            UpdateUI();
        }
        else
        {
            GameOver(false); // Perder por tiempo
        }
    }

    public void CollectCoin()
    {
        if (isGameOver) return;

        score++;
        UpdateUI();

        if (score >= totalCoinsToWin)
        {
            GameOver(true); // Ganar el juego
        }
    }

    public void HitObstacle()
    {
        if (isGameOver) return;
        
        GameOver(false); // Perder por chocar contra un peligro
    }

    private void UpdateUI()
    {
        scoreText.text = "Monedas: " + score + " / " + totalCoinsToWin;
        timerText.text = "Tiempo: " + Mathf.Max(0, Mathf.CeilToInt(timeRemaining)) + "s";
    }

    private void GameOver(bool won)
    {
        isGameOver = true;
        if (won)
        {
            winLoseText.text = "¡VICTORIA! 🎉";
            winLoseText.color = Color.green;
        }
        else
        {
            winLoseText.text = "GAME OVER 💀";
            winLoseText.color = Color.red;
        }
    }
}`;

const playerUpdateCode = `// Modificacion dentro de PlayerController.cs al interactuar con objetos

private void OnTriggerEnter(Collider other)
{
    if (other.CompareTag("Coin"))
    {
        other.gameObject.SetActive(false);
        
        // Reportamos al GameManager la recoleccion usando la instancia Singleton
        GameManager.Instance.CollectCoin();
    }
}

private void OnCollisionEnter(Collision collision)
{
    if (collision.gameObject.CompareTag("Obstacle"))
    {
        // Reportamos al GameManager que chocamos contra un peligro
        GameManager.Instance.HitObstacle();
    }
}`;
