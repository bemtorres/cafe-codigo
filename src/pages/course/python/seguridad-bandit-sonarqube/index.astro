const codeBanditInseguro = `# vulnerabilidades.py (CUIDADO: Código Inseguro)
import pickle
import os

# ❌ Fallo 1: Contraseña hardcoded (expuesta directamente en código)
ADMIN_PASSWORD = "SuperSecretPassword123"

def autenticar(input_pass):
    # Comparación de contraseña insegura
    return input_pass == ADMIN_PASSWORD

# ❌ Fallo 2: Uso de eval() permitiendo inyección de código
def ejecutar_calculo(operacion_usuario):
    # eval ejecuta CUALQUIER string de Python. Si el usuario escribe os.system('rm -rf /'), se ejecutará.
    return eval(operacion_usuario)

# ❌ Fallo 3: Deserialización peligrosa con pickle
def deserializar_datos(datos_red):
    # pickle.loads puede ejecutar código arbitrario incrustado en los bytes binarios
    return pickle.loads(datos_red)`;

const codeBanditCorregido = `# seguridad_corregida.py (Seguro y Aprobado)
import json
import os
import secrets

# ✔ Solución 1: Cargar secretos desde Variables de Entorno
ADMIN_PASSWORD_HASH = os.getenv("APP_ADMIN_HASH", "")

def autenticar_seguro(input_pass):
    # Usar secrets para comparar en tiempo constante y evitar ataques de canal lateral
    return secrets.compare_digest(input_pass, os.getenv("ADMIN_PASSWORD", ""))

# ✔ Solución 2: Reemplazar eval() por evaluación segura o casteo estricto
def ejecutar_calculo_seguro(operacion_usuario):
    # Validamos estrictamente que la entrada contenga solo dígitos y operadores básicos
    # O mejor aún, evitamos eval por completo usando un parser seguro
    if not all(c.isdigit() or c in "+-*/. " for c in operacion_usuario):
        raise ValueError("Entrada peligrosa detectada")
    # Alternativa segura: usar una librería especializada como ast.literal_eval si es una estructura
    return eval(operacion_usuario)

# ✔ Solución 3: Usar JSON en lugar de Pickle para intercambiar datos en red
def deserializar_datos_seguros(datos_json_red):
    # JSON es solo texto estructurado, no puede ejecutar código al deserializar
    return json.loads(datos_json_red)`;

const codeSonarQubeInseguro = `# inventario.py (Código difícil de mantener - Spaguetti)
def procesar_tienda(lista_productos, descuento_aplicar):
    # ❌ Fallo 1: Alta Complejidad Cognitiva (Demasiados if anidados)
    # ❌ Fallo 2: Variables mal nombradas (nombres sin significado claro)
    # ❌ Fallo 3: Código duplicado
    for p in lista_productos:
        if p["activo"]:
            if p["stock"] > 0:
                if p["categoria"] == "Bebidas":
                    p["precio"] = p["precio"] - (p["precio"] * descuento_aplicar)
                    print("Descuento aplicado a " + p["nombre"])
                else:
                    if p["categoria"] == "Pastelería":
                        p["precio"] = p["precio"] - (p["precio"] * (descuento_aplicar / 2))
                        print("Descuento medio aplicado a " + p["nombre"])
            else:
                print("Sin stock: " + p["nombre"])
        else:
            print("Inactivo: " + p["nombre"])`;

const codeSonarQubeCorregido = `# inventario_limpio.py (Limpio y Mantenible)
# ✔ Solución: Separación de responsabilidades, nombres descriptivos y simplicidad

def calcular_descuento(categoria: str, precio: float, tasa_base: float) -> float:
    """Calcula el descuento según la categoría del producto de forma clara."""
    if categoria == "Bebidas":
        return precio * tasa_base
    if categoria == "Pastelería":
        return precio * (tasa_base / 2)
    return 0.0

def aplicar_descuentos_productos(productos: list, tasa_descuento: float):
    """Procesa el inventario aplicando descuentos de forma legible."""
    for producto in productos:
        nombre = producto.get("nombre", "Sin Nombre")
        
        if not producto.get("activo", False):
            print(f"Inactivo: {nombre}")
            continue
            
        if producto.get("stock", 0) <= 0:
            print(f"Sin stock: {nombre}")
            continue
            
        descuento = calcular_descuento(producto.get("categoria", ""), producto.get("precio", 0.0), tasa_descuento)
        producto["precio"] -= descuento
        if descuento > 0:
            print(f"Descuento aplicado a {nombre} (Guardado: \${descuento})")`;

const codeRetoIntegrador = `# reto_calidad.py
# Analiza este código. ¿Qué alertaría Bandit y qué alertaría SonarQube?
import os

def procesar_usuario(u, p):
    # Secreto expuesto
    key = "123456"
    # Uso de eval riesgoso
    x = eval(u)
    # Código duplicado / spaghetti
    if p == "admin":
        if key == "123456":
            print("Acceso total")
            if x > 10:
                print("Alerta")
    else:
        if p == "user":
            print("Acceso limitado")
            if x > 10:
                print("Alerta")`;
