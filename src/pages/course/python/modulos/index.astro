const codeValidadorRut = `# validador_rut.py
from itertools import cycle

def validar_rut(rut):
    # Limpiamos el RUT de puntos y guiones, y pasamos a mayúsculas
    rut = rut.replace(".", "").replace("-", "").upper().strip()
    if len(rut) < 2:
        return False
    
    cuerpo = rut[:-1]
    dv = rut[-1]
    
    # Validamos que el cuerpo contenga solo dígitos
    if not cuerpo.isdigit():
        return False
        
    # Calculamos el Dígito Verificador usando el Módulo 11
    revertido = map(int, reversed(cuerpo))
    factores = cycle(range(2, 8))
    suma = sum(d * f for d, f in zip(revertido, factores))
    res = 11 - (suma % 11)
    
    dv_esperado = 'K' if res == 10 else '0' if res == 11 else str(res)
    
    return dv == dv_esperado`;

