const codeCryptographyUsage = `# Primero instalas con: pip install cryptography
from cryptography.fernet import Fernet

# 1. Generamos una llave de encriptación segura
llave = Fernet.generate_key()
fernet_client = Fernet(llave)

# 2. Encriptamos información sensible (como la contraseña de un cliente)
password_secreta = b"CafeteraUltraSegura2026"
password_encriptada = fernet_client.encrypt(password_secreta)

print(f"Llave de Encriptación: {llave.decode()}")
print(f"Password Encriptada (Bytes cifrados): {password_encriptada.decode()}")

# 3. Desencriptamos para recuperar el texto original
password_desencriptada = fernet_client.decrypt(password_encriptada)
print(f"Password Recuperada: {password_desencriptada.decode()}")`;
