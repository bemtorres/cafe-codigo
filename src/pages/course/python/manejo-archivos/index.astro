const codePersistenciaBasica = `# Estructura básica para escribir (w = write)
with open("saludo.txt", "w", encoding="utf-8") as archivo:
    archivo.write("¡Bienvenidos a la Cafetería Python!\\n")

# Estructura básica para leer (r = read)
with open("saludo.txt", "r", encoding="utf-8") as archivo:
    contenido = archivo.read()
    print(contenido)`;

const codeCatalogoCsv = `import csv

# Nuestros productos de la cafetería representados como [[codigo, nombre, precio]]
productos = [
    ["C001", "Café Expreso", 1500],
    ["C002", "Capuchino Italiano", 2200],
    ["C003", "Medialuna Dulce", 800],
    ["C004", "Tarta de Arándanos", 2500]
]

# 1. Guardar a CSV usando PUNTO Y COMA (;) como delimitador
with open("productos.csv", "w", newline="", encoding="utf-8") as archivo:
    # Pasamos delimiter=";" para cambiar el delimitador
    escritor = csv.writer(archivo, delimiter=";")
    escritor.writerows(productos)
print("¡Catálogo guardado con éxito en productos.csv!")

# 2. Importar/Leer desde el archivo CSV con delimitador ";"
productos_importados = []
with open("productos.csv", "r", encoding="utf-8") as archivo:
    lector = csv.reader(archivo, delimiter=";")
    for fila in lector:
        if fila:  # Evitar líneas vacías
            codigo = fila[0]
            nombre = fila[1]
            precio = int(fila[2])  # Convertimos a entero para poder operar
            productos_importados.append([codigo, nombre, precio])

print("Productos cargados:", productos_importados)`;

const codeVouchersTxt = `import datetime

# Generar un voucher de entrega (Boleta) para un cliente
def guardar_boleta(cliente, productos_comprados, total):
    fecha_hora = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    nombre_archivo = f"boleta_{cliente.lower().replace(' ', '_')}.txt"
    
    with open(nombre_archivo, "w", encoding="utf-8") as boleta:
        boleta.write("========================================\\n")
        boleta.write("         CAFETERÍA PYTHON EXPRESS        \\n")
        boleta.write("========================================\\n")
        boleta.write(f"Cliente: {cliente}\\n")
        boleta.write(f"Fecha: {fecha_hora}\\n")
        boleta.write("----------------------------------------\\n")
        for prod, cant, subtotal in productos_comprados:
            boleta.write(f"{prod:<22} x{cant:<3} \${subtotal:>8}\\n")
        boleta.write("----------------------------------------\\n")
        boleta.write(f"TOTAL PAGADO:                 \${total:>8}\\n")
        boleta.write("========================================\\n")
        boleta.write("      ¡Gracias por su preferencia!      \\n")
        boleta.write("========================================\\n")
    print(f"Boleta guardada como: {nombre_archivo}")

# Guardar o actualizar el reporte acumulado del día (reporte_caja.txt)
def registrar_en_reporte_diario(cliente, total_venta):
    fecha_hora = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    # Usamos "a" para añadir datos sin sobreescribir el reporte existente
    with open("reporte_caja.txt", "a", encoding="utf-8") as reporte:
        reporte.write(f"[{fecha_hora}] Venta a {cliente} por un total de: \${total_venta}\\n")

# Simulamos una venta
compra = [
    ["Café Expreso", 2, 3000],
    ["Medialuna Dulce", 3, 2400]
]
guardar_boleta("Benjamín Torres", compra, 5400)
registrar_en_reporte_diario("Benjamín Torres", 5400)`;

const codeInventarioJson = `import json

# Estructura del menú con stock y categoría utilizando diccionarios
inventario_completo = {
    "C001": {"nombre": "Café Expreso", "precio": 1500, "stock": 50, "categoria": "Bebidas"},
    "C002": {"nombre": "Capuchino Italiano", "precio": 2200, "stock": 30, "categoria": "Bebidas"},
    "C003": {"nombre": "Medialuna Dulce", "precio": 800, "stock": 100, "categoria": "Pastelería"}
}

# 1. Guardar diccionario a JSON (Escribir con identación legible)
with open("inventario.json", "w", encoding="utf-8") as archivo_json:
    # indent=4 le da un formato visual ordenado y estructurado
    # ensure_ascii=False respeta los acentos y caracteres del español
    json.dump(inventario_completo, archivo_json, indent=4, ensure_ascii=False)
print("Inventario JSON guardado.")

# 2. Cargar/Importar diccionario desde JSON
with open("inventario.json", "r", encoding="utf-8") as archivo_json:
    datos_cargados = json.load(archivo_json)

# Acceder de forma estructurada
print("El precio del Capuchino es:", datos_cargados["C002"]["precio"])`;

const codeDelimitadorPersonalizado = `# Creamos un archivo de prueba con delimitador personalizado '|'
with open("pedidos.txt", "w", encoding="utf-8") as f:
    f.write("Daniela|Café Cortado|2|3600\\n")
    f.write("Andrés|Té Verde|1|1500\\n")
    f.write("Sofía|Tarta de Manzana|2|4400\\n")

# Leemos y procesamos usando split('|')
with open("pedidos.txt", "r", encoding="utf-8") as f:
    for linea in f:
        linea = linea.strip()
        if not linea:
            continue
        # Separamos usando nuestro delimitador vertical
        cliente, producto, cant, total = linea.split("|")
        print(f"El cliente {cliente} pidió {cant}x '{producto}' pagando \${total} en total.")`;

const codeCafeteriaCompleta = `import csv
import json
import datetime
import os

# Base de datos en memoria (Lista de listas para productos)
# Estructura: [codigo, nombre, precio, stock]
catalogo = []

# Cargar catálogo de ejemplo en CSV si no existe
def inicializar_csv_si_no_existe():
    if not os.path.exists("catalogo_inicial.csv"):
        datos = [
            ["C01", "Café Americano", 1200, 100],
            ["C02", "Café Latte", 1800, 80],
            ["C03", "Muffin de Chocolate", 1100, 50],
            ["C04", "Jugo de Naranja Natural", 2000, 30]
        ]
        with open("catalogo_inicial.csv", "w", newline="", encoding="utf-8") as f:
            escritor = csv.writer(f, delimiter=";")
            escritor.writerows(datos)
        print("-> Archivo 'catalogo_inicial.csv' de muestra creado.")

# 1. IMPORTAR PRODUCTOS DESDE CSV
def importar_catalogo_csv():
    global catalogo
    catalogo = []
    try:
        with open("catalogo_inicial.csv", "r", encoding="utf-8") as f:
            lector = csv.reader(f, delimiter=";")
            for fila in lector:
                if fila:
                    codigo = fila[0]
                    nombre = fila[1]
                    precio = int(fila[2])
                    stock = int(fila[3])
                    catalogo.append([codigo, nombre, precio, stock])
        print(f"✔ Catálogo importado correctamente. {len(catalogo)} productos cargados.")
    except FileNotFoundError:
        print("❌ Error: No se encontró 'catalogo_inicial.csv'. Por favor, inicialízalo primero.")

# 2. VENDER Y EMITIR BOLETA TXT
def realizar_venta():
    if not catalogo:
        print("⚠ Primero debes importar el catálogo (Opción 1).")
        return

    print("\\n--- MENÚ DE PRODUCTOS ---")
    for prod in catalogo:
        print(f"Código: {prod[0]} | {prod[1]:<22} | Precio: \${prod[2]:>5} | Stock: {prod[3]}")
    
    cliente = input("\\nNombre del cliente: ").strip()
    if not cliente:
        print("❌ El nombre del cliente no puede estar vacío.")
        return

    productos_vendidos = []
    total_venta = 0

    while True:
        codigo_buscado = input("Escribe el código del producto a comprar (o 'fin' para cobrar): ").strip().upper()
        if codigo_buscado == "FIN":
            break
        
        # Buscar producto
        producto_encontrado = None
        for prod in catalogo:
            if prod[0] == codigo_buscado:
                producto_encontrado = prod
                break
        
        if not producto_encontrado:
            print("❌ Código de producto no encontrado. Intenta nuevamente.")
            continue
        
        # Validar stock
        try:
            cantidad = int(input(f"Cantidad de '{producto_encontrado[1]}' (Disponibles: {producto_encontrado[3]}): "))
            if cantidad <= 0:
                print("❌ La cantidad debe ser mayor que 0.")
                continue
            if cantidad > producto_encontrado[3]:
                print("❌ No hay suficiente stock disponible.")
                continue
        except ValueError:
            print("❌ Debes ingresar un número entero válido.")
            continue

        # Descontar stock y agregar a la venta
        producto_encontrado[3] -= cantidad  # Descontamos stock del catálogo
        subtotal = producto_encontrado[2] * cantidad
        total_venta += subtotal
        productos_vendidos.append([producto_encontrado[1], cantidad, subtotal])
        print(f"✔ Agregado: {cantidad}x {producto_encontrado[1]} (\${subtotal})")

    if not productos_vendidos:
        print("⚠ No se realizó ninguna compra.")
        return

    # Guardar boleta en TXT
    guardar_boleta_txt(cliente, productos_vendidos, total_venta)
    # Registrar en bitácora de caja general en TXT
    registrar_venta_caja_txt(cliente, total_venta)
    
    print(f"✔ ¡Venta finalizada con éxito! Total: \${total_venta}")

def guardar_boleta_txt(cliente, items, total):
    nombre_archivo = f"boleta_{cliente.lower().replace(' ', '_')}_{datetime.datetime.now().strftime('%H%M%S')}.txt"
    with open(nombre_archivo, "w", encoding="utf-8") as f:
        f.write("========================================\\n")
        f.write("         CAFETERÍA PYTHON EXPRESS        \\n")
        f.write("========================================\\n")
        f.write(f"Cliente: {cliente}\\n")
        f.write(f"Fecha: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\n")
        f.write("----------------------------------------\\n")
        for nombre, cant, subtotal in items:
            f.write(f"{nombre:<22} x{cant:<3} \${subtotal:>8}\\n")
        f.write("----------------------------------------\\n")
        f.write(f"TOTAL PAGADO:                 \${total:>8}\\n")
        f.write("========================================\\n")
    print(f"-> Boleta virtual TXT generada: {nombre_archivo}")

def registrar_venta_caja_txt(cliente, total):
    with open("reporte_caja_diaria.txt", "a", encoding="utf-8") as f:
        f.write(f"[{datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] Cliente: {cliente} | Total: \${total}\\n")

# 3. EXPORTAR CATÁLOGO ACTUALIZADO Y VENTAS A DICCIONARIO + JSON
def exportar_estado_json():
    if not catalogo:
        print("⚠ No hay catálogo cargado para exportar.")
        return

    # Estructuramos en un diccionario robusto
    datos_cierre = {
        "fecha_cierre": datetime.datetime.now().strftime("%Y-%m-%d"),
        "productos_actualizados": {}
    }

    for prod in catalogo:
        codigo, nombre, precio, stock = prod
        # Mezclamos lista de listas convirtiéndolo a un diccionario estructurado
        datos_cierre["productos_actualizados"][codigo] = {
            "nombre": nombre,
            "precio": precio,
            "stock_restante": stock
        }

    with open("cierre_caja.json", "w", encoding="utf-8") as f:
        json.dump(datos_cierre, f, indent=4, ensure_ascii=False)
    print("✔ Reporte de inventario final y cierre exportado con éxito a 'cierre_caja.json'.")

# MENU PRINCIPAL DE LA CAFETERÍA
def main():
    inicializar_csv_si_no_existe()
    while True:
        print("\\n☕ === BIENVENIDO A CAFETERÍA PYTHON === ☕")
        print("1. Importar Catálogo Inicial (CSV con delimitador ';')")
        print("2. Realizar una Venta (Genera Boleta TXT y descuenta stock)")
        print("3. Exportar Inventario Actualizado y Cierre de Caja (JSON)")
        print("0. Salir del programa")
        
        opcion = input("Elige una opción: ").strip()
        if opcion == "1":
            importar_catalogo_csv()
        elif opcion == "2":
            realizar_venta()
        elif opcion == "3":
            exportar_estado_json()
        elif opcion == "0":
            print("¡Gracias por operar la cafetería! Buen día.")
            break
        else:
            print("❌ Opción inválida, intenta de nuevo.")

if __name__ == "__main__":
    main()`;
