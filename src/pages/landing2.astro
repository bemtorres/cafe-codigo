---
import Layout from '../layouts/Layout.astro';
import imagen1 from '../assets/images/imagen1.png';

const benefits = [
  {
    icon: '🗺️',
    title: 'Rutas claras',
    text: 'Un camino ordenado para saber qué estudiar hoy y qué viene después. Sin laberintos.',
  },
  {
    icon: '✍️',
    title: 'Práctica integrada',
    text: 'Ejercicios y ejemplos al lado de cada explicación. Aprendés haciendo, no solo leyendo.',
  },
  {
    icon: '🍵',
    title: 'Ritmo propio',
    text: 'Sin fechas rígidas ni presión. Estudiás cuando querés, hasta donde llegues hoy.',
  },
  {
    icon: '📱',
    title: 'Desde cualquier lugar',
    text: 'Computadora, tablet o celular. Tu progreso te acompaña a donde vayas.',
  },
];

const testimonials = [
  {
    quote: 'Dejé de sentirme perdido. Por fin supe qué estudiar primero y qué venía después.',
    name: 'María L.',
    role: 'Estudiante de sistemas',
  },
  {
    quote: 'Los ejemplos son cortos y claros. Se entiende sin tener que ver cinco videos más.',
    name: 'Lucas G.',
    role: 'Desarrollador junior',
  },
  {
    quote: 'Volví a estudiar después de años. El tono amable me sacó el miedo a no llegar.',
    name: 'Diego F.',
    role: 'Cambio de carrera',
  },
];
---

<Layout
  title="Aprende programación sin perderte"
  description="Café y Código: una guía en español, clara y paso a paso para aprender a programar desde cero, a tu ritmo."
>
  <div class="l2">
    <!-- Hero -->
    <section class="l2-hero">
      <div class="l2-hero-grid">
        <div class="l2-hero-text">
          <span class="l2-badge">
            <span class="l2-badge-dot"></span>
            En español · paso a paso
          </span>
          <h1 class="l2-h1">
            Aprende programación
            <em>sin perderte</em>
            entre tutoriales.
          </h1>
          <p class="l2-sub">
            Una guía clara y tranquila para avanzar desde cero, a tu ritmo,
            sin saltar entre mil pestañas buscando qué estudiar.
          </p>
          <a href="/cursos/" class="l2-cta">
            Empieza ahora
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <p class="l2-micro">Gratis · sin tarjeta · en español</p>
        </div>

        <div class="l2-hero-visual">
          <div class="l2-card-float l2-card-float-1">
            <span class="l2-float-dot" style="background:#06d6a0"></span>
            <span>Lección 3 · Variables</span>
            <span class="l2-float-check">✓</span>
          </div>
          <div class="l2-card-float l2-card-float-2">
            <span class="l2-float-dot" style="background:#45b3e0"></span>
            <span>Siguiente: Condicionales</span>
          </div>
          <div class="l2-hero-image">
            <img
              src={imagen1.src}
              alt="Aprende a programar con calma"
              width={imagen1.width}
              height={imagen1.height}
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Problema -->
    <section class="l2-problem">
      <div class="l2-container">
        <p class="l2-eyebrow">El problema</p>
        <h2 class="l2-h2">
          Aprender por tu cuenta no debería sentirse así.
        </h2>

        <div class="l2-pain-grid">
          <div class="l2-pain">
            <span class="l2-pain-icon">😵‍💫</span>
            <p>Diez pestañas abiertas y ninguna te dice <strong>qué estudiar primero</strong>.</p>
          </div>
          <div class="l2-pain">
            <span class="l2-pain-icon">🔀</span>
            <p>Saltás de un tutorial a otro y cada uno <strong>arranca desde cero</strong> de nuevo.</p>
          </div>
          <div class="l2-pain">
            <span class="l2-pain-icon">🫠</span>
            <p>Avanzás un rato, te frustrás y <strong>abandonás</strong> sin saber por qué.</p>
          </div>
        </div>

        <p class="l2-pain-outro">
          No es tu culpa. Es el camino el que está desordenado.
        </p>
      </div>
    </section>

    <!-- Solución -->
    <section class="l2-solution">
      <div class="l2-container">
        <div class="l2-solution-inner">
          <p class="l2-eyebrow l2-eyebrow-light">La solución</p>
          <h2 class="l2-h2 l2-h2-light">
            Un solo lugar, un solo camino, a tu ritmo.
          </h2>
          <p class="l2-solution-text">
            Café y Código ordena lo que necesitás aprender en rutas claras, con explicaciones
            cortas, ejemplos al lado y ejercicios para practicar. Así pasás de no saber por dónde
            empezar a avanzar con confianza, una lección a la vez.
          </p>

          <ol class="l2-steps">
            <li>
              <span class="l2-step-num">1</span>
              <div>
                <strong>Elegís una ruta.</strong>
                <p>Lógica, Python, web… la que más te interese.</p>
              </div>
            </li>
            <li>
              <span class="l2-step-num">2</span>
              <div>
                <strong>Leés y practicás.</strong>
                <p>Explicación breve + ejercicio en la misma pantalla.</p>
              </div>
            </li>
            <li>
              <span class="l2-step-num">3</span>
              <div>
                <strong>Avanzás con calma.</strong>
                <p>Sin fechas, sin presión. Tu progreso siempre visible.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <!-- Beneficios -->
    <section class="l2-benefits">
      <div class="l2-container">
        <p class="l2-eyebrow">Por qué funciona</p>
        <h2 class="l2-h2">Todo pensado para que no te pierdas.</h2>

        <ul class="l2-benefits-grid">
          {benefits.map((b) => (
            <li class="l2-benefit">
              <span class="l2-benefit-icon">{b.icon}</span>
              <h3>{b.title}</h3>
              <p>{b.text}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Testimonios -->
    <section class="l2-testimonials">
      <div class="l2-container">
        <p class="l2-eyebrow">Lo que dicen</p>
        <h2 class="l2-h2">Personas reales, caminos más claros.</h2>

        <div class="l2-testimonials-grid">
          {testimonials.map((t) => (
            <figure class="l2-testimonial">
              <div class="l2-quote-mark" aria-hidden="true">"</div>
              <blockquote>
                <p>{t.quote}</p>
              </blockquote>
              <figcaption>
                <strong>{t.name}</strong>
                <span>{t.role}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="l2-cta-final">
      <div class="l2-container">
        <div class="l2-cta-box">
          <span class="l2-cta-ornament" aria-hidden="true">☕</span>
          <h2>
            Servite un café.
            <em>Empezá a programar con calma.</em>
          </h2>
          <p>
            Abrí tu primera ruta hoy y descubrí lo cómodo que es aprender cuando el camino
            está ordenado para vos.
          </p>
          <a href="/cursos/" class="l2-cta l2-cta-lg">
            Empieza ahora
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <p class="l2-micro l2-micro-dark">
            Gratis para siempre · sin tarjeta · en español
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* ──────────────────────────────────────────────────────────────
     Landing 2 · Café y Código
     Paleta cálida, estética editorial y tranquila
     ────────────────────────────────────────────────────────────── */
  .l2 {
    --cream: #FBF6EE;
    --cream-2: #F3EADB;
    --coffee: #2B1D1B;
    --coffee-2: #4A3A37;
    --muted: #7A6B66;
    --accent: #B06D63;
    --accent-soft: #E8C8A9;
    --mint: #4CAE95;
    --mint-soft: #D6EDE4;
    --sky: #6CA7C4;
    --sky-soft: #DCEBF2;
    --line: rgba(43, 29, 27, 0.12);

    font-family: 'Nunito', 'Quicksand', system-ui, sans-serif;
    color: var(--coffee);
    background: var(--cream);
  }

  .l2-container {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Tipografía base */
  .l2-eyebrow {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }
  .l2-eyebrow-light {
    color: var(--accent-soft);
  }

  .l2-h1 {
    font-size: clamp(2.1rem, 5vw, 3.4rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
    color: var(--coffee);
  }
  .l2-h1 em {
    font-style: normal;
    color: var(--accent);
    display: inline;
    position: relative;
  }
  .l2-h1 em::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 0.35em;
    background: var(--accent-soft);
    opacity: 0.55;
    z-index: -1;
    border-radius: 4px;
  }

  .l2-h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.3rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0 0 1.5rem;
    max-width: 36ch;
  }
  .l2-h2-light { color: #FBF6EE; }

  .l2-sub {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.65;
    color: var(--coffee-2);
    max-width: 52ch;
    margin: 0 0 1.75rem;
    font-weight: 500;
  }

  /* ───────── HERO ───────── */
  .l2-hero {
    position: relative;
    padding: 3.5rem 1.5rem 4rem;
    background:
      radial-gradient(900px 380px at 85% -10%, rgba(176, 109, 99, 0.12), transparent 60%),
      radial-gradient(700px 300px at -5% 90%, rgba(76, 174, 149, 0.10), transparent 60%),
      var(--cream);
    overflow: hidden;
  }
  .l2-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(43, 29, 27, 0.055) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: linear-gradient(to bottom, black 0%, transparent 85%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 85%);
    pointer-events: none;
  }

  .l2-hero-grid {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .l2-hero-grid { grid-template-columns: 1.15fr 1fr; gap: 3.5rem; }
    .l2-hero { padding: 5rem 2rem 5.5rem; }
  }

  .l2-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(6px);
    border: 1px solid var(--line);
    color: var(--coffee-2);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }
  .l2-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--mint);
    box-shadow: 0 0 0 3px rgba(76, 174, 149, 0.2);
  }

  .l2-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--coffee);
    color: var(--cream);
    font-weight: 800;
    font-size: 1rem;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    border: none;
    box-shadow: 0 10px 24px -8px rgba(43, 29, 27, 0.35);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .l2-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 30px -10px rgba(43, 29, 27, 0.45);
    background: #1e1210;
  }
  .l2-cta svg { transition: transform 0.2s ease; }
  .l2-cta:hover svg { transform: translateX(3px); }

  .l2-cta-lg {
    font-size: 1.1rem;
    padding: 1.1rem 2rem;
    background: var(--cream);
    color: var(--coffee);
  }
  .l2-cta-lg:hover { background: white; }

  .l2-micro {
    margin-top: 0.9rem;
    font-size: 0.82rem;
    color: var(--muted);
    font-weight: 600;
  }
  .l2-micro-dark { color: rgba(251, 246, 238, 0.65); }

  /* Visual hero */
  .l2-hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 320px;
  }
  .l2-hero-image {
    position: relative;
    max-width: 420px;
    width: 100%;
    border-radius: 28px;
    overflow: hidden;
    background: white;
    box-shadow:
      0 30px 60px -20px rgba(43, 29, 27, 0.25),
      0 0 0 1px var(--line);
    transform: rotate(-1.2deg);
  }
  .l2-hero-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .l2-card-float {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: white;
    border: 1px solid var(--line);
    padding: 0.6rem 0.9rem;
    border-radius: 14px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--coffee);
    box-shadow: 0 14px 30px -12px rgba(43, 29, 27, 0.25);
    z-index: 2;
    white-space: nowrap;
  }
  .l2-card-float-1 {
    top: 12%;
    left: -2%;
    animation: l2-float 6s ease-in-out infinite;
  }
  .l2-card-float-2 {
    bottom: 10%;
    right: -2%;
    animation: l2-float 7s ease-in-out infinite reverse;
  }
  @media (max-width: 520px) {
    .l2-card-float-1 { left: 2%; }
    .l2-card-float-2 { right: 2%; }
  }
  .l2-float-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
  }
  .l2-float-check {
    color: var(--mint);
    font-weight: 900;
  }
  @keyframes l2-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ───────── PROBLEMA ───────── */
  .l2-problem {
    padding: 5rem 1.5rem;
    background: white;
    border-top: 1px solid var(--line);
  }

  .l2-pain-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 2rem 0 2rem;
  }
  @media (min-width: 720px) {
    .l2-pain-grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  }
  .l2-pain {
    display: flex;
    gap: 0.9rem;
    padding: 1.25rem;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: 16px;
  }
  .l2-pain-icon {
    font-size: 1.6rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .l2-pain p {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.55;
    color: var(--coffee-2);
  }
  .l2-pain strong { color: var(--coffee); }

  .l2-pain-outro {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0;
    max-width: 36ch;
  }

  /* ───────── SOLUCIÓN ───────── */
  .l2-solution {
    padding: 5rem 1.5rem;
    background: var(--coffee);
    color: var(--cream);
    position: relative;
    overflow: hidden;
  }
  .l2-solution::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(600px 300px at 85% 10%, rgba(176, 109, 99, 0.18), transparent 60%),
      radial-gradient(500px 250px at -5% 85%, rgba(76, 174, 149, 0.12), transparent 60%);
    pointer-events: none;
  }
  .l2-solution-inner { position: relative; }

  .l2-solution-text {
    color: rgba(251, 246, 238, 0.8);
    font-size: 1.08rem;
    line-height: 1.7;
    max-width: 58ch;
    margin: 0 0 2.5rem;
  }

  .l2-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 640px;
  }
  @media (min-width: 720px) {
    .l2-steps { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  }
  .l2-steps li {
    display: flex;
    gap: 0.9rem;
    background: rgba(251, 246, 238, 0.06);
    border: 1px solid rgba(251, 246, 238, 0.12);
    padding: 1.1rem 1.2rem;
    border-radius: 16px;
  }
  .l2-step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: white;
    font-weight: 900;
    border-radius: 999px;
    font-size: 0.95rem;
  }
  .l2-steps strong {
    display: block;
    color: var(--cream);
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }
  .l2-steps p {
    margin: 0;
    color: rgba(251, 246, 238, 0.7);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* ───────── BENEFICIOS ───────── */
  .l2-benefits {
    padding: 5rem 1.5rem;
    background: var(--cream);
  }

  .l2-benefits-grid {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 560px) {
    .l2-benefits-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  }
  @media (min-width: 900px) {
    .l2-benefits-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .l2-benefit {
    background: white;
    border: 1px solid var(--line);
    padding: 1.5rem;
    border-radius: 18px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .l2-benefit:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 35px -18px rgba(43, 29, 27, 0.2);
    border-color: var(--accent-soft);
  }
  .l2-benefit-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--cream-2);
    border-radius: 12px;
    font-size: 1.4rem;
    margin-bottom: 0.9rem;
  }
  .l2-benefit h3 {
    font-size: 1.08rem;
    font-weight: 800;
    margin: 0 0 0.4rem;
    color: var(--coffee);
  }
  .l2-benefit p {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--coffee-2);
    margin: 0;
  }

  /* ───────── TESTIMONIOS ───────── */
  .l2-testimonials {
    padding: 5rem 1.5rem;
    background: white;
    border-top: 1px solid var(--line);
  }

  .l2-testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  @media (min-width: 800px) {
    .l2-testimonials-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .l2-testimonial {
    position: relative;
    background: var(--cream);
    padding: 2rem 1.5rem 1.5rem;
    border-radius: 18px;
    margin: 0;
    border: 1px solid var(--line);
  }
  .l2-quote-mark {
    position: absolute;
    top: -0.6rem;
    left: 1.25rem;
    width: 38px;
    height: 38px;
    background: var(--accent);
    color: white;
    font-family: Georgia, serif;
    font-size: 2rem;
    font-weight: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    line-height: 1;
    padding-top: 0.4rem;
  }
  .l2-testimonial blockquote {
    margin: 0 0 1rem;
  }
  .l2-testimonial p {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--coffee-2);
    margin: 0;
  }
  .l2-testimonial figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    border-top: 1px dashed var(--line);
    padding-top: 0.85rem;
  }
  .l2-testimonial figcaption strong {
    color: var(--coffee);
    font-weight: 800;
    font-size: 0.92rem;
  }
  .l2-testimonial figcaption span {
    color: var(--muted);
    font-size: 0.82rem;
  }

  /* ───────── CTA FINAL ───────── */
  .l2-cta-final {
    padding: 5rem 1.5rem 6rem;
    background: var(--cream);
  }
  .l2-cta-box {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    background: var(--coffee);
    color: var(--cream);
