---
import Layout from '../layouts/Layout.astro';
import { courses } from '../data/courses';
import logoPseint from '../assets/images/pseint.png';
import imagen1 from '../assets/images/imagen1.png';
---

<Layout
  title="Inicio"
  description="cafeycodigo: aprende a programar gratis con cursos paso a paso, ejercicios y simulador."
>
  <div class="max-w-7xl mx-auto px-4 pt-10">
    <!-- Hero Section -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center py-6">
      
      <!-- Text Side -->
      <div class="flex flex-col">
        <h1 class="text-[3.3rem] leading-[1.02] -tracking-[0.03em] font-nunito font-black text-textPrimary mb-3">
          Aprendé a programar,<br />
          <span class="text-[#b06d63]">creá tu futuro</span>
        </h1>
        <p class="text-[1.08rem] leading-relaxed text-textPrimary/80 font-[650] max-w-2xl mb-5">
          Cursos prácticos, ejercicios y un simulador para practicar desde cero 🚀
        </p>

        <div class="flex flex-wrap gap-3 mb-4">
          <a href="/pseint/" class="bg-[#2b1d1b] text-white py-3 px-6 rounded-full font-black font-nunito border border-black/10 shadow-soft hover:-translate-y-1 transition-transform">
            Empezar a aprender <span class="ml-1 inline-block">→</span>
          </a>
          <a href="/pseint/" class="bg-white/80 text-[#2b1d1b] py-3 px-6 rounded-full font-black font-nunito border border-black/10 shadow-sm hover:-translate-y-1 transition-transform">
            Ver cursos
          </a>
        </div>

        <div class="flex flex-wrap gap-3 mt-2">
          <span class="inline-flex items-center gap-2 bg-white/70 border border-black/10 rounded-full py-2 px-4 text-textPrimary/85 font-extrabold font-nunito text-[0.95rem] shadow-sm">
            <span class="w-6 h-6 grid place-items-center rounded bg-white/70">⚡</span> Para principiantes
          </span>
          <span class="inline-flex items-center gap-2 bg-white/70 border border-black/10 rounded-full py-2 px-4 text-textPrimary/85 font-extrabold font-nunito text-[0.95rem] shadow-sm">
            <span class="w-6 h-6 grid place-items-center rounded bg-white/70">🧩</span> Proyectos guiados
          </span>
        </div>
      </div>

      <!-- Image Side -->
      <div class="flex items-stretch w-full">
        <!-- Background decoration div imitating radial gradient mesh -->
        <div class="flex-1 flex items-center justify-center bg-white/70 border border-black/10 rounded-[22px] p-3 w-full" 
             style="background-image: radial-gradient(900px 360px at 20% 25%, rgba(239, 71, 111, 0.18), transparent 60%), radial-gradient(900px 360px at 95% 10%, rgba(69, 179, 224, 0.22), transparent 60%), radial-gradient(900px 360px at 70% 95%, rgba(6, 214, 160, 0.14), transparent 60%);">
          <img
            src={imagen1.src}
            alt="Café y código"
            class="w-full h-auto object-contain rounded-[18px]"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <!-- Courses Sections -->
    <div class="mt-10">
      
      <!-- Conceptos Base -->
      <div class="mt-20">
        <h2 class="text-4xl font-nunito font-extrabold text-textPrimary mb-8">Conceptos Base (Nivel 0)</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {courses.filter(c => c.category === 'foundations').map((course, i) => (
            <a
              href={course.status === 'coming' ? '#' : `/${course.slug}/`}
              class="block group outline-none"
              data-coming={course.status === 'coming' ? 'true' : 'false'}
              data-course-name={course.name}
            >
              <div class={`relative border-[3px] border-border rounded-3xl p-6 shadow-neo-lg transition-transform group-hover:-translate-y-1 bg-${i % 2 === 0 ? 'tertiary' : 'secondary'}`}>
                {course.status === 'coming' && (
                  <div class="absolute -top-4 right-5 bg-border text-white border-[3px] border-border rounded-xl py-1 px-3 font-extrabold font-nunito shadow-[2px_2px_0px_var(--text-secondary)]">
                    Próximamente
                  </div>
                )}
                <h3 class="text-xl font-nunito font-extrabold text-textPrimary mb-2">{course.name}</h3>
                <p class="text-[0.95rem] font-[650] text-textSecondary line-clamp-4 leading-relaxed m-0">
                  {course.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Lenguajes de Programación -->
      <div class="mt-20">
        <h2 class="text-4xl font-nunito font-extrabold text-textPrimary mb-8">Lenguajes de Programación</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {courses.filter(c => c.category === 'language').map((course, i) => (
            <a
              href={course.status === 'coming' ? '#' : `/${course.slug}/`}
              class="block group outline-none"
              data-coming={course.status === 'coming' ? 'true' : 'false'}
              data-course-name={course.name}
            >
              <div class={`relative border-[3px] border-border rounded-3xl p-6 shadow-neo-lg transition-transform group-hover:-translate-y-1 bg-${i % 2 === 0 ? 'tertiary' : 'secondary'}`}>
                {course.status === 'coming' && (
                  <div class="absolute -top-4 right-5 bg-border text-white border-[3px] border-border rounded-xl py-1 px-3 font-extrabold font-nunito shadow-[2px_2px_0px_var(--text-secondary)]">
                    Próximamente
                  </div>
                )}
                <h3 class="text-xl font-nunito font-extrabold text-textPrimary mb-2">{course.name}</h3>
                <p class="text-[0.95rem] font-[650] text-textSecondary line-clamp-4 leading-relaxed m-0">
                  {course.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Desarrollo Frontend -->
      <div class="mt-20">
        <h2 class="text-4xl font-nunito font-extrabold text-textPrimary mb-8">Desarrollo Frontend (Web)</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {courses.filter(c => c.category === 'frontend').map((course, i) => (
            <a
              href={course.status === 'coming' ? '#' : `/${course.slug}/`}
              class="block group outline-none"
              data-coming={course.status === 'coming' ? 'true' : 'false'}
              data-course-name={course.name}
            >
              <div class={`relative border-[3px] border-border rounded-3xl p-6 shadow-neo-lg transition-transform group-hover:-translate-y-1 bg-${i % 2 === 0 ? 'tertiary' : 'secondary'}`}>
                {course.status === 'coming' && (
                  <div class="absolute -top-4 right-5 bg-border text-white border-[3px] border-border rounded-xl py-1 px-3 font-extrabold font-nunito shadow-[2px_2px_0px_var(--text-secondary)]">
                    Próximamente
                  </div>
                )}
                <h3 class="text-xl font-nunito font-extrabold text-textPrimary mb-2">{course.name}</h3>
                <p class="text-[0.95rem] font-[650] text-textSecondary line-clamp-4 leading-relaxed m-0">
                  {course.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Ingeniería y Calidad -->
      <div class="mt-20">
        <h2 class="text-4xl font-nunito font-extrabold text-textPrimary mb-8">Ingeniería y Calidad</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {courses.filter(c => c.category === 'engineering').map((course, i) => (
            <a
              href={course.status === 'coming' ? '#' : `/${course.slug}/`}
              class="block group outline-none"
              data-coming={course.status === 'coming' ? 'true' : 'false'}
              data-course-name={course.name}
            >
              <div class={`relative border-[3px] border-border rounded-3xl p-6 shadow-neo-lg transition-transform group-hover:-translate-y-1 bg-${i % 2 === 0 ? 'tertiary' : 'secondary'}`}>
                {course.status === 'coming' && (
                  <div class="absolute -top-4 right-5 bg-border text-white border-[3px] border-border rounded-xl py-1 px-3 font-extrabold font-nunito shadow-[2px_2px_0px_var(--text-secondary)]">
                    Próximamente
                  </div>
                )}
                <h3 class="text-xl font-nunito font-extrabold text-textPrimary mb-2">{course.name}</h3>
                <p class="text-[0.95rem] font-[650] text-textSecondary line-clamp-4 leading-relaxed m-0">
                  {course.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Bases de Datos -->
      <div class="mt-20">
        <h2 class="text-4xl font-nunito font-extrabold text-textPrimary mb-8">Bases de Datos</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {courses.filter(c => c.category === 'database').map((course, i) => (
            <a
              href={course.status === 'coming' ? '#' : `/${course.slug}/`}
              class="block group outline-none"
              data-coming={course.status === 'coming' ? 'true' : 'false'}
              data-course-name={course.name}
            >
              <div class={`relative border-[3px] border-border rounded-3xl p-6 shadow-neo-lg transition-transform group-hover:-translate-y-1 bg-${i % 2 === 0 ? 'tertiary' : 'secondary'}`}>
                {course.status === 'coming' && (
                  <div class="absolute -top-4 right-5 bg-border text-white border-[3px] border-border rounded-xl py-1 px-3 font-extrabold font-nunito shadow-[2px_2px_0px_var(--text-secondary)]">
                    Próximamente
                  </div>
                )}
                <h3 class="text-xl font-nunito font-extrabold text-textPrimary mb-2">{course.name}</h3>
                <p class="text-[0.95rem] font-[650] text-textSecondary line-clamp-4 leading-relaxed m-0">
                  {course.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Herramientas -->
      <div class="mt-20 mb-20">
        <h2 class="text-4xl font-nunito font-extrabold text-textPrimary mb-8">Herramientas</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {courses.filter(c => c.category === 'tools').map((course, i) => (
            <a
              href={course.status === 'coming' ? '#' : `/${course.slug}/`}
              class="block group outline-none"
              data-coming={course.status === 'coming' ? 'true' : 'false'}
              data-course-name={course.name}
            >
              <div class={`relative border-[3px] border-border rounded-3xl p-6 shadow-neo-lg transition-transform group-hover:-translate-y-1 bg-${i % 2 === 0 ? 'tertiary' : 'secondary'}`}>
                {course.status === 'coming' && (
                  <div class="absolute -top-4 right-5 bg-border text-white border-[3px] border-border rounded-xl py-1 px-3 font-extrabold font-nunito shadow-[2px_2px_0px_var(--text-secondary)]">
                    Próximamente
                  </div>
                )}
                <h3 class="text-xl font-nunito font-extrabold text-textPrimary mb-2">{course.name}</h3>
                <p class="text-[0.95rem] font-[650] text-textSecondary line-clamp-4 leading-relaxed m-0">
                  {course.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- Modal Próximamente -->
  <div id="comingCoursesModal" class="fixed inset-0 z-[1100] hidden [&.is-open]:block" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="absolute inset-0 bg-black/35 backdrop-blur-sm" data-close-coming-modal="1"></div>
    <div class="relative max-w-lg mx-auto mt-[10vh] bg-white border-4 border-border rounded-3xl shadow-2xl p-6 md:mt-[20vh] max-md:w-[90%] max-md:mt-[6vh]">
      <div class="flex justify-between items-center mb-4">
        <h3 id="comingCoursesTitle" class="text-2xl text-info font-nunito font-black m-0">Próximamente</h3>
        <button type="button" class="w-10 h-10 rounded-full border-2 border-border bg-white text-lg font-black cursor-pointer hover:bg-gray-100" data-close-coming-modal="1" aria-label="Cerrar modal">
          ✕
        </button>
      </div>
      <p id="comingCoursesText" class="text-lg text-textSecondary font-bold leading-relaxed m-0">
        Este curso estará disponible pronto.
      </p>
    </div>
  </div>

</Layout>

<script is:inline>
  (function () {
    const modal = document.getElementById('comingCoursesModal');
    if (!modal) return;

    const titleEl = document.getElementById('comingCoursesTitle');
    const textEl = document.getElementById('comingCoursesText');

    const close = () => {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.documentElement.style.overflow = '';
    };

    const open = (courseName) => {
      const name = courseName ? String(courseName) : '';
      titleEl.textContent = 'Próximamente';
      textEl.textContent = name ? `El curso "${name}" estará disponible pronto.` : 'Este curso estará disponible pronto.';
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';
    };

    document.querySelectorAll('[data-coming="true"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        open(a.getAttribute('data-course-name') || '');
      });
    });

    modal.querySelectorAll('[data-close-coming-modal="1"]').forEach((el) => {
      el.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  })();
</script>
