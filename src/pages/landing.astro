---
import Layout from '../layouts/Layout.astro';
import imagen1 from '../assets/images/imagen1.png';
import type { TestimonialItem } from '../components/TestimonialsSlider';

const testimonials = [
  {
    quote:
      'Empecé de cero con PSeInt y la progresión me ayudará a no frustrarme. Los textos son claros y sin humo.',
    name: 'María L.',
    role: 'Estudiante de sistemas',
    carita: 'study',
  },
  {
    quote:
      'Uso los cursos de Git y SQL como repaso rápido antes de entrevistas. Me gusta que todo esté en un solo lugar.',
    name: 'Lucas G.',
    role: 'Desarrollador junior',
    carita: 'code',
  },
  {
    quote:
      'Mis hijos y yo miramos HTML/CSS los fines de semana. Los ejemplos cortos se entienden sin ser expertos.',
    name: 'Ana R.',
    role: 'Autodidacta',
    carita: 'heart',
  },
  {
    quote: 'Volví a estudiar después de años; el tono amable y los pasos cortos me sacaron el miedo a "no dar abasto".',
    name: 'Diego F.',
    role: 'Cambio de carrera',
    carita: 'thinking',
  },
] satisfies TestimonialItem[];

const benefits = [
  {
    icon: '🗺️',
    title: 'Rutas claras',
    text: 'Sabés qué estudiar después. Sin salto entre tutoriales sueltos.',
  },
  {
    icon: '✏️',
    title: 'Práctica integrada',
    text: 'Ejercicios y ejemplos para aplicar sin quedarte en la teoría.',
  },
  {
    icon: '⏱️',
    title: 'Ritmo propio',
    text: 'Sin fechas rígidas. Estudiás cuando puedas.',
  },
  {
    icon: '📱',
    title: 'Acceso desde cualquier lugar',
    text: 'Desde PC, tablet o celular.',
  },
];
---

<Layout
  title="Aprende programación sin perderte entre tutoriales"
  description="Una guía en español, práctica y paso a paso para que avances a tu ritmo desde cero."
>
  <div class="landing-page">
    <!-- Hero principal -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <div class="hero-text">
          <p class="hero-label">Guía paso a paso · en español</p>
          <h1 class="hero-title">
            Aprende programación
            <span class="hero-highlight">sin perderte entre tutoriales</span>
          </h1>
          <p class="hero-subtitle">
            Una guía en español, práctica y paso a paso para que avances a tu ritmo desde cero.
          </p>
          <a href="/cursos/" class="hero-cta">
            Empieza ahora
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="hero-visual">
          <div class="hero-image-wrapper">
            <img
              src={imagen1.src}
              alt="Ambiente de aprendizaje Café y Código"
              class="hero-image"
              loading="eager"
              decoding="async"
              width={imagen1.width}
              height={imagen1.height}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Problema / Dolor del usuario -->
    <section class="problem">
      <div class="container">
        <div class="problem-card">
          <div class="problem-icon">😩</div>
          <h2 class="problem-title">¿Te sentís perdido mientras aprendés?</h2>
          <p class="problem-text">
            Si estás aprendiendo con videos sueltos, PDFs dispersos y explicaciones desordenadas,
            es normal sentir que no avanzás. Saltás de un tutorial a otro y al final no sabés qué estudiar después.
          </p>
          <p class="problem-text">
            <strong>Café y Código organiza el camino</strong> para que sepás qué estudiar, cómo practicar y qué viene después.
          </p>
        </div>
      </div>
    </section>

    <!-- Solución / Beneficios -->
    <section class="benefits">
      <div class="container">
        <div class="benefits-header">
          <h2 class="benefits-title">Tu ruta clara para aprender programación</h2>
          <p class="benefits-subtitle">
            Pasás de sentirte confundido a tener un camino claro para avanzar con seguridad.
          </p>
        </div>
        <ul class="benefits-grid">
          {benefits.map((b) => (
            <li class="benefit-card">
              <span class="benefit-icon" aria-hidden="true">{b.icon}</span>
              <h3 class="benefit-title">{b.title}</h3>
              <p class="benefit-text">{b.text}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Prueba social / Testimonios -->
    <section class="testimonials">
      <div class="container">
        <h2 class="testimonials-title"> quienes ya están aprendiendo</h2>
        <div class="testimonials-grid">
          {testimonials.map((t) => (
            <blockquote class="testimonial-card">
              <p class="testimonial-quote">"{t.quote}"</p>
              <footer class="testimonial-author">
                <span class="testimonial-name">{t.name}</span>
                <span class="testimonial-role">{t.role}</span>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-final">
      <div class="container">
        <div class="cta-card">
          <h2 class="cta-title">Empezá hoy con una ruta más clara y cómoda</h2>
          <p class="cta-text">
            Dejá de saltar entre tutoriales. Encontrá el camino que te lleva a programar de verdad.
          </p>
          <a href="/cursos/" class="cta-button">
            Ver cursos
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .landing-page {
    --landing-bg: #faf8f6;
    --landing-primary: #2b1d1b;
    --landing-accent: #b06d63;
    --landing-info: #45b3e0;
    --landing-success: #06d6a0;
    --landing-border: #1e1210;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 3rem 1.5rem 4rem;
    background: var(--landing-bg);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.9;
    background-image: 
      radial-gradient(700px 280px at 15% 20%, rgba(239, 71, 111, 0.12), transparent 55%),
      radial-gradient(600px 240px at 90% 15%, rgba(69, 179, 224, 0.18), transparent 50%),
      radial-gradient(500px 200px at 70% 90%, rgba(6, 214, 160, 0.1), transparent 55%);
  }

  .hero-content {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-content {
      grid-template-columns: 1.1fr 1fr;
      gap: 3rem;
    }
  }

  .hero-label {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--landing-accent);
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 2rem;
    line-height: 1.1;
    color: var(--landing-primary);
    margin-bottom: 1rem;
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 2.75rem;
    }
  }

  .hero-highlight {
    display: block;
    color: var(--landing-accent);
  }

  .hero-subtitle {
    font-weight: 650;
    font-size: 1.1rem;
    line-height: 1.6;
    color: #5a4a47;
    margin-bottom: 1.5rem;
    max-width: 500px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--landing-primary);
    color: white;
    padding: 1rem 1.75rem;
    border-radius: 9999px;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    border: 3px solid var(--landing-border);
    box-shadow: 4px 4px 0px var(--landing-border);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 6px 6px 0px var(--landing-border);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .hero-image-wrapper {
    max-width: 420px;
    border-radius: 22px;
    border: 3px solid var(--landing-border);
    background: rgba(255, 255, 255, 0.8);
    padding: 0.5rem;
    box-shadow: 6px 6px 0px var(--landing-border);
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: 16px;
    object-fit: contain;
  }

  /* Problema */
  .problem {
    padding: 4rem 1.5rem;
    background: white;
  }

  .problem-card {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    padding: 2.5rem 2rem;
    border: 4px solid var(--landing-border);
    border-radius: 24px;
    box-shadow: 6px 6px 0px var(--landing-border);
  }

  .problem-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .problem-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    color: var(--landing-primary);
    margin-bottom: 1rem;
  }

  @media (min-width: 640px) {
    .problem-title {
      font-size: 1.75rem;
    }
  }

  .problem-text {
    font-weight: 650;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #5a4a47;
    margin-bottom: 0.75rem;
  }

  .problem-text:last-child {
    margin-bottom: 0;
  }

  .problem-text strong {
    color: var(--landing-primary);
  }

  /* Beneficios */
  .benefits {
    padding: 4rem 1.5rem;
    background: var(--landing-bg);
  }

  .benefits-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .benefits-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.75rem;
    color: var(--landing-primary);
    margin-bottom: 0.5rem;
  }

  @media (min-width: 640px) {
    .benefits-title {
      font-size: 2rem;
    }
  }

  .benefits-subtitle {
    font-weight: 650;
    color: #5a4a47;
    font-size: 1.05rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 480px) {
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .benefits-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .benefit-card {
    background: white;
    border: 3px solid var(--landing-border);
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    box-shadow: 4px 4px 0px var(--landing-border);
    transition: transform 0.2s;
  }

  .benefit-card:hover {
    transform: translateY(-2px);
  }

  .benefit-icon {
    display: block;
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .benefit-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    color: var(--landing-primary);
    margin-bottom: 0.5rem;
  }

  .benefit-text {
    font-weight: 650;
    font-size: 0.9rem;
    color: #5a4a47;
    line-height: 1.5;
    margin: 0;
  }

  /* Testimonios */
  .testimonials {
    padding: 4rem 1.5rem;
    background: white;
  }

  .testimonials-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    color: var(--landing-primary);
    text-align: center;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .testimonials-title {
      font-size: 1.75rem;
    }
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .testimonial-card {
    background: var(--landing-bg);
    border: 3px solid var(--landing-border);
    border-radius: 16px;
    padding: 1.25rem;
    margin: 0;
    box-shadow: 4px 4px 0px var(--landing-border);
  }

  .testimonial-quote {
    font-weight: 650;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #5a4a47;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .testimonial-name {
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--landing-primary);
  }

  .testimonial-role {
    font-size: 0.8rem;
    color: #8a7a77;
  }

  /* CTA final */
  .cta-final {
    padding: 4rem 1.5rem;
    background: var(--landing-bg);
  }

  .cta-card {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    background: var(--landing-primary);
    border: 4px solid var(--landing-border);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    box-shadow: 6px 6px 0px var(--landing-border);
  }

  .cta-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    color: white;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  @media (min-width: 640px) {
    .cta-title {
      font-size: 1.75rem;
    }
  }

  .cta-text {
    font-weight: 650;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 1.5rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: var(--landing-primary);
    padding: 1rem 2rem;
    border-radius: 9999px;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    border: 3px solid var(--landing-border);
    box-shadow: 4px 4px 0px rgba(255, 255, 255, 0.3);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 6px 6px 0px rgba(255, 255, 255, 0.3);
  }
</style>