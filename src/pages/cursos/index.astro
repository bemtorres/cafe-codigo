---
import Layout from '../../layouts/Layout.astro';
import CoursesCatalog from '../../components/courses/CoursesCatalog';
---

<Layout
  title="Todos los cursos"
  description="Catálogo de cursos de Café y Código: vista en cuadrícula o lista."
>
  <div class="mx-auto max-w-6xl px-4 pb-12 pt-6 sm:px-5">
    <header class="mb-8">
      <p class="m-0 font-nunito text-[0.65rem] font-extrabold uppercase tracking-[0.2em] text-textMuted">Catálogo</p>
      <h1 class="!mt-1 font-nunito text-3xl font-black text-textPrimary sm:text-4xl">Todos los cursos</h1>
      <p class="mt-2 max-w-2xl font-nunito text-base font-[650] leading-relaxed text-textSecondary">
        Usá el <strong>buscador</strong> para filtrar. Elegí <strong>cuadrícula</strong> o <strong>lista</strong>; la
        preferencia de vista se guarda en este navegador.
      </p>
    </header>
    <CoursesCatalog client:load />
  </div>
</Layout>
