---
import Layout from '../../layouts/Layout.astro';
import SponsorZoneGate from '../../components/colaboradores/SponsorZoneGate';
---

<Layout
  title="Zona colaboradores"
  description="Contenido exclusivo para sponsors de cafeycodigo: acceso vinculado a tu cuenta tras colaborar por Ko-fi."
>
  <div class="max-w-3xl mx-auto px-4 pt-6 pb-20">
    <nav class="mb-6 font-nunito text-sm font-bold">
      <a href="/colaboradores/" class="text-info underline decoration-2 underline-offset-2">← Colaboradores</a>
    </nav>
    <h1 class="font-nunito font-black text-3xl text-textPrimary mb-2">Zona exclusiva</h1>
    <p class="text-textSecondary font-[650] mb-8 m-0 max-w-2xl">
      Solo visible si tu cuenta tiene el rol de colaborador activado en el proyecto.
    </p>
    <SponsorZoneGate client:load />
  </div>
</Layout>
