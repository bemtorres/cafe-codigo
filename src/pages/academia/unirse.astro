---
import Layout from '../../layouts/Layout.astro';
import AcademyJoinClient from '../../components/academy/AcademyJoinClient';
---

<Layout
  title="Unirse a una sección"
  description="Inscribite en una sección de academia con el código secreto de 8 caracteres o el enlace que te compartió tu docente."
>
  <div class="mx-auto max-w-xl px-4 pb-14 pt-4 sm:px-5">
    <header class="mb-8 text-center">
      <p class="mb-2 font-nunito text-[0.65rem] font-extrabold uppercase tracking-[0.2em] text-textMuted">Academia</p>
      <h1 class="!mt-0 font-nunito text-3xl font-black text-textPrimary sm:text-4xl">Unirse a una sección</h1>
    </header>
    <AcademyJoinClient client:load />
  </div>
</Layout>
