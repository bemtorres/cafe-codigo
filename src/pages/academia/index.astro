---
import Layout from '../../layouts/Layout.astro';
import AcademyApp from '../../components/academy/AcademyApp';
---

<Layout
  title="Academia"
  description="Modo academia: cursos asignados por tu docente o gestión de secciones si tenés perfil docente."
>
  <div class="mx-auto max-w-6xl px-4 pb-14 pt-4 sm:px-5">
    <header class="mb-8 md:mb-10">
      <p class="mb-2 font-nunito text-[0.65rem] font-extrabold uppercase tracking-[0.2em] text-textMuted">Academia</p>
      <h1 class="!mt-0 font-nunito text-3xl font-black text-textPrimary sm:text-4xl">Modo academia</h1>
      <p class="mx-auto mt-3 max-w-2xl font-nunito text-base font-[650] leading-relaxed text-textSecondary">
        Los estudiantes ven aquí solo los cursos que el docente asignó a la sección. Los docentes con privilegio crean
        secciones, comparten el enlace y revisan el avance en quizzes.
      </p>
    </header>
    <AcademyApp client:load />
  </div>
</Layout>
