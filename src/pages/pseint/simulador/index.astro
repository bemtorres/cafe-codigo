---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="Simulador PSeInt"
  description="Ejecuta pseudocódigo PSeInt directamente en el navegador"
  courseSlug="pseint"
>
  <article class="ide">
    <div class="ide-top">
      <div class="ide-title">
        <span class="tab">Algoritmo</span>
        <span class="tab active">sin_titulo</span>
      </div>
      <div class="ide-actions">
        <button id="btn-run" class="btn primary" type="button">Ejecutar</button>
        <button id="btn-clear" class="btn" type="button">Limpiar salida</button>
      </div>
    </div>

    <section class="ide-main">
      <div class="left">
        <div class="editor-wrap">
          <div id="editor" class="editor" aria-label="Editor PSeInt"></div>
        </div>

        <aside class="sidebar" aria-label="Bloques PSeInt">
          <button class="tool" type="button" data-snippet="escribir" title="Escribir">
            <span class="tool-icon">""</span>
            <span class="tool-label">Escribir</span>
          </button>
          <button class="tool" type="button" data-snippet="leer" title="Leer">
            <span class="tool-icon">⌨</span>
            <span class="tool-label">Leer</span>
          </button>
          <button class="tool" type="button" data-snippet="asignar" title="Asignar">
            <span class="tool-icon">←</span>
            <span class="tool-label">Asignar</span>
          </button>
          <button class="tool" type="button" data-snippet="si" title="Si-Entonces">
            <span class="tool-icon">Si</span>
            <span class="tool-label">Si-Entonces</span>
          </button>
          <button class="tool" type="button" data-snippet="segun" title="Según">
            <span class="tool-icon">≡</span>
            <span class="tool-label">Según</span>
          </button>
          <button class="tool" type="button" data-snippet="mientras" title="Mientras">
            <span class="tool-icon">↻</span>
            <span class="tool-label">Mientras</span>
          </button>
          <button class="tool" type="button" data-snippet="repetir" title="Repetir">
            <span class="tool-icon">⟲</span>
            <span class="tool-label">Repetir</span>
          </button>
          <button class="tool" type="button" data-snippet="para" title="Para">
            <span class="tool-icon">⇢</span>
            <span class="tool-label">Para</span>
          </button>
          <button class="tool" type="button" data-snippet="funcion" title="Función">
            <span class="tool-icon">ƒ</span>
            <span class="tool-label">Función</span>
          </button>
        </aside>
      </div>

      <section class="right io">
        <!-- Modal para Leer (Entrada) escondido al inicio -->
        <div id="modal-leer" class="modal-overlay" style="display: none;">
          <div class="modal-content io-panel">
            <div class="io-head">
              <div class="io-title">Entrada (<code>Leer</code>)</div>
              <div class="muted mono" id="input-line"></div>
            </div>
            <div class="io-body">
              <div class="muted" id="input-prompt" style="font-size: 1.1rem; color: var(--text-primary);"></div>
              <div class="io-row">
                <input id="input-value" class="input" type="text" placeholder="Escribe el valor y presiona Enter" />
                <button id="btn-send" class="btn primary" type="button">Enviar</button>
              </div>
              <small class="muted">Tipos: <code>Entero</code>, <code>Real</code>, <code>Logico</code> (Verdadero/Falso) y <code>Caracter</code>.</small>
            </div>
          </div>
        </div>

        <div class="io-panel">
          <div class="io-head">
            <div class="io-title">Salida</div>
            <small class="muted">Cada <code>Escribir</code> agrega una línea.</small>
          </div>
          <pre id="stdout" class="stdout" aria-live="polite"></pre>
        </div>
      </section>
    </section>

    <nav class="nav-bottom">
      <a href="/pseint/" class="prev">← Curso PSeInt</a>
      <a href="/pseint/ayuda/" class="next">Ayuda / Guía →</a>
    </nav>
  </article>
</Layout>

<script>
  // @ts-nocheck
  import { createPSeIntRunner } from '../../../lib/pseint/interpreter.js';
  import { createMonacoPSeIntEditor } from '../../../lib/pseint/monacoPseint.js';

  /**
   * @param {string} id
   * @returns {HTMLElement}
   */
  function mustEl(id) {
    const node = document.getElementById(id);
    if (!node) throw new Error(`No se encontró el elemento #${id}`);
    return node;
  }

  const $editorHost = /** @type {HTMLElement} */ (mustEl('editor'));
  const $stdout = /** @type {HTMLElement} */ (mustEl('stdout'));
  const $run = /** @type {HTMLButtonElement} */ (mustEl('btn-run'));
  const $clear = /** @type {HTMLButtonElement} */ (mustEl('btn-clear'));
  const $prompt = /** @type {HTMLElement} */ (mustEl('input-prompt'));
  const $line = /** @type {HTMLElement} */ (mustEl('input-line'));
  const $input = /** @type {HTMLInputElement} */ (mustEl('input-value'));
  const $send = /** @type {HTMLButtonElement} */ (mustEl('btn-send'));
  const $modal = /** @type {HTMLElement} */ (mustEl('modal-leer'));

  const defaultProgram = `Algoritmo SumaDosNumeros
  Definir num1 Como Entero;
  Definir num2 Como Entero;
  Definir resultado Como Entero;
  Escribir "Primer número:";
  Leer num1;
  Escribir "Segundo número:";
  Leer num2;
  resultado = num1 + num2;
  Escribir "La suma es: ", resultado;
FinAlgoritmo`;

  let editorApi = null;
  let editor = null;
  let insertSnippet = null;

  const initialCode = localStorage.getItem('pseint.code') || defaultProgram;
  const autoStart = localStorage.getItem('pseint.autorun') === '1';
  createMonacoPSeIntEditor($editorHost, initialCode).then((api) => {
    editorApi = api;
    editor = api.editor;
    insertSnippet = api.insertSnippet;

    // Persistencia
    editor.onDidChangeModelContent(() => {
      localStorage.setItem('pseint.code', editor.getValue());
    });

    if (autoStart) {
      localStorage.removeItem('pseint.autorun');
      // Arranca hasta el siguiente `Leer`
      setTimeout(() => $run.click(), 0);
    }
  });

  /** @param {string} line */
  function appendOut(line) {
    $stdout.textContent += (line ?? '') + '\n';
  }

  function clearOut() {
    $stdout.textContent = '';
  }

  /** @param {{prompt: string, lineNo?: number} | null} wait */
  function setWaitingUI(wait) {
    if (!wait) {
      $modal.style.display = 'none';
      $prompt.textContent = '';
      $line.textContent = '';
      $input.value = '';
      return;
    }
    $prompt.textContent = wait.prompt;
    $line.textContent = wait.lineNo ? `(línea ${wait.lineNo})` : '';
    $input.value = '';
    $modal.style.display = 'flex';
    setTimeout(() => $input.focus(), 50);
  }

  /** @param {boolean} isBusy */
  function setBusy(isBusy) {
    // Si estuviéramos en "Run", podríamos deshabilitarlo
    $run.disabled = isBusy;
  }

  /** @typedef {ReturnType<typeof createPSeIntRunner>} Runner */
  /** @type {Runner | null} */
  let runner = null;

  /** @param {boolean} resetOutput */
  function ensureRunner(resetOutput) {
    const code = editor ? editor.getValue() : localStorage.getItem('pseint.code') || '';
    if (resetOutput) clearOut();
    runner = createPSeIntRunner(code, { onOutput: (line) => appendOut(line) });
    setWaitingUI(null);
  }

  async function runUntilPause() {
    if (!runner) ensureRunner(true);
    const r = await runner.run();
    if (r.status === 'need_input') {
      setWaitingUI(r);
    } else {
      setWaitingUI(null);
      appendOut('');
      appendOut('--- FIN ---');
      setBusy(false);
      $run.textContent = 'Ejecutar';
    }
  }

  async function sendInput() {
    if (!runner) return;
    const raw = $input.value;
    try {
      runner.provideInput(raw);
      $input.value = '';
      setWaitingUI(null);
      // Auto-continue! Continúa el loop automáticamente.
      await runUntilPause();
    } catch (e) {
      setWaitingUI(null);
      appendOut('');
      appendOut('--- ERROR ---');
      appendOut(e instanceof Error ? e.message : String(e));
      setBusy(false);
      $run.textContent = 'Ejecutar';
    }
  }

  $clear.addEventListener('click', () => clearOut());
  $send.addEventListener('click', () => sendInput());
  $input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      sendInput();
    }
  });

  $run.addEventListener('click', async () => {
    setBusy(true);
    $run.textContent = 'Ejecutando...';
    try {
      ensureRunner(true);
      await runUntilPause(); // Podría pausar y mostrar input
    } catch (e) {
      appendOut('');
      appendOut('--- ERROR ---');
      appendOut(e instanceof Error ? e.message : String(e));
      setBusy(false);
      $run.textContent = 'Ejecutar';
    }
  });

  setWaitingUI(null);

  const SNIPS = {
    escribir: 'Escribir "${1:texto}";',
    leer: 'Leer ${1:variable};',
    asignar: '${1:variable} = ${2:expresion};',
    si: 'Si ${1:condicion} Entonces\n\t$0\nFinSi',
    segun: '// (No implementado aún en el intérprete)\n// Segun ${1:valor} Hacer\n// \tDe Otro Modo:\n// FinSegun\n',
    mientras: 'Mientras ${1:condicion} Hacer\n\t$0\nFinMientras',
    repetir: '// (No implementado aún en el intérprete)\n// Repetir\n// \t$0\n// Hasta Que ${1:condicion}\n',
    para: '// (No implementado aún en el intérprete)\n// Para ${1:i} = ${2:1} Hasta ${3:n} Hacer\n// \t$0\n// FinPara\n',
    funcion: '// (No implementado aún en el intérprete)\n// Funcion ${1:miFuncion}(${2:parametros})\n// \t$0\n// FinFuncion\n',
  };

  document.querySelectorAll('[data-snippet]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-snippet');
      const raw = SNIPS[key] || '';
      if (insertSnippet) insertSnippet(raw);
      else appendOut(`(Editor aún cargando) Snippet: ${key}`);
    });
  });
</script>

<style>
  /* Para este page: usar todo el ancho (evita el max-width del Layout) */
  :global(.site-main) {
    max-width: none !important;
    padding-left: 0.75rem !important;
    padding-right: 0.75rem !important;
  }

  .muted { color: var(--text-muted); }
  .mono { font-family: 'JetBrains Mono', monospace; }
  
  .btn {
    border: 2px solid var(--border);
    background: white;
    color: var(--text-primary);
    padding: 0.5rem 1rem;
    border-radius: 12px;
    font-weight: 800;
    font-family: 'Nunito', sans-serif;
    cursor: pointer;
    box-shadow: 3px 3px 0px var(--border);
    transition: all 0.1s;
    font-size: 0.95rem;
  }
  .btn:hover { background: var(--bg-secondary); transform: translateY(-2px); }
  .btn:active { transform: translate(3px, 3px); box-shadow: 0 0 0 var(--border); }
  
  .btn.primary {
    background: var(--success);
    color: white;
  }
  .btn.primary:hover {
    background: #05c290;
  }
  .btn:disabled { opacity: 0.65; cursor: not-allowed; box-shadow: none; transform: translate(3px,3px); }

  /* IDE layout similar a PSeInt en estilo Joyful */
  .ide {
    margin: 1.25rem auto 0;
    max-width: 1300px;
    width: 100%;
    border: 4px solid var(--border);
    border-radius: 24px;
    background: white;
    box-shadow: 8px 8px 0px var(--border);
    overflow: hidden;
  }
  .ide-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-bottom: 4px solid var(--border);
    background: var(--warning);
  }
  .ide-title { display: flex; gap: 0.5rem; align-items: center; }
  .tab {
    font-size: 0.95rem;
    padding: 0.35rem 1rem;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    border: 3px solid transparent;
    border-radius: 12px;
    color: rgba(0,0,0,0.6);
  }
  .tab.active {
    color: var(--text-primary);
    border-color: var(--border);
    background: white;
    box-shadow: 3px 3px 0px var(--border);
  }
  .ide-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; justify-content: flex-end; }

  .ide-main {
    display: grid;
    grid-template-columns: 60% 40%;
    align-items: stretch;
    background: var(--bg-primary);
  }
  .left {
    display: grid;
    grid-template-columns: 1fr 180px;
    border-right: 4px solid var(--border);
    background: white;
  }
  .editor-wrap {
    background: white;
    min-height: 460px;
    padding: 0;
  }
  .editor { height: 460px; width: 100%; }

  .sidebar {
    border-left: 4px solid var(--border);
    background: var(--bg-tertiary); /* Celeste suave */
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
    gap: 0.5rem;
  }
  .tool {
    width: 100%;
    display: grid;
    grid-template-columns: 36px 1fr;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border: 2px solid var(--border);
    border-radius: 12px;
    background: white;
    color: var(--text-primary);
    cursor: pointer;
    text-align: left;
    box-shadow: 2px 2px 0px var(--border);
    transition: transform 0.1s;
  }
  .tool:hover { transform: translateY(-2px); background: var(--bg-secondary); }
  .tool:active { transform: translate(2px, 2px); box-shadow: 0 0 0 var(--border); }
  
  .tool-icon {
    width: 32px;
    height: 32px;
    border: 2px solid var(--border);
    border-radius: 8px;
    background: var(--warning);
    display: grid;
    place-items: center;
    font-weight: 800;
    color: var(--text-primary);
  }
  .tool-label { font-size: 0.95rem; font-weight: 700; font-family: 'Nunito', sans-serif;}

  @media (max-width: 1100px) {
    .ide-main { grid-template-columns: 1fr; }
    .left { grid-template-columns: 1fr; border-right: none; border-bottom: 4px solid var(--border); }
    .sidebar { border-left: none; border-top: 4px solid var(--border); flex-direction: row; overflow-x: auto; padding: 1rem; }
    .tool { min-width: 140px; }
  }

  .io {
    display: flex;
    flex-direction: column;
    background: var(--bg-primary); /* Crema */
    padding: 1.5rem;
    gap: 1.5rem;
  }
  .io-panel {
    border: 3px solid var(--border);
    border-radius: 16px;
    background: white;
    padding: 1rem;
    box-shadow: 4px 4px 0px var(--border);
    display: flex;
    flex-direction: column;
  }
  .io-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 0.5rem;
    border-bottom: 2px dashed var(--border);
    padding-bottom: 0.5rem;
  }
  .io-title { font-weight: 800; font-family: 'Nunito', sans-serif; font-size: 1.2rem; color: var(--info); }
  .io-body { display: grid; gap: 0.8rem; margin-top: 0.5rem; }
  .io-row { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: stretch; }

  .input {
    flex: 1;
    min-width: 220px;
    border-radius: 12px;
    border: 2px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-primary);
    padding: 0.5rem 1rem;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    outline: none;
  }
  .input:focus { border-color: var(--info); }
  
  .stdout {
    min-height: 280px;
    height: 320px; /* altura fija para "Salida" */
    max-height: 320px;
    border-radius: 12px;
    border: 3px solid var(--border);
    background: var(--code-bg);
    color: var(--code-text);
    padding: 1rem;
    overflow-y: auto;
    overflow-x: hidden;
    white-space: pre-wrap;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem;
    margin-top: 1rem;
    box-shadow: inset 4px 4px 10px rgba(0,0,0,0.5);
  }

  /* ESTILO PARA EL MODAL DE LECTURA */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .modal-content {
    background: white;
    width: 90%;
    max-width: 450px;
    padding: 1.5rem;
    box-shadow: 10px 10px 0px var(--border);
    border: 4px solid var(--border);
    border-radius: 24px;
    animation: popIn 0.2s ease-out forwards;
  }
  @keyframes popIn {
    from {
      transform: scale(0.8) translateY(20px);
      opacity: 0;
    }
    to {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
  }
</style>

