---
import Layout from '../../../layouts/Layout.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
import Ejercicio from '../../../components/Ejercicio.astro';
---

<Layout title="Variables" description="Definición de variables, escribir con concatenaciones y ejercicios" courseSlug="pseint">
  <article class="content-section">
    <h1>Variables en PSeInt</h1>

    <section class="mb-10">
      <h2>¿Qué es una variable?</h2>
      <p>
        Una variable es un espacio en memoria donde guardamos datos. Cada variable tiene un nombre y un tipo. 
        En PSeInt con configuración flexible, <strong>debemos definir cada variable antes de usarla</strong> y 
        todas las instrucciones terminan con <code>;</code>.
      </p>
    </section>

    <section class="mb-10">
      <h2>Tipos de datos</h2>
      <ul class="mb-4">
        <li><strong>Entero:</strong> Números sin decimales (ej: 5, -10, 0)</li>
        <li><strong>Real:</strong> Números con decimales (ej: 3.14, -0.5)</li>
        <li><strong>Caracter:</strong> Texto o cadenas (ej: "Hola", "Juan")</li>
        <li><strong>Logico:</strong> Verdadero o Falso</li>
      </ul>
    </section>

    <section class="mb-10">
      <h2>Definir variables</h2>
      <p>
        La sintaxis es: <code>Definir nombreVariable Como Tipo;</code>
      </p>
      <CodeBlock
        code={`Algoritmo DefinirVariables
  Definir edad Como Entero;
  Definir precio Como Real;
  Definir nombre Como Caracter;
  Definir activo Como Logico;
FinAlgoritmo`}
        title="Ejemplos de definición"
      />
    </section>

    <section class="mb-10">
      <h2>Escribir con concatenaciones</h2>
      <p>
        Para mostrar texto y variables juntos, usamos <code>Escribir</code> con 
        comas <code>,</code> para concatenar:
      </p>
      <CodeBlock
        code={`Algoritmo Presentacion
  Definir nombre Como Caracter;
  Definir edad Como Entero;
  nombre = "María";
  edad = 20;
  Escribir "Hola, me llamo ", nombre, " y tengo ", edad, " años";
FinAlgoritmo`}
        title="Concatenación con coma"
      />
      <p class="mb-2" style="font-size: 0.875rem; color: var(--text-muted);">
        La salida sería: <em>Hola, me llamo María y tengo 20 años</em>
      </p>
    </section>

    <section class="mb-10">
      <h2>Asignación de valores</h2>
      <p>
        Usamos <code>&lt;-</code> para asignar un valor a una variable:
      </p>
      <CodeBlock
        code={`Algoritmo Asignacion
  Definir x Como Entero;
  Definir mensaje Como Caracter;
  x = 10;
  mensaje = "Hola mundo";
FinAlgoritmo`}
      />
    </section>

    <section class="mb-10">
      <h2>Ejercicios</h2>

      <Ejercicio
        titulo="Ejercicio 1: Saludo"
        enunciado="Crea un algoritmo que defina una variable de tipo Caracter llamada 'nombre' con el valor 'Carlos', y luego escriba el mensaje 'Buenos días, Carlos' usando concatenación."
        solucion={`Algoritmo Saludo
  Definir nombre Como Caracter;
  nombre = "Carlos";
  Escribir "Buenos días, ", nombre;
FinAlgoritmo`}
      />

      <Ejercicio
        titulo="Ejercicio 2: Información personal"
        enunciado="Define tres variables: nombre (Caracter), edad (Entero) y ciudad (Caracter). Asígnales valores y escribe una frase que las combine."
        solucion={`Algoritmo InfoPersonal
  Definir nombre Como Caracter;
  Definir edad Como Entero;
  Definir ciudad Como Caracter;
  nombre = "Ana";
  edad = 25;
  ciudad = "Madrid";
  Escribir nombre, " tiene ", edad, " años y vive en ", ciudad;
FinAlgoritmo`}
      />

      <Ejercicio
        titulo="Ejercicio 3: Variables numéricas"
        enunciado="Define dos variables enteras (a y b) con valores 5 y 3. Escribe un mensaje que muestre ambos números."
        solucion={`Algoritmo Numeros
  Definir a Como Entero;
  Definir b Como Entero;
  a = 5;
  b = 3;
  Escribir "El primer número es ", a, " y el segundo es ", b;
FinAlgoritmo`}
      />

      <Ejercicio
        titulo="Ejercicio 4: Pregunta"
        enunciado="¿Por qué es importante definir cada variable antes de usarla en PSeInt?"
        pregunta="Explica la importancia de la declaración de variables."
      />
    </section>

    <nav class="nav-bottom">
      <a href="/pseint/introduccion/" class="prev">← Introducción</a>
      <a href="/pseint/leer/" class="next">Leer →</a>
    </nav>
  </article>
</Layout>
