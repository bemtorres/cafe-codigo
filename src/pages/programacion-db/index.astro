---
import Layout from '../../layouts/Layout.astro';
import { courses } from '../../data/courses';

const plsqlCourse = courses.find(c => c.slug === 'programacion-db');
if (!plsqlCourse) {
  throw new Error("No se encontró el curso 'programacion-db' en el archivo de datos.");
}
---

<Layout title="Programación PL/SQL Pro" description="Aprende a programar dentro de la base de datos: Procedures, Triggers y Funciones." courseSlug="programacion-db">
  <div class="course-container">
    <header class="course-index-header">
      <div class="db-logo-box">
        <span class="db-badge">⚙️</span>
      </div>
      <h1 class="course-big-title">
        {plsqlCourse.name}
      </h1>
      <p class="course-description">
        {plsqlCourse.description}
      </p>
    </header>

    <div class="cards-grid">
      {plsqlCourse.lessons?.map((lesson, index) => (
        <a href={lesson.href} class="lesson-card">
          <div class="lesson-card__number">{index + 1}</div>
          <div class="lesson-card__content">
            <h3 class="lesson-card__title">{lesson.title}</h3>
            <span class="lesson-card__cta">Programar objeto →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .course-container { max-width: 1000px; margin: 0 auto; padding: 2.5rem 1.25rem; }
  .course-index-header { text-align: center; margin-bottom: 4rem; }
  .db-logo-box { margin-bottom: 1.5rem; font-size: 3rem; }
  .db-badge { display: inline-block; background: #e67e22; color: white; padding: 0.5rem 1rem; border-radius: 12px; border: 3px solid var(--border); box-shadow: 4px 4px 0px var(--border); }
  .course-big-title { font-size: clamp(2.2rem, 7vw, 3.2rem); font-weight: 950; color: #e67e22; text-shadow: 2px 2px 0px var(--border); }
  .course-description { font-size: 1.2rem; font-weight: 700; color: var(--text-secondary); max-width: 600px; margin: 0 auto; }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
  .lesson-card { display: flex; gap: 1rem; background: white; border: 3px solid var(--border); border-radius: 20px; padding: 1.5rem; text-decoration: none; color: var(--text-primary); box-shadow: 5px 5px 0px var(--border); align-items: center; transition: transform 0.2s; }
  .lesson-card:hover { transform: translate(-5px, -5px); box-shadow: 10px 10px 0px var(--border); border-color: #e67e22; }
  .lesson-card__number { font-size: 2rem; font-weight: 900; opacity: 0.15; }
  .lesson-card__title { font-size: 1.1rem; font-weight: 950; margin-bottom: 0.25rem; }
  .lesson-card__cta { font-size: 0.9rem; font-weight: 800; color: #e67e22; }
</style>
