        <article class="ex-card" data-ex-id="u1-9">
          <h3>9. Descuento en compra</h3>
          <p class="ex-statement">Ingresar precio y porcentaje; mostrar precio original y final.</p>
          <div class="ex-checks">
            <span class="ex-progress" data-progress-for="u1-9"></span>
            <label class="chk"><input type="checkbox" data-check-id="enunciado" /> Comprendí el enunciado</label>
            <label class="chk"><input type="checkbox" data-check-id="definir" /> Definí variables con `Definir`</label>
            <label class="chk"><input type="checkbox" data-check-id="leer" /> Leí datos con `Leer`</label>
            <label class="chk"><input type="checkbox" data-check-id="proceso" /> Calculé en el proceso</label>
            <label class="chk"><input type="checkbox" data-check-id="escribir" /> Mostré el resultado con `Escribir`</label>
          </div>
        </article>

        <article class="ex-card" data-ex-id="u1-10">
          <h3>10. Tiempo en segundos</h3>
          <p class="ex-statement">Ingresar horas y convertir a segundos con un mensaje.</p>
          <div class="ex-checks">
            <span class="ex-progress" data-progress-for="u1-10"></span>
            <label class="chk"><input type="checkbox" data-check-id="enunciado" /> Comprendí el enunciado</label>
            <label class="chk"><input type="checkbox" data-check-id="definir" /> Definí variables con `Definir`</label>
            <label class="chk"><input type="checkbox" data-check-id="leer" /> Leí datos con `Leer`</label>
            <label class="chk"><input type="checkbox" data-check-id="proceso" /> Calculé en el proceso</label>
            <label class="chk"><input type="checkbox" data-check-id="escribir" /> Mostré el resultado con `Escribir`</label>
          </div>
        </article>
      </div>
    </section>

    <section class="mb-10">
      <h2>🎯 Cierre de la Parte 1</h2>
      <p class="muted">
        Cuando termines los ejercicios, asegurate de que podés hacer sin mirar mucho:
        declarar variables, leer datos, calcular y mostrar el resultado.
      </p>
      <ul>
        <li>Podés implementar un mensaje + resultado entendible.</li>
        <li>Tu salida tiene el formato del enunciado.</li>
        <li>Usás `Leer` antes de calcular.</li>
      </ul>
      <p>
        Listo para avanzar: <a href="/ejercicios/unidad-2/">Unidad 2 (Si)</a>.
      </p>
    </section>
  </article>

  <script is:inline>
    // Checklist con progreso guardado localmente.
    const STORAGE_KEY = 'cafeycodigo.exerciseChecks.v1';

    function readStore() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      } catch {
        return {};
      }
    }

    function writeStore(store) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(store));
      } catch {}
    }

    function updateProgressFor(exId) {
      const card = document.querySelector(`.ex-card[data-ex-id="${exId}"]`);
      if (!card) return;
      const checks = Array.from(card.querySelectorAll('input[type="checkbox"][data-check-id]'));
      const done = checks.filter((c) => c.checked).length;
      const total = checks.length;
      const el = card.querySelector('[data-progress-for]');
      if (el) el.textContent = `Progreso: ${done}/${total}`;
    }

    (function initChecklist() {
      const store = readStore();

      const allCards = Array.from(document.querySelectorAll('.ex-card[data-ex-id]'));
      allCards.forEach((card) => {
        const exId = card.getAttribute('data-ex-id');
        const perEx = store[exId] || {};

        card.querySelectorAll('input[type="checkbox"][data-check-id]').forEach((input) => {
          const checkId = input.getAttribute('data-check-id');
          input.checked = Boolean(perEx[checkId]);
          input.addEventListener('change', () => {
            const s = readStore();
            if (!s[exId]) s[exId] = {};
            s[exId][checkId] = input.checked;
            writeStore(s);
            updateProgressFor(exId);
          });
        });

        updateProgressFor(exId);
      });
    })();
  </script>

  <style>
    .muted {
      color: var(--text-muted);
      font-weight: 650;
      line-height: 1.6;
    }
    .exercise-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .ex-card {
      border: 3px solid var(--border);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.78);
      padding: 1rem 1rem;
      box-shadow: 0 16px 34px rgba(30, 18, 16, 0.08);
    }
    .ex-card h3 {
      margin: 0 0 0.35rem;
      color: var(--info);
      font-size: 1.2rem;
    }
    .ex-statement {
      margin: 0 0 0.65rem;
      color: var(--text-secondary);
      font-weight: 650;
      line-height: 1.55;
    }
    .ex-checks {
      display: grid;
      gap: 0.35rem;
    }
    .ex-progress {
      font-weight: 900;
      font-family: 'Nunito', sans-serif;
      color: var(--text-primary);
      margin-bottom: 0.25rem;
    }
    .chk {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: var(--text-secondary);
      font-weight: 650;
    }
    .chk input {
      width: 18px;
      height: 18px;
      accent-color: var(--success);
    }
  </style>
</Layout>

