---
import { Code } from 'astro:components';

interface Props {
  code: string;
  title?: string;
  lang?: string;
  isPSeIntCode?: boolean;
}

const { code, title, lang, isPSeIntCode = false } = Astro.props;

// ─── Detección de lenguaje ───────────────────────────────────────────────────
function detectLang(src: string) {
  const s = String(src ?? '');

  // PSeInt — completo
  if (/\bAlgoritmo\b/i.test(s) && /\bFinAlgoritmo\b/i.test(s)) return 'pseint';
  // PSeInt — fragmentos
  const pseintHits = [
    /\bSi\b.+\bEntonces\b/i, /\bSino\b/i, /\bFinSi\b/i,
    /\bSegun\b/i, /\bFinSegun\b/i,
    /\bMientras\b.+\bHacer\b/i, /\bFinMientras\b/i,
    /\bPara\b.+\bHasta\b/i, /\bFinPara\b/i,
    /\bEscribir\b/i, /\bLeer\b/i, /\bDefinir\b.+\bComo\b/i, /\bMOD\b/,
  ];
  if (pseintHits.filter(r => r.test(s)).length >= 2) return 'pseint';

  // C#
  if (/\bConsole\.Write(Line)?\b/.test(s) || /\busing System\b/.test(s) || /\bnamespace\b/.test(s)) return 'csharp';
  // Kotlin
  if (/\bfun main\b/.test(s) || (/\bprintln\b/.test(s) && !/\bSystem\.out\b/.test(s))) return 'kotlin';
  // Java / JUnit
  if (/@Test\b/.test(s) || /@BeforeEach\b/.test(s) || /@AfterEach\b/.test(s) ||
      /\bassertEquals\b/.test(s) || /\bassertThrows\b/.test(s) ||
      /import org\.junit/.test(s) || /import static org\.junit/.test(s)) return 'java';
  if (/\bpublic class\b/.test(s) || /\bSystem\.out\.print/.test(s) || /\bimport java\./.test(s)) return 'java';
  // Python
  if (/\bdef \w+\(/.test(s) || (/\bimport \w/.test(s) && /\bprint\(/.test(s))) return 'python';
  // SQL
  if (/\b(SELECT|INSERT|UPDATE|DELETE|CREATE|ALTER|DROP|FROM|WHERE|JOIN)\b/i.test(s)) return 'sql';
  // HTML
  if (/<\/?[a-z][a-z0-9]*[\s>]/i.test(s) && /<!DOCTYPE|<html|<div|<p |<h[1-6]|<span/i.test(s)) return 'html';
  // CSS
  if (/\{[\s\S]*?:[\s\S]*?\}/.test(s) && /[.#]?\w+\s*\{/.test(s)) return 'css';
  // JavaScript
  if (/\b(const|let|var|function|=>|document\.|console\.log|async|await)\b/.test(s)) return 'javascript';

  return 'java';
}

const finalLang = lang || (isPSeIntCode ? 'pseint' : detectLang(code));
const isPseintFinal = finalLang === 'pseint';

// ─── Badge color por lenguaje ────────────────────────────────────────────────
const langColors: Record<string, string> = {
  pseint: '#45B3E0', csharp: '#9B4F96', kotlin: '#F18E33',
  java: '#f59e0b', python: '#3572A5', javascript: '#F7DF1E',
  typescript: '#3178C6', html: '#E34F26', css: '#1572B6',
  bash: '#4EAA25', sql: '#2980b9', cmd: '#888888',
};
const badgeColor = langColors[finalLang.toLowerCase()] || '#1E1210';
const langName = finalLang.toUpperCase();

const safeCode = String(code || '');
const lines = safeCode.replace(/\r\n/g, '\n').split('\n');

let hash = 0;
for (let i = 0; i < safeCode.length; i++) hash = (hash * 31 + safeCode.charCodeAt(i)) | 0;
const blockId = `block_${Math.abs(hash)}`;

// ─── Paleta IDE por lenguaje (para modo IDE) ─────────────────────────────────
const idePalettes: Record<string, any> = {
  java:       { bg: '#2b2b2b', txt: '#a9b7c6', kw: '#cc7832', str: '#6a8759', func: '#ffc66d', type: '#a9b7c6', op: '#a9b7c6' },
  csharp:     { bg: '#1e1e1e', txt: '#d4d4d4', kw: '#569cd6', str: '#d69d85', func: '#dcdcaa', type: '#4ec9b0', op: '#b4b4b4' },
  python:     { bg: '#282c34', txt: '#abb2bf', kw: '#c678dd', str: '#98c379', func: '#61afef', type: '#e5c07b', op: '#c678dd' },
  javascript: { bg: '#1e1e1e', txt: '#9cdcfe', kw: '#569cd6', str: '#ce9178', func: '#dcdcaa', type: '#4ec9b0', op: '#d4d4d4' },
  typescript: { bg: '#1e1e1e', txt: '#9cdcfe', kw: '#569cd6', str: '#ce9178', func: '#dcdcaa', type: '#4ec9b0', op: '#d4d4d4' },
  sql:        { bg: '#1e1e1e', txt: '#d4d4d4', kw: '#569cd6', str: '#ce9178', func: '#dcdcaa', type: '#4ec9b0', op: '#d4d4d4' },
  html:       { bg: '#1e1e1e', txt: '#d4d4d4', kw: '#569cd6', str: '#ce9178', func: '#dcdcaa', type: '#4ec9b0', op: '#d4d4d4' },
  css:        { bg: '#1e1e1e', txt: '#d4d4d4', kw: '#569cd6', str: '#ce9178', func: '#dcdcaa', type: '#4ec9b0', op: '#d4d4d4' },
  pseint:     { bg: '#ffffff', txt: '#000000', kw: '#0000FF', str: '#A31515', func: '#000000', type: '#008080', op: '#000000' },
};
const ide = idePalettes[finalLang.toLowerCase()] || idePalettes.python;
const ideStyles = `--ide-bg:${ide.bg};--ide-txt:${ide.txt};--ide-kw:${ide.kw};--ide-str:${ide.str};--ide-func:${ide.func};--ide-type:${ide.type};--ide-op:${ide.op};`;

// ─── Highlighters por lenguaje ────────────────────────────────────────────────
function escape(s: string) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

// Utilidad: tokenizador simple preservando strings y comentarios
function tokenize(line: string, rules: Array<{ re: RegExp; cls: string }>) {
  let result = '';
  let i = 0;
  const src = line;
  while (i < src.length) {
    let matched = false;
    for (const rule of rules) {
      const sub = src.slice(i);
      const m = sub.match(rule.re);
      if (m && m.index === 0) {
        result += `<span class="${rule.cls}">${escape(m[0])}</span>`;
        i += m[0].length;
        matched = true;
        break;
      }
    }
    if (!matched) {
      result += escape(src[i]);
      i++;
    }
  }
  return result;
}

// ─── Motor de tokenización de una sola pasada ────────────────────────────────
// Trabaja sobre el texto ORIGINAL (nunca sobre HTML ya generado).
// Cada carácter se procesa UNA sola vez evitando re-procesar atributos HTML.

type Token = { re: RegExp; cls: string };

function tokenize(src: string, tokens: Token[]): string {
  let out = '';
  let i = 0;
  while (i < src.length) {
    let matched = false;
    for (const tok of tokens) {
      // Anclar la regex al índice actual usando slice
      const m = tok.re.exec(src.slice(i));
      if (m && m.index === 0) {
        out += `<span class="${tok.cls}">${escape(m[0])}</span>`;
        i += m[0].length;
        matched = true;
        break;
      }
    }
    if (!matched) {
      out += escape(src[i]);
      i++;
    }
  }
  return out;
}

// ── PSeInt ────────────────────────────────────────────────────────────────────
function highlightPseint(line: string): string {
  return tokenize(line, [
    { re: /\/\/.*/,                                        cls: 'hl-comment' },
    { re: /"[^"]*"|'[^']*'/,                               cls: 'hl-str' },
    { re: /\b(Algoritmo|FinAlgoritmo|Definir|Como|Escribir|Leer|Si|Entonces|Sino|FinSi|Mientras|Hacer|FinMientras|Para|Hasta|Con Paso|FinPara|Segun|De Otro Modo|FinSegun|Funcion|FinFuncion|Verdadero|Falso|Y|O|No|MOD|DIV)\b/i, cls: 'hl-kw' },
    { re: /\b(Entero|Real|Caracter|Logico|Cadena)\b/i,    cls: 'hl-type' },
    { re: /\b\d+\.?\d*\b/,                                cls: 'hl-num' },
  ]);
}

// ── Java / Kotlin / JUnit ─────────────────────────────────────────────────────
function highlightJava(line: string): string {
  return tokenize(line, [
    { re: /\/\/.*/,                                                             cls: 'hl-comment' },
    { re: /"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'/,                               cls: 'hl-str' },
    { re: /@\w+/,                                                               cls: 'hl-annotation' },
    { re: /\b(public|private|protected|static|final|void|class|interface|enum|extends|implements|import|package|new|return|if|else|for|while|do|switch|case|break|continue|try|catch|finally|throw|throws|instanceof|this|super|abstract|synchronized|volatile|native|transient|strictfp|assert|record|sealed|permits|var)\b/, cls: 'hl-kw' },
    { re: /\b(int|long|double|float|boolean|char|byte|short|String|Integer|Long|Double|Boolean|List|Map|Set|Optional|Object|Number|ArrayList|HashMap|HashSet|Arrays|Collections)\b/, cls: 'hl-type' },
    { re: /\b(\w+)(?=\s*\()/,                                                  cls: 'hl-func' },
    { re: /\b\d+\.?\d*[LlFfDd]?\b/,                                           cls: 'hl-num' },
  ]);
}

// ── Python ────────────────────────────────────────────────────────────────────
function highlightPython(line: string): string {
  return tokenize(line, [
    { re: /#.*/,                                                                cls: 'hl-comment' },
    { re: /"""[\s\S]*?"""|'''[\s\S]*?'''|"[^"\\]*(?:\\.[^"\\]*)*"|'[^'\\]*(?:\\.[^'\\]*)*'/, cls: 'hl-str' },
    { re: /@\w+/,                                                               cls: 'hl-annotation' },
    { re: /\b(def|class|import|from|as|return|if|elif|else|for|while|in|not|and|or|is|None|True|False|try|except|finally|raise|with|pass|break|continue|yield|lambda|global|nonlocal|del|assert|async|await)\b/, cls: 'hl-kw' },
    { re: /\b(print|input|len|range|int|str|float|bool|list|dict|set|tuple|type|isinstance|enumerate|zip|map|filter|sorted|reversed|open|super|self|cls)\b/, cls: 'hl-func' },
    { re: /\b\d+\.?\d*\b/,                                                     cls: 'hl-num' },
  ]);
}

// ── C# ────────────────────────────────────────────────────────────────────────
function highlightCsharp(line: string): string {
  return tokenize(line, [
    { re: /\/\/.*/,                                                             cls: 'hl-comment' },
    { re: /"(?:[^"\\]|\\.)*"/,                                                  cls: 'hl-str' },
    { re: /\[(\w+)\]/,                                                          cls: 'hl-annotation' },
    { re: /\b(public|private|protected|internal|static|readonly|sealed|abstract|override|virtual|class|interface|enum|struct|record|namespace|using|new|return|if|else|for|foreach|while|do|switch|case|break|continue|try|catch|finally|throw|in|out|ref|params|var|void|this|base|async|await|get|set|init|required)\b/, cls: 'hl-kw' },
    { re: /\b(int|long|double|float|bool|char|byte|string|String|object|decimal|List|Dictionary|Array|IEnumerable|Task|Console|Math|StringBuilder|DateTime)\b/, cls: 'hl-type' },
    { re: /\b(\w+)(?=\s*\()/,                                                  cls: 'hl-func' },
    { re: /\b\d+\.?\d*[fFdDmMuUlL]*\b/,                                       cls: 'hl-num' },
  ]);
}

// ── SQL ───────────────────────────────────────────────────────────────────────
function highlightSql(line: string): string {
  return tokenize(line, [
    { re: /--.*/,                                                               cls: 'hl-comment' },
    { re: /'(?:[^'\\]|\\.)*'/,                                                  cls: 'hl-str' },
    { re: /\b(SELECT|INSERT|UPDATE|DELETE|CREATE|ALTER|DROP|FROM|WHERE|JOIN|LEFT|RIGHT|INNER|OUTER|FULL|CROSS|ON|GROUP\s+BY|ORDER\s+BY|HAVING|LIMIT|OFFSET|UNION|INTO|VALUES|SET|AS|AND|OR|NOT|IN|BETWEEN|LIKE|IS|NULL|DISTINCT|ALL|EXISTS|CASE|WHEN|THEN|ELSE|END|TABLE|VIEW|DATABASE|PRIMARY|FOREIGN|KEY|REFERENCES|UNIQUE|CHECK|DEFAULT|BEGIN|COMMIT|ROLLBACK)\b/i, cls: 'hl-kw' },
    { re: /\b(COUNT|SUM|AVG|MIN|MAX|COALESCE|CONCAT|SUBSTRING|LENGTH|UPPER|LOWER|TRIM|NOW|DATE|YEAR|MONTH|DAY|CAST|CONVERT|ROUND|ABS|FLOOR|CEILING)\b/i, cls: 'hl-func' },
    { re: /\b\d+\.?\d*\b/,                                                     cls: 'hl-num' },
  ]);
}

// ── JavaScript / TypeScript ───────────────────────────────────────────────────
function highlightJs(line: string): string {
  return tokenize(line, [
    { re: /\/\/.*/,                                                             cls: 'hl-comment' },
    { re: /`[^`]*`|"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'/,                      cls: 'hl-str' },
    { re: /\b(const|let|var|function|return|if|else|for|while|do|switch|case|break|continue|try|catch|finally|throw|new|class|extends|import|export|from|default|typeof|instanceof|in|of|delete|void|async|await|yield|static|get|set)\b/, cls: 'hl-kw' },
    { re: /\b(true|false|null|undefined|NaN|Infinity|this|super)\b/,           cls: 'hl-type' },
    { re: /\b(console|document|window|Array|Object|String|Number|Boolean|Math|Date|JSON|Promise|Map|Set|localStorage|fetch|setTimeout|setInterval)\b/, cls: 'hl-func' },
    { re: /\b(\w+)(?=\s*\()/,                                                  cls: 'hl-func' },
    { re: /\b\d+\.?\d*\b/,                                                     cls: 'hl-num' },
  ]);
}

// ── HTML ──────────────────────────────────────────────────────────────────────
function highlightHtml(line: string): string {
  return tokenize(line, [
    { re: /<!--[\s\S]*?-->/,                                                    cls: 'hl-comment' },
    { re: /"[^"]*"|'[^']*'/,                                                    cls: 'hl-str' },
    { re: /<\/?[\w-]+/,                                                         cls: 'hl-tag' },
    { re: /[\w-]+(?=\s*=)/,                                                     cls: 'hl-attr' },
  ]);
}

// ── CSS ───────────────────────────────────────────────────────────────────────
function highlightCss(line: string): string {
  return tokenize(line, [
    { re: /\/\*[\s\S]*?\*\//,                                                   cls: 'hl-comment' },
    { re: /"[^"]*"|'[^']*'/,                                                    cls: 'hl-str' },
    { re: /@[\w-]+/,                                                            cls: 'hl-kw' },
    { re: /#[0-9a-fA-F]{3,8}\b/,                                               cls: 'hl-num' },
    { re: /\b\d+\.?\d*(?:px|em|rem|vh|vw|%|s|ms|deg|fr|pt|cm|mm)?\b/,        cls: 'hl-num' },
    { re: /[\w-]+(?=\s*:)/,                                                     cls: 'hl-attr' },
    { re: /[.#]?[\w-]+(?=\s*\{)/,                                               cls: 'hl-tag' },
  ]);
}

// Dispatch al highlighter correcto
function highlightLine(line: string, lang: string): string {
  switch(lang) {
    case 'pseint':     return highlightPseint(line);
    case 'java':
    case 'kotlin':     return highlightJava(line);
    case 'csharp':     return highlightCsharp(line);
    case 'python':     return highlightPython(line);
    case 'sql':        return highlightSql(line);
    case 'javascript':
    case 'typescript': return highlightJs(line);
    case 'html':       return highlightHtml(line);
    case 'css':        return highlightCss(line);
    default:           return escape(line);

  }
}

const encodedCode = encodeURIComponent(safeCode);
---

<div
  id={blockId}
  class="my-8 border-[3px] rounded-2xl overflow-hidden shadow-[4px_4px_0px_var(--hl-badge)]"
  style={`--hl-badge: ${badgeColor}; border-color: ${badgeColor}; ${ideStyles}`}
>
  {/* Barra superior */}
  <div class="flex justify-between items-center bg-[#FAFAFA] border-b-[3px]" style={`border-bottom-color: ${badgeColor};`}>
    <span class={`text-[0.95rem] text-[#111] px-4 py-2 font-nunito font-extrabold ${title ? '' : 'invisible'}`}>
      {title || 'Código'}
    </span>
    <div class="flex items-center gap-0">
      {/* Botón copiar */}
      <button
        class="copy-btn group flex items-center gap-1.5 px-3 py-2 text-[0.78rem] font-nunito font-extrabold text-[#555] hover:text-[#111] hover:bg-black/5 transition-all border-r-2 cursor-pointer border-none bg-transparent"
        style={`border-right-color: ${badgeColor};`}
        data-copy-code={encodedCode}
        aria-label="Copiar código"
        title="Copiar código"
      >
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" />
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        <span class="copy-label hidden sm:inline">Copiar</span>
      </button>
      <span
        class="text-[0.8rem] text-white px-3 py-1.5 font-mono font-extrabold rounded-bl-xl border-l-[3px] border-l-black/10"
        style={`background-color: ${badgeColor}; color: ${finalLang === 'javascript' ? '#1E1210' : 'white'};`}
      >
        {langName}
      </span>
    </div>
  </div>

  {/* Área de código con highlighter personalizado */}
  <div
    class="code-viewer overflow-x-auto py-4 m-0 w-full font-mono"
    aria-label={`Código ${langName} (solo lectura)`}
    data-lang={finalLang}
  >
    {lines.map((line, idx) => (
      <div class="code-line flex px-2 leading-[1.65] text-[0.93rem] hover:bg-white/5 min-w-max">
        <span class="line-num text-right select-none min-w-[2.2rem] pr-3 mr-3 opacity-40 shrink-0 border-r border-white/10">
          {idx + 1}
        </span>
        <span class="whitespace-pre" set:html={highlightLine(line === '' ? ' ' : line, finalLang)} />
      </div>
    ))}
  </div>
</div>

<script>
  // Copy button logic — aplica a todos los bloques de código
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const encoded = btn.getAttribute('data-copy-code') ?? '';
      let text = '';
      try { text = decodeURIComponent(encoded); } catch { text = encoded; }

      const label = btn.querySelector('.copy-label');
      const svg   = btn.querySelector('svg');

      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }

      // Feedback visual
      if (label) label.textContent = '¡Copiado!';
      btn.style.color = '#06D6A0';
      setTimeout(() => {
        if (label) label.textContent = 'Copiar';
        btn.style.color = '';
      }, 1800);
    });
  });
</script>

<style>
  /* Fondo reactivo a las CSS vars del tema seleccionado */
  .code-viewer {
    background-color: var(--shiki-color-background, #1e1e1e);
    color: var(--shiki-color-text, #d4d4d4);
    transition: background-color 0.3s, color 0.3s;
  }

  /* Tokens — usan las mismas CSS vars que los temas en code-themes.css */
  :global(.hl-kw)         { color: var(--shiki-token-keyword);   font-weight: 700; }
  :global(.hl-str)        { color: var(--shiki-token-string);    }
  :global(.hl-func)       { color: var(--shiki-token-function);  }
  :global(.hl-func-call)  { color: var(--shiki-token-function);  }
  :global(.hl-type)       { color: var(--shiki-token-type);      }
  :global(.hl-num)        { color: var(--shiki-token-constant);  }
  :global(.hl-comment)    { color: var(--shiki-token-comment);   font-style: italic; opacity: 0.75; }
  :global(.hl-annotation) { color: var(--shiki-token-parameter); font-weight: 700; }
  :global(.hl-attr)       { color: var(--shiki-token-parameter); }
  :global(.hl-tag)        { color: var(--shiki-token-keyword);   }

  /* Número de línea */
  .line-num { color: var(--shiki-token-comment, #555); }

  /* Hover suave en cada línea */
  .code-line:hover { background: rgba(255,255,255,0.04); }
</style>
