---
import { Code } from 'astro:components';

interface Props {
  code: string;
  title?: string;
  lang?: string;
  isPSeIntCode?: boolean;
}

const { code, title, lang, isPSeIntCode = false } = Astro.props;

// Inferir lenguaje si no se provee
function detectLang(src: string) {
  const s = String(src ?? '');

  // PSeInt
  if (/\bAlgoritmo\b/i.test(s) && /\bFinAlgoritmo\b/i.test(s)) return 'pseint';

  // C#
  if (/\bConsole\.Write(Line)?\b/.test(s) || /\busing System\b/.test(s) || /\bnamespace\b/.test(s)) return 'csharp';

  // Kotlin
  if (/\bfun main\b/.test(s) || (/\bprintln\b/.test(s) && !/\bSystem\.out\b/.test(s))) return 'kotlin';

  // Java / JUnit — detectar anotaciones JUnit ANTES de la detección Java genérica
  if (
    /@Test\b/.test(s) ||
    /@BeforeEach\b/.test(s) ||
    /@AfterEach\b/.test(s) ||
    /@BeforeAll\b/.test(s) ||
    /@AfterAll\b/.test(s) ||
    /\bassertEquals\b/.test(s) ||
    /\bassertThrows\b/.test(s) ||
    /\bassertTrue\b/.test(s) ||
    /\bassertFalse\b/.test(s) ||
    /\bassertNotNull\b/.test(s) ||
    /import org\.junit/.test(s) ||
    /import static org\.junit/.test(s)
  ) return 'java';

  // Java genérico
  if (/\bpublic class\b/.test(s) || /\bSystem\.out\.print/.test(s) || /\bimport java\./.test(s)) return 'java';

  // Python
  if (/\bdef \w+\(/.test(s) || /\bimport \w/.test(s) && /\bprint\(/.test(s)) return 'python';

  // SQL
  if (/\b(SELECT|INSERT|UPDATE|DELETE|CREATE|ALTER|DROP|FROM|WHERE|JOIN)\b/i.test(s)) return 'sql';

  // HTML
  if (/<\/?[a-z][a-z0-9]*[\s>]/i.test(s) && /<!DOCTYPE|<html|<div|<p |<h[1-6]|<span/i.test(s)) return 'html';

  // CSS
  if (/\{[\s\S]*?:[\s\S]*?\}/.test(s) && /[.#]?\w+\s*\{/.test(s) && !/{/.test(s.replace(/\/\*[\s\S]*?\*\//g, ''))) return 'css';

  // JavaScript / TypeScript
  if (/\b(const|let|var|function|=>|document\.|console\.log|async|await)\b/.test(s)) return 'javascript';

  return 'java'; // fallback inteligente — la mayoría del contenido del curso es Java
}

const finalLang = lang || (isPSeIntCode ? 'pseint' : detectLang(code));
const isPseintFinal = finalLang === 'pseint';

// Paleta de colores neo-brutalist por lenguaje
const langColors: Record<string, string> = {
  pseint: '#45B3E0',   // var(--info)
  csharp: '#9B4F96',   // Morado C#
  kotlin: '#F18E33',   // Naranja Kotlin
  java: '#f59e0b',     // Amarillo oscuro Java
  python: '#3572A5',   // Azul Python
  cmd: '#888888',      // Gris
  javascript: '#F7DF1E',
  typescript: '#3178C6',
  html: '#E34F26',
  css: '#1572B6',
  bash: '#4EAA25',
  sql: '#2980b9'
};

const badgeColor = langColors[finalLang.toLowerCase()] || '#1E1210';
const langName = finalLang.toUpperCase();

const encodedCode = isPseintFinal ? encodeURIComponent(code) : '';

let hash = 0;
const safeCode = code || '';
for (let i = 0; i < safeCode.length; i++) {
  hash = (hash * 31 + safeCode.charCodeAt(i)) | 0;
}
const blockId = `block_${Math.abs(hash)}`;
const lines = String(safeCode).replace(/\r\n/g, '\n').split('\n');

function highlightPSeInt(line: string) {
  let text = line.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  text = text.replace(/(&quot;.*?&quot;|".*?")/g, '<span class="text-[#A31515]">$1</span>');
  text = text.replace(/\b(Algoritmo|FinAlgoritmo|Definir|Como|Escribir|Leer|Si|Entonces|Sino|FinSi|Mientras|Hacer|FinMientras|Para|Hasta|Con Paso|FinPara|Segun|De Otro Modo|FinSegun|Funcion|FinFuncion|Verdadero|Falso)\b/gi, '<span class="text-blue-600 font-extrabold">$&</span>');
  text = text.replace(/\b(Entero|Real|Caracter|Logico|Cadena)\b/gi, '<span class="text-teal-600">$&</span>');
  text = text.replace(/(\/\/.*)/g, '<span class="text-green-700 italic">$1</span>');
  return text;
}

// Convertir csharp a cs para Shiki, o python a py
const shikiLang = finalLang === 'csharp' ? 'cs' : finalLang === 'cmd' ? 'bash' : finalLang;

// --- Lógica de Colores Estilo IDE ---
const idePalettes: Record<string, any> = {
  java: {
    bg: '#2b2b2b', txt: '#a9b7c6', kw: '#cc7832', str: '#6a8759', func: '#ffc66d', type: '#a9b7c6', op: '#a9b7c6'
  },
  csharp: {
    bg: '#1e1e1e', txt: '#d4d4d4', kw: '#569cd6', str: '#d69d85', func: '#dcdcaa', type: '#4ec9b0', op: '#b4b4b4'
  },
  python: {
    bg: '#282c34', txt: '#abb2bf', kw: '#c678dd', str: '#98c379', func: '#61afef', type: '#e5c07b', op: '#c678dd'
  },
  javascript: {
    bg: '#1e1e1e', txt: '#9cdcfe', kw: '#569cd6', str: '#ce9178', func: '#dcdcaa', type: '#4ec9b0', op: '#d4d4d4'
  },
  typescript: {
    bg: '#1e1e1e', txt: '#9cdcfe', kw: '#569cd6', str: '#ce9178', func: '#dcdcaa', type: '#4ec9b0', op: '#d4d4d4'
  },
  pseint: {
    bg: '#ffffff', txt: '#000000', kw: '#0000FF', str: '#A31515', func: '#000000', type: '#008080', op: '#000000'
  },
  sql: {
    bg: '#1e1e1e', txt: '#d4d4d4', kw: '#569cd6', str: '#ce9178', func: '#dcdcaa', type: '#4ec9b0', op: '#d4d4d4'
  }
};

const ide = idePalettes[finalLang.toLowerCase()] || idePalettes.python;
const ideStyles = `
  --ide-bg: ${ide.bg};
  --ide-txt: ${ide.txt};
  --ide-kw: ${ide.kw};
  --ide-str: ${ide.str};
  --ide-func: ${ide.func};
  --ide-type: ${ide.type};
  --ide-op: ${ide.op};
`;
---

<div class="my-8 border-[3px] border-border rounded-2xl bg-[var(--shiki-color-background,#1a1a1a)] overflow-hidden transition-colors shadow-neo" style={`border-color: ${badgeColor}; box-shadow: 4px 4px 0px ${badgeColor}; ${ideStyles}`}>
  <div class="flex justify-between items-center bg-[#FAFAFA] border-b-[3px]" style={`border-bottom-color: ${badgeColor};`}>
    <span class={`text-[0.95rem] text-[#111] px-4 py-2 font-nunito font-extrabold ${title ? '' : 'invisible'}`}>
      {title || 'Código'}
    </span>
    <span class="text-[0.8rem] text-white px-3 py-1.5 font-mono font-extrabold rounded-bl-xl border-l-[3px] border-l-black/10 shadow-[inset_0_-2px_0_rgba(0,0,0,0.15)]" style={`background-color: ${badgeColor};`}>
      {langName}
    </span>
  </div>

  {isPseintFinal ? (
    <div class="bg-white overflow-auto py-4 m-0 w-full font-mono transition-colors" aria-label={`Editor ${langName} (solo lectura)`}>
      {lines.map((line, idx) => (
        <div class="flex px-4 leading-[1.6] text-[0.95rem]">
          <span class="text-textMuted text-right select-none min-w-[2rem] border-r-2 border-r-black/10 pr-3 mr-3">{idx + 1}</span>
          <span class="text-black whitespace-pre-wrap" set:html={highlightPSeInt(line === '' ? ' ' : line)}></span>
        </div>
      ))}
    </div>
  ) : (
    <div class="standard-editor">
      <Code code={safeCode} lang={shikiLang as any} theme="css-variables" />
    </div>
  )}
</div>

{isPseintFinal && (
  <script>
    // @ts-nocheck
    const root = document.currentScript?.previousElementSibling;
    const runBtn = root?.querySelector('[data-pseint-run]');
    const copyBtn = root?.querySelector('[data-pseint-copy]');

    const getCode = (btn) => {
      const raw = btn?.getAttribute('data-pseint-code') ?? '';
      try {
        return decodeURIComponent(raw);
      } catch {
        return raw;
      }
    };

    if (runBtn) {
      runBtn.addEventListener('click', () => {
        try {
          localStorage.setItem('pseint.code', getCode(runBtn));
          localStorage.setItem('pseint.autorun', '1');
        } catch {}
        window.location.href = '/pseint/simulador/';
      });
    }

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(getCode(copyBtn));
          copyBtn.textContent = '¡Copiado! ✅';
          setTimeout(() => (copyBtn.textContent = 'Copiar 📄'), 1400);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = getCode(copyBtn);
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          ta.remove();
          copyBtn.textContent = '¡Copiado! ✅';
          setTimeout(() => (copyBtn.textContent = 'Copiar 📄'), 1400);
        }
      });
    }
  </script>
)}

<style>
  /* Quitamos paddings/márgenes forzados para pre (Shiki) */
  :global(.standard-editor pre) {
    margin: 0 !important;
    padding: 1.25rem 1rem !important;
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    font-size: 0.95rem;
    box-shadow: none !important;
  }
  :global(.standard-editor code) {
    font-family: 'JetBrains Mono', monospace;
  }
</style>
