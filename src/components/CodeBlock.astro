---
import { highlightLine, idePalettes, langColors, resolveFinalLang } from '../lib/codeHighlight';

interface Props {
  code: string;
  title?: string;
  lang?: string;
  isPSeIntCode?: boolean;
}

const { code, title, lang, isPSeIntCode = false } = Astro.props;

const finalLang = resolveFinalLang(lang, code, isPSeIntCode);

const badgeColor = langColors[finalLang.toLowerCase()] || '#1E1210';
const langName = finalLang.toUpperCase();

const safeCode = String(code || '');
const lines = safeCode.replace(/\r\n/g, '\n').split('\n');

let hash = 0;
for (let i = 0; i < safeCode.length; i++) hash = (hash * 31 + safeCode.charCodeAt(i)) | 0;
const blockId = `block_${Math.abs(hash)}`;

const ide = idePalettes[finalLang.toLowerCase()] || idePalettes.python;
const ideStyles = `--ide-bg:${ide.bg};--ide-txt:${ide.txt};--ide-kw:${ide.kw};--ide-str:${ide.str};--ide-func:${ide.func};--ide-type:${ide.type};--ide-op:${ide.op};`;

const encodedCode = encodeURIComponent(safeCode);
---

<div
  id={blockId}
  class="my-8 border-[3px] rounded-2xl overflow-hidden shadow-[4px_4px_0px_var(--hl-badge)]"
  style={`--hl-badge: ${badgeColor}; border-color: ${badgeColor}; ${ideStyles}`}
>
  {/* Barra superior */}
  <div class="flex justify-between items-center bg-[#FAFAFA] border-b-[3px]" style={`border-bottom-color: ${badgeColor};`}>
    <span class={`text-[0.95rem] text-[#111] px-4 py-2 font-nunito font-extrabold ${title ? '' : 'invisible'}`}>
      {title || 'Código'}
    </span>
    <div class="flex items-center gap-0">
      {/* Botón copiar */}
      <button
        class="copy-btn group flex items-center gap-1.5 px-3 py-2 text-[0.78rem] font-nunito font-extrabold text-[#555] hover:text-[#111] hover:bg-black/5 transition-all border-r-2 cursor-pointer border-none bg-transparent"
        style={`border-right-color: ${badgeColor};`}
        data-copy-code={encodedCode}
        aria-label="Copiar código"
        title="Copiar código"
      >
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" />
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        <span class="copy-label hidden sm:inline">Copiar</span>
      </button>
      <span
        class="text-[0.8rem] text-white px-3 py-1.5 font-mono font-extrabold rounded-bl-xl border-l-[3px] border-l-black/10"
        style={`background-color: ${badgeColor}; color: ${finalLang === 'javascript' ? '#1E1210' : 'white'};`}
      >
        {langName}
      </span>
    </div>
  </div>

  {/* Área de código con highlighter personalizado */}
  <div
    class="code-viewer overflow-x-auto py-4 m-0 w-full font-mono"
    aria-label={`Código ${langName} (solo lectura)`}
    data-lang={finalLang}
  >
    {lines.map((line, idx) => (
      <div class="code-line flex px-2 leading-[1.65] text-[0.93rem] hover:bg-white/5 min-w-max">
        <span class="line-num text-right select-none min-w-[2.2rem] pr-3 mr-3 opacity-40 shrink-0 border-r border-white/10">
          {idx + 1}
        </span>
        <span class="whitespace-pre" set:html={highlightLine(line === '' ? ' ' : line, finalLang)} />
      </div>
    ))}
  </div>
</div>

<script>
  // Copy button logic — aplica a todos los bloques de código
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const encoded = btn.getAttribute('data-copy-code') ?? '';
      let text = '';
      try {
        text = decodeURIComponent(encoded);
      } catch {
        text = encoded;
      }

      const label = btn.querySelector('.copy-label');

      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }

      // Feedback visual
      if (label) label.textContent = '¡Copiado!';
      (btn as HTMLElement).style.color = '#06D6A0';
      setTimeout(() => {
        if (label) label.textContent = 'Copiar';
        (btn as HTMLElement).style.color = '';
      }, 1800);
    });
  });
</script>

<style>
  /* Fondo reactivo a las CSS vars del tema seleccionado */
  .code-viewer {
    background-color: var(--shiki-color-background, #1e1e1e);
    color: var(--shiki-color-text, #d4d4d4);
    transition: background-color 0.3s, color 0.3s;
    font-variant-ligatures: none;
    font-feature-settings: 'liga' 0, 'calt' 0, 'dlig' 0;
  }

  /* Consola C++: usa la paleta --ide-* inyectada en el bloque (azul profundo + acentos) */
  .code-viewer[data-lang='cpp'] {
    background-color: var(--ide-bg);
    color: var(--ide-txt);
    --shiki-color-background: var(--ide-bg);
    --shiki-color-text: var(--ide-txt);
    --shiki-token-keyword: var(--ide-kw);
    --shiki-token-string: var(--ide-str);
    --shiki-token-string-expression: var(--ide-str);
    --shiki-token-function: var(--ide-func);
    --shiki-token-type: var(--ide-type);
    --shiki-token-comment: #7a9ab8;
    --shiki-token-constant: var(--ide-type);
    --shiki-token-parameter: var(--ide-txt);
    --shiki-token-operator: var(--ide-op);
    --shiki-token-variable: var(--ide-txt);
    --shiki-token-punctuation: var(--ide-op);
  }

  .code-viewer[data-lang='ruby'] {
    background-color: var(--ide-bg);
    color: var(--ide-txt);
    --shiki-color-background: var(--ide-bg);
    --shiki-color-text: var(--ide-txt);
    --shiki-token-keyword: var(--ide-kw);
    --shiki-token-string: var(--ide-str);
    --shiki-token-string-expression: var(--ide-str);
    --shiki-token-function: var(--ide-func);
    --shiki-token-type: var(--ide-type);
    --shiki-token-comment: #9a8a7a;
    --shiki-token-constant: var(--ide-type);
    --shiki-token-parameter: var(--ide-txt);
    --shiki-token-operator: var(--ide-op);
    --shiki-token-variable: var(--ide-txt);
    --shiki-token-punctuation: var(--ide-op);
  }
  .code-viewer :global(.code-line),
  .code-viewer :global(.whitespace-pre) {
    font-variant-ligatures: none;
    font-feature-settings: 'liga' 0, 'calt' 0, 'dlig' 0;
  }

  /* Tokens — usan las mismas CSS vars que los temas en code-themes.css */
  :global(.hl-kw) {
    color: var(--shiki-token-keyword);
    font-weight: 700;
  }
  :global(.hl-str) {
    color: var(--shiki-token-string);
  }
  :global(.hl-func) {
    color: var(--shiki-token-function);
  }
  :global(.hl-func-call) {
    color: var(--shiki-token-function);
  }
  :global(.hl-type) {
    color: var(--shiki-token-type);
  }
  :global(.hl-num) {
    color: var(--shiki-token-constant);
  }
  :global(.hl-comment) {
    color: var(--shiki-token-comment);
    font-style: italic;
    opacity: 0.75;
  }
  :global(.hl-annotation) {
    color: var(--shiki-token-parameter);
    font-weight: 700;
  }
  :global(.hl-attr) {
    color: var(--shiki-token-parameter);
  }
  :global(.hl-tag) {
    color: var(--shiki-token-keyword);
  }

  /* Número de línea */
  .line-num {
    color: var(--shiki-token-comment, #555);
  }

  /* Hover suave en cada línea */
  .code-line:hover {
    background: rgba(255, 255, 255, 0.04);
  }
</style>
