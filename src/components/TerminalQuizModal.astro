---
import { terminalQuizBank } from '../data/terminalQuizBank';

type Props = {
  quizKey: string;
};

const { quizKey } = Astro.props as Props;
const quiz = terminalQuizBank[quizKey];

if (!quiz) {
  throw new Error(`TerminalQuizModal: no existe quizKey "${quizKey}" en terminalQuizBank.`);
}

const modalId = `term-quiz-modal-${quizKey}`;
const openBtnId = `term-quiz-open-${quizKey}`;
const closeBtnId = `term-quiz-close-${quizKey}`;
const resultId = `term-quiz-result-${quizKey}`;
const radiosNamePrefix = `term_quiz_${quizKey}_q_`;
---

<div class="term-quiz">
  <button id={openBtnId} type="button" class="term-quiz__start" data-term-quiz-open>
    <span class="prompt-sym">$</span> Comenzar Test Terminal
  </button>

  <div id={modalId} class="term-quiz__modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="term-quiz__overlay" data-term-quiz-close></div>

    <div class="term-quiz__panel">
      <div class="term-quiz__header">
        <div class="term-quiz__title">
          <span class="term-quiz__title-badge">CLI Terminal Quiz</span>
          <span>{quiz.title}</span>
        </div>

        <button
          id={closeBtnId}
          type="button"
          class="term-quiz__close"
          data-term-quiz-close
          aria-label="Cerrar"
        >
          ✕
        </button>
      </div>

      <div class="term-quiz__body">
        <p class="term-quiz__intro">
          Demuestra tu dominio de la línea de comandos. Son <strong>{quiz.questions.length}</strong> preguntas.
        </p>

        <form class="term-quiz__form" onsubmit="return false;">
          {quiz.questions.map((q, i) => (
            <section
              class="term-quiz__q"
              data-term-quiz-q={i}
              data-correct-index={q.correctIndex}
            >
              <h4 class="term-quiz__q-title">
                <span class="term-quiz__q-num">{i + 1}</span>. {q.prompt}
              </h4>

              <div class="term-quiz__options">
                {q.options.map((opt, idx) => {
                  const name = `${radiosNamePrefix}${i}`;
                  const value = String(idx);
                  const id = `${radiosNamePrefix}${i}_${idx}`;
                  return (
                    <label class="term-quiz__opt" for={id}>
                      <input
                        id={id}
                        type="radio"
                        name={name}
                        value={value}
                        data-term-quiz-answer={i}
                      />
                      <span>{opt}</span>
                    </label>
                  );
                })}
              </div>

              <div
                class="term-quiz__feedback"
                data-term-quiz-feedback={i}
                aria-live="polite"
              ></div>
            </section>
          ))}
        </form>
      </div>

      <div class="term-quiz__footer">
        <div id={resultId} class="term-quiz__result" aria-live="polite"></div>
        <div class="term-quiz__actions">
          <button type="button" class="term-quiz__submit" data-term-quiz-submit>
            Ejecutar y Revisar
          </button>
          <button type="button" class="term-quiz__restart" data-term-quiz-restart>
            Limpiar (Reset)
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const WKEY = '__terminalQuizModalDelegated__';
    if (window[WKEY]) return;
    window[WKEY] = true;

    function closeModal(modal) {
      if (!modal) return;
      modal.setAttribute('aria-hidden', 'true');
      modal.classList.remove('is-open');
      document.documentElement.style.overflow = '';
    }

    function openModal(modal) {
      if (!modal) return;
      const resultEl = modal.querySelector('.term-quiz__result');
      if (resultEl) resultEl.textContent = '';
      modal.querySelectorAll('[data-term-quiz-feedback]').forEach((el) => {
        el.textContent = '';
      });
      modal.setAttribute('aria-hidden', 'false');
      modal.classList.add('is-open');
      document.documentElement.style.overflow = 'hidden';
    }

    function shuffleQuestions(modal) {
      const form = modal.querySelector('.term-quiz__form');
      const qEls = Array.from(modal.querySelectorAll('[data-term-quiz-q]'));
      if (!form || qEls.length < 2) return;

      for (let i = qEls.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        const tmp = qEls[i];
        qEls[i] = qEls[j];
        qEls[j] = tmp;
      }

      qEls.forEach((el) => {
        form.appendChild(el);
      });

      qEls.forEach((qEl, idx) => {
        const numEl = qEl.querySelector('.term-quiz__q-num');
        if (numEl) numEl.textContent = String(idx + 1);
      });
    }

    function gradeModal(modal) {
      const resultEl = modal.querySelector('.term-quiz__result');
      if (!resultEl) return;

      const qEls = modal.querySelectorAll('[data-term-quiz-q]');
      let score = 0;

      qEls.forEach((qEl) => {
        const correct = Number(qEl.getAttribute('data-correct-index'));
        const feedbackEl = qEl.querySelector('[data-term-quiz-feedback]');
        const selected = qEl.querySelector('input[type="radio"]:checked');
        const idx = selected ? Number(selected.value) : null;

        const correctInput = qEl.querySelector(`input[type="radio"][value="${correct}"]`);
        const correctText = correctInput?.parentElement?.querySelector('span')?.textContent ?? '';
        const selectedText = selected?.parentElement?.querySelector('span')?.textContent ?? '';

        const isCorrect = idx === correct;
        if (isCorrect) score++;

        if (feedbackEl) {
          if (isCorrect) {
            feedbackEl.innerHTML = '<span style="color:#00ff41;">> ACCESS GRANTED. SINTAXIS OK. ✅</span>';
          } else {
            feedbackEl.innerHTML =
              `<span style="color:#fff; background: #ff0000; padding: 2px 5px;">> ACCESS DENIED. ERROR DE SEGURIDAD. ❌</span>` +
              `<br><span style="color: #00ff41;">CORE_CMD_EXPECTED: "${correctText}"</span>`;
          }
        }
      });

      const total = qEls.length;
      if (score === total) resultEl.innerHTML = `[SISTEMA]: ESTADO SUPERUSUARIO ACTIVADO (${score}/${total}).`;
      else if (score > total / 2) resultEl.innerHTML = `[SISTEMA]: CONEXIÓN ESTABLE (${score}/${total}).`;
      else resultEl.innerHTML = `[SISTEMA]: CONEXIÓN INESTABLE (${score}/${total}). REINICIANDO NODO...`;
    }

    document.addEventListener('click', (e) => {
      const target = e.target;

      const startBtn = target instanceof Element ? target.closest('.term-quiz__start') : null;
      if (startBtn) {
        e.preventDefault();
        const root = startBtn.closest('.term-quiz');
        const modal = root?.querySelector('.term-quiz__modal') || null;
        openModal(modal);
        if (modal) shuffleQuestions(modal);
        return;
      }

      const closeBtn = target instanceof Element ? target.closest('[data-term-quiz-close]') : null;
      if (closeBtn) {
        const root = closeBtn.closest('.term-quiz');
        const modal = root?.querySelector('.term-quiz__modal') || null;
        closeModal(modal);
        return;
      }

      const submitBtn = target instanceof Element ? target.closest('[data-term-quiz-submit]') : null;
      if (submitBtn) {
        const root = submitBtn.closest('.term-quiz');
        const modal = root?.querySelector('.term-quiz__modal') || null;
        if (modal) gradeModal(modal);
        return;
      }

      const restartBtn = target instanceof Element ? target.closest('[data-term-quiz-restart]') : null;
      if (restartBtn) {
        const root = restartBtn.closest('.term-quiz');
        const modal = root?.querySelector('.term-quiz__modal') || null;
        if (!modal) return;
        const resultEl = modal.querySelector('.term-quiz__result');
        if (resultEl) resultEl.textContent = '';
        modal.querySelectorAll('input[type="radio"]').forEach((r) => {
          r.checked = false;
        });
        modal.querySelectorAll('[data-term-quiz-feedback]').forEach((el) => {
          el.textContent = '';
        });
        return;
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll('.term-quiz__modal.is-open').forEach((m) => closeModal(m));
    });
  })();
</script>

<style>
  .term-quiz {
    margin: 2.5rem 0 2rem;
  }

  /* Matrix Hacker Aesthetic */
  .term-quiz__start {
    width: 100%;
    max-width: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 1rem 1.25rem;
    border-radius: 4px;
    border: 2px solid #00ff41;
    background: #000; 
    color: #00ff41;
    font-family: 'Courier New', Courier, monospace;
    font-weight: 900;
    font-size: 1.1rem;
    cursor: pointer;
    box-shadow: 0 0 10px rgba(0, 255, 65, 0.4);
    transition: all 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 auto;
  }

  .prompt-sym { color: #00ff41; margin-right: 8px; animation: blink 1s infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  .term-quiz__start:hover {
    background: #00ff41;
    color: #000;
    box-shadow: 0 0 30px rgba(0, 255, 65, 0.8);
    transform: scale(1.02);
  }

  .term-quiz__modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: none;
  }

  .term-quiz__modal.is-open {
    display: block;
  }

  .term-quiz__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
  }

  .term-quiz__panel {
    position: relative;
    max-width: 900px;
    margin: 4vh auto 0;
    background: #000;
    border: 1px solid #00ff41;
    border-radius: 4px;
    box-shadow: 0 0 50px rgba(0, 255, 65, 0.2);
    overflow: hidden;
    color: #00ff41;
    font-family: 'Courier New', Courier, monospace;
  }

  .term-quiz__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #00ff41;
    background: #000; 
  }

  .term-quiz__title {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .term-quiz__title-badge {
    background: #00ff41;
    color: #000;
    padding: 0.2rem 0.8rem;
    border-radius: 2px;
    font-size: 0.8rem;
    font-weight: 900;
  }

  .term-quiz__close {
    background: transparent;
    color: #00ff41;
    border: 1px solid #00ff41;
    width: 35px;
    height: 35px;
    cursor: pointer;
    font-size: 1.1rem;
    transition: all 0.2s;
  }
  .term-quiz__close:hover {
    background: #00ff41;
    color: #000;
  }

  .term-quiz__body {
    padding: 2rem;
    max-height: 70vh;
    overflow: auto;
    scrollbar-width: thin;
    scrollbar-color: #00ff41 #000;
  }

  .term-quiz__intro {
    margin: 0 0 2rem;
    color: #00ff41;
    opacity: 0.8;
    font-size: 1rem;
    border-left: 3px solid #00ff41;
    padding-left: 1rem;
  }

  .term-quiz__q {
    padding: 1.5rem;
    border: 1px solid rgba(0, 255, 65, 0.3);
    background: rgba(0, 255, 65, 0.05);
    margin-bottom: 2rem;
    transition: border-color 0.3s;
  }
  .term-quiz__q:hover {
    border-color: #00ff41;
  }

  .term-quiz__q-title {
    margin: 0 0 1.5rem;
    font-weight: 900;
    font-size: 1.1rem;
    color: #00ff41;
    text-shadow: 0 0 5px rgba(0, 255, 65, 0.5);
  }

  .term-quiz__q-num { color: #fff; background: #00ff41; padding: 0 5px; color: #000; }

  .term-quiz__options {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .term-quiz__opt {
    display: flex;
    gap: 1rem;
    align-items: center;
    cursor: pointer;
    color: #00ff41;
    padding: 0.75rem;
    border: 1px solid transparent;
    transition: all 0.2s;
  }

  .term-quiz__opt:hover {
    background: rgba(0, 255, 65, 0.1);
    border-color: rgba(0, 255, 65, 0.5);
  }

  .term-quiz__opt input {
    width: 18px;
    height: 18px;
    accent-color: #00ff41;
    cursor: pointer;
  }

  .term-quiz__footer {
    padding: 1.5rem 2rem;
    border-top: 1px solid #00ff41;
    background: #000;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .term-quiz__result {
    font-size: 1.2rem;
    font-weight: 900;
    color: #00ff41;
    text-transform: uppercase;
    letter-spacing: 2px;
    min-height: 1.5rem;
  }

  .term-quiz__actions {
    display: flex;
    gap: 1.5rem;
    justify-content: flex-end;
  }

  .term-quiz__submit {
    background: #00ff41;
    color: #000;
    border: none;
    padding: 0.8rem 2rem;
    font-weight: 900;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .term-quiz__submit:hover {
    box-shadow: 0 0 20px #00ff41;
    transform: translateY(-2px);
  }

  .term-quiz__restart {
    background: transparent;
    color: #00ff41;
    border: 1px solid #00ff41;
    padding: 0.8rem 2rem;
    font-weight: 900;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .term-quiz__restart:hover {
    background: rgba(0, 255, 65, 0.1);
  }

  .term-quiz__feedback {
    margin-top: 1rem;
    font-size: 0.9rem;
    font-weight: 900;
  }

  @media (max-width: 650px) {
    .term-quiz__panel {
      margin-top: 2vh;
      width: calc(100% - 1rem);
    }
    .term-quiz__title { font-size: 1rem; }
    .term-quiz__actions { flex-direction: column; }
  }
</style>
