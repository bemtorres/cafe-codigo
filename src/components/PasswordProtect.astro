---
interface Props {
  courseSlug: string;
}

const { courseSlug } = Astro.props;
---

<div id="password-overlay" class="fixed inset-0 z-[9999] bg-[#F1F5F9] hidden flex-col items-center justify-center p-6">
  <div class="max-w-md w-full bg-white rounded-3xl border-4 border-[#1E1210] p-8 shadow-[8px_8px_0px_#1E1210] text-center">
    <div class="text-6xl mb-4">🔒</div>
    <h2 class="font-nunito font-black text-2xl text-[#1E1210] mb-2">Contenido Exclusivo</h2>
    <p class="font-nunito text-[#475569] mb-6 font-bold">Este contenido aun no es público.</p>
    
    <form id="password-form" class="flex flex-col gap-4">
      <input type="password" id="course-password" placeholder="Ingresa la contraseña" class="w-full px-4 py-3 rounded-xl border-4 border-[#1E1210] font-nunito font-bold text-lg text-center outline-none focus:border-[#45B3E0]" autocomplete="off" />
      <div id="password-error" class="hidden text-[#EF476F] font-nunito font-bold text-sm">Contraseña incorrecta.</div>
      <button type="submit" class="w-full py-3 rounded-xl border-4 border-[#1E1210] bg-[#45B3E0] text-white font-nunito font-black text-lg shadow-[4px_4px_0px_#1E1210] hover:-translate-y-1 hover:shadow-[4px_6px_0px_#1E1210] active:translate-y-1 active:shadow-[0px_0px_0px_#1E1210] transition-all">
        Desbloquear Curso
      </button>
    </form>
  </div>
</div>

<script is:inline define:vars={{ courseSlug }}>
  (function() {
    const isUnlocked = localStorage.getItem(`unlocked_${courseSlug}`);
    if (!isUnlocked) {
      // Ocultar barras de navegación y contenido principal si está bloqueado
      document.documentElement.style.overflow = 'hidden';
      const style = document.createElement('style');
      style.id = 'lock-styles';
      style.innerHTML = `
        .main-content-wrapper, header, #mobileBottomNav { display: none !important; }
        #password-overlay { display: flex !important; }
      `;
      document.head.appendChild(style);
    }
  })();
</script>

<script is:inline define:vars={{ courseSlug }}>
  window.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('password-form');
    const input = document.getElementById('course-password');
    const errorMsg = document.getElementById('password-error');
    const overlay = document.getElementById('password-overlay');
    const lockStyles = document.getElementById('lock-styles');

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (input.value === 'cafecito') {
          localStorage.setItem(`unlocked_${courseSlug}`, 'true');
          overlay.style.display = 'none';
          document.documentElement.style.overflow = '';
          if (lockStyles) lockStyles.remove();
        } else {
          errorMsg.classList.remove('hidden');
          input.value = '';
          input.focus();
          // sacudir el input
          input.style.transform = 'translateX(10px)';
          setTimeout(() => input.style.transform = 'translateX(-10px)', 100);
          setTimeout(() => input.style.transform = 'translateX(10px)', 200);
          setTimeout(() => input.style.transform = 'translateX(0)', 300);
        }
      });
    }
  });
</script>
