---
import { htmlQuizBank } from '../data/htmlQuizBank';

type Props = {
  quizKey: string;
};

const { quizKey } = Astro.props as Props;
const quiz = htmlQuizBank[quizKey];

if (!quiz) {
  throw new Error(`HtmlQuizModal: no existe quizKey "${quizKey}" en htmlQuizBank.`);
}

const modalId = `html-quiz-modal-${quizKey}`;
const openBtnId = `html-quiz-open-${quizKey}`;
const closeBtnId = `html-quiz-close-${quizKey}`;
const resultId = `html-quiz-result-${quizKey}`;
const radiosNamePrefix = `html_quiz_${quizKey}_q_`;
---

<div class="html-quiz">
  <button id={openBtnId} type="button" class="html-quiz__start" data-html-quiz-open>
    Comprobar conocimientos HTML
  </button>

  <div id={modalId} class="html-quiz__modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="html-quiz__overlay" data-html-quiz-close></div>

    <div class="html-quiz__panel">
      <div class="html-quiz__header">
        <div class="html-quiz__title">
          <span class="html-quiz__title-badge">HTML5 Quiz</span>
          <span>{quiz.title}</span>
        </div>

        <button
          id={closeBtnId}
          type="button"
          class="html-quiz__close"
          data-html-quiz-close
          aria-label="Cerrar"
        >
          ✕
        </button>
      </div>

      <div class="html-quiz__body">
        <p class="html-quiz__intro">
          Repasa las etiquetas y la estructura de un sitio web. Son <strong>{quiz.questions.length}</strong> preguntas.
        </p>

        <form class="html-quiz__form" onsubmit="return false;">
          {quiz.questions.map((q, i) => (
            <section
              class="html-quiz__q"
              data-html-quiz-q={i}
              data-correct-index={q.correctIndex}
            >
              <h4 class="html-quiz__q-title">
                <span class="html-quiz__q-num">{i + 1}</span>. {q.prompt}
              </h4>

              <div class="html-quiz__options">
                {q.options.map((opt, idx) => {
                  const name = `${radiosNamePrefix}${i}`;
                  const value = String(idx);
                  const id = `${radiosNamePrefix}${i}_${idx}`;
                  return (
                    <label class="html-quiz__opt" for={id}>
                      <input
                        id={id}
                        type="radio"
                        name={name}
                        value={value}
                        data-html-quiz-answer={i}
                      />
                      <span>{opt}</span>
                    </label>
                  );
                })}
              </div>

              <div
                class="html-quiz__feedback"
                data-html-quiz-feedback={i}
                aria-live="polite"
              ></div>
            </section>
          ))}
        </form>
      </div>

      <div class="html-quiz__footer">
        <div id={resultId} class="html-quiz__result" aria-live="polite"></div>
        <div class="html-quiz__actions">
          <button type="button" class="html-quiz__submit" data-html-quiz-submit>
            Validar Etiquetas
          </button>
          <button type="button" class="html-quiz__restart" data-html-quiz-restart>
            Limpiar Respuestas
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const WKEY = '__htmlQuizModalDelegated__';
    if (window[WKEY]) return;
    window[WKEY] = true;

    function closeModal(modal) {
      if (!modal) return;
      modal.setAttribute('aria-hidden', 'true');
      modal.classList.remove('is-open');
      document.documentElement.style.overflow = '';
    }

    function openModal(modal) {
      if (!modal) return;
      const resultEl = modal.querySelector('.html-quiz__result');
      if (resultEl) resultEl.textContent = '';
      modal.querySelectorAll('[data-html-quiz-feedback]').forEach((el) => {
        el.textContent = '';
      });
      modal.setAttribute('aria-hidden', 'false');
      modal.classList.add('is-open');
      document.documentElement.style.overflow = 'hidden';
    }

    function shuffleQuestions(modal) {
      const form = modal.querySelector('.html-quiz__form');
      const qEls = Array.from(modal.querySelectorAll('[data-html-quiz-q]'));
      if (!form || qEls.length < 2) return;

      for (let i = qEls.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        const tmp = qEls[i];
        qEls[i] = qEls[j];
        qEls[j] = tmp;
      }

      qEls.forEach((el) => {
        form.appendChild(el);
      });

      qEls.forEach((qEl, idx) => {
        const numEl = qEl.querySelector('.html-quiz__q-num');
        if (numEl) numEl.textContent = String(idx + 1);
      });
    }

    function gradeModal(modal) {
      const resultEl = modal.querySelector('.html-quiz__result');
      if (!resultEl) return;

      const qEls = modal.querySelectorAll('[data-html-quiz-q]');
      let score = 0;

      qEls.forEach((qEl) => {
        const correct = Number(qEl.getAttribute('data-correct-index'));
        const feedbackEl = qEl.querySelector('[data-html-quiz-feedback]');
        const selected = qEl.querySelector('input[type="radio"]:checked');
        const idx = selected ? Number(selected.value) : null;

        const isCorrect = idx === correct;
        if (isCorrect) score++;

        if (feedbackEl) {
          if (isCorrect) {
            feedbackEl.innerHTML = '<span style="color:#22c55e;">Sintaxis CORRECTA ✅</span>';
          } else {
            feedbackEl.innerHTML = '<span style="color:#ff4d00;">Error de etiqueta ❌. Reintenta.</span>';
          }
        }
      });

      const total = qEls.length;
      if (score === total) resultEl.innerHTML = `🌟 ¡Puntuación perfecta! ${score}/${total}. ¡Arquitecto Web!`;
      else if (score > total / 2) resultEl.innerHTML = `👍 Bien hecho: ${score}/${total} aciertos. Casi listo para el Front.`;
      else resultEl.innerHTML = `📚 Etiquetas sin cerrar: ${score}/${total}. Te recomendamos repasar.`;
    }

    document.addEventListener('click', (e) => {
      const target = e.target;

      const startBtn = target instanceof Element ? target.closest('.html-quiz__start') : null;
      if (startBtn) {
        e.preventDefault();
        const root = startBtn.closest('.html-quiz');
        const modal = root?.querySelector('.html-quiz__modal') || null;
        openModal(modal);
        if (modal) shuffleQuestions(modal);
        return;
      }

      const closeBtn = target instanceof Element ? target.closest('[data-html-quiz-close]') : null;
      if (closeBtn) {
        const root = closeBtn.closest('.html-quiz');
        const modal = root?.querySelector('.html-quiz__modal') || null;
        closeModal(modal);
        return;
      }

      const submitBtn = target instanceof Element ? target.closest('[data-html-quiz-submit]') : null;
      if (submitBtn) {
        const root = submitBtn.closest('.html-quiz');
        const modal = root?.querySelector('.html-quiz__modal') || null;
        if (modal) gradeModal(modal);
        return;
      }

      const restartBtn = target instanceof Element ? target.closest('[data-html-quiz-restart]') : null;
      if (restartBtn) {
        const root = restartBtn.closest('.html-quiz');
        const modal = root?.querySelector('.html-quiz__modal') || null;
        if (!modal) return;
        const resultEl = modal.querySelector('.html-quiz__result');
        if (resultEl) resultEl.textContent = '';
        modal.querySelectorAll('input[type="radio"]').forEach((r) => {
          r.checked = false;
        });
        modal.querySelectorAll('[data-html-quiz-feedback]').forEach((el) => {
          el.textContent = '';
        });
        return;
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll('.html-quiz__modal.is-open').forEach((m) => closeModal(m));
    });
  })();
</script>

<style>
  .html-quiz {
    margin: 2.5rem 0 2rem;
  }

  /* Color Naranja HTML (#ff4d00) */
  .html-quiz__start {
    width: 100%;
    max-width: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.1rem;
    border-radius: 12px;
    border: 3px solid var(--border);
    background: #ff4d00; 
    color: white;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 5px 5px 0px var(--border);
    transition: transform 0.1s, box-shadow 0.1s;
    margin: 0 auto;
  }

  .html-quiz__start:hover {
    transform: translateY(-2px);
    box-shadow: 7px 7px 0px var(--border);
  }

  .html-quiz__modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: none;
  }

  .html-quiz__modal.is-open {
    display: block;
  }

  .html-quiz__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .html-quiz__panel {
    position: relative;
    max-width: 860px;
    margin: 6vh auto 0;
    background: #fff;
    border: 3px solid var(--border);
    border-radius: 20px;
    box-shadow: 0 28px 90px rgba(255, 77, 0, 0.2);
    overflow: hidden;
  }

  .html-quiz__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.75rem;
    border-bottom: 3px solid var(--border);
    background: #fffaf0; 
  }

  .html-quiz__title {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.15rem;
    color: #c24100;
  }

  .html-quiz__title-badge {
    background: #ff4d00;
    color: white;
    border: 2px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  .html-quiz__close {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 2px solid var(--border);
    background: white;
    font-weight: 900;
  }

  .html-quiz__body {
    padding: 1.5rem 1.75rem;
    max-height: 68vh;
    overflow: auto;
  }

  .html-quiz__intro {
    margin: 0 0 1.5rem;
    color: var(--text-secondary);
    font-weight: 800;
  }

  .html-quiz__q {
    padding: 1.25rem;
    border: 2px solid #eee;
    border-radius: 16px;
    background: #fdfdfd;
    margin-bottom: 1.5rem;
  }

  .html-quiz__q-title {
    margin: 0 0 1rem;
    font-weight: 900;
    color: var(--text-primary);
  }

  .html-quiz__q-num { color: #ff4d00; }

  .html-quiz__options {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.7rem;
  }

  .html-quiz__opt {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    cursor: pointer;
    font-weight: 750;
    color: var(--text-secondary);
    line-height: 1.4;
    padding: 0.4rem;
    border-radius: 10px;
  }

  .html-quiz__opt:hover {
    background: #fffaf0;
  }

  .html-quiz__opt input {
    margin-top: 4px;
    accent-color: #ff4d00;
  }

  .html-quiz__footer {
    padding: 1.25rem 1.75rem;
    border-top: 3px solid var(--border);
    background: #fffaf0;
  }

  .html-quiz__result {
    min-height: 1.25rem;
    margin-bottom: 0.75rem;
    font-weight: 900;
    color: #ff4d00;
  }

  .html-quiz__actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
  }

  .html-quiz__submit {
    border: 3px solid var(--border);
    background: #ff4d00;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 14px;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 4px 4px 0px var(--border);
  }

  .html-quiz__restart {
    border: 3px solid var(--border);
    background: white;
    color: #ff4d00;
    padding: 0.75rem 1.5rem;
    border-radius: 14px;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 4px 4px 0px var(--border);
  }
</style>
