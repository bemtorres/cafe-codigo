---
import { linuxDistrosQuizBank } from '../data/linuxDistrosQuizBank';

type Props = {
  quizKey: string;
};

const { quizKey } = Astro.props as Props;
const quiz = linuxDistrosQuizBank[quizKey];

if (!quiz) {
  throw new Error(`LinuxDistrosQuizModal: no existe quizKey "${quizKey}" en linuxDistrosQuizBank.`);
}

const modalId = `linux-quiz-modal-${quizKey}`;
const openBtnId = `linux-quiz-open-${quizKey}`;
const closeBtnId = `linux-quiz-close-${quizKey}`;
const resultId = `linux-quiz-result-${quizKey}`;
const radiosNamePrefix = `linux_quiz_${quizKey}_q_`;
---

<div class="linux-quiz">
  <button id={openBtnId} type="button" class="linux-quiz__start" data-linux-quiz-open>
    Realizar Test Distros
  </button>

  <div id={modalId} class="linux-quiz__modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="linux-quiz__overlay" data-linux-quiz-close></div>

    <div class="linux-quiz__panel">
      <div class="linux-quiz__header">
        <div class="linux-quiz__title">
          <span class="linux-quiz__title-badge">Linux Distro Quiz</span>
          <span>{quiz.title}</span>
        </div>

        <button
          id={closeBtnId}
          type="button"
          class="linux-quiz__close"
          data-linux-quiz-close
          aria-label="Cerrar"
        >
          ✕
        </button>
      </div>

      <div class="linux-quiz__body">
        <p class="linux-quiz__intro">
          Demuestra cuánto sabes sobre el ecosistema del pingüino. Son <strong>{quiz.questions.length}</strong> preguntas.
        </p>

        <form class="linux-quiz__form" onsubmit="return false;">
          {quiz.questions.map((q, i) => (
            <section
              class="linux-quiz__q"
              data-linux-quiz-q={i}
              data-correct-index={q.correctIndex}
            >
              <h4 class="linux-quiz__q-title">
                <span class="linux-quiz__q-num">{i + 1}</span>. {q.prompt}
              </h4>

              <div class="linux-quiz__options">
                {q.options.map((opt, idx) => {
                  const name = `${radiosNamePrefix}${i}`;
                  const value = String(idx);
                  const id = `${radiosNamePrefix}${i}_${idx}`;
                  return (
                    <label class="linux-quiz__opt" for={id}>
                      <input
                        id={id}
                        type="radio"
                        name={name}
                        value={value}
                        data-linux-quiz-answer={i}
                      />
                      <span>{opt}</span>
                    </label>
                  );
                })}
              </div>

              <div
                class="linux-quiz__feedback"
                data-linux-quiz-feedback={i}
                aria-live="polite"
              ></div>
            </section>
          ))}
        </form>
      </div>

      <div class="linux-quiz__footer">
        <div id={resultId} class="linux-quiz__result" aria-live="polite"></div>
        <div class="linux-quiz__actions">
          <button type="button" class="linux-quiz__submit" data-linux-quiz-submit>
            Validar Respuestas
          </button>
          <button type="button" class="linux-quiz__restart" data-linux-quiz-restart>
            Limpiar (Reset)
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const WKEY = '__linuxDistrosQuizModalDelegated__';
    if (window[WKEY]) return;
    window[WKEY] = true;

    function closeModal(modal) {
      if (!modal) return;
      modal.setAttribute('aria-hidden', 'true');
      modal.classList.remove('is-open');
      document.documentElement.style.overflow = '';
    }

    function openModal(modal) {
      if (!modal) return;
      const resultEl = modal.querySelector('.linux-quiz__result');
      if (resultEl) resultEl.textContent = '';
      modal.querySelectorAll('[data-linux-quiz-feedback]').forEach((el) => {
        el.textContent = '';
      });
      modal.setAttribute('aria-hidden', 'false');
      modal.classList.add('is-open');
      document.documentElement.style.overflow = 'hidden';
    }

    function shuffleQuestions(modal) {
      const form = modal.querySelector('.linux-quiz__form');
      const qEls = Array.from(modal.querySelectorAll('[data-linux-quiz-q]'));
      if (!form || qEls.length < 2) return;

      for (let i = qEls.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        const tmp = qEls[i];
        qEls[i] = qEls[j];
        qEls[j] = tmp;
      }

      qEls.forEach((el) => {
        form.appendChild(el);
      });

      qEls.forEach((qEl, idx) => {
        const numEl = qEl.querySelector('.linux-quiz__q-num');
        if (numEl) numEl.textContent = String(idx + 1);
      });
    }

    function gradeModal(modal) {
      const resultEl = modal.querySelector('.linux-quiz__result');
      if (!resultEl) return;

      const qEls = modal.querySelectorAll('[data-linux-quiz-q]');
      let score = 0;

      qEls.forEach((qEl) => {
        const correct = Number(qEl.getAttribute('data-correct-index'));
        const feedbackEl = qEl.querySelector('[data-linux-quiz-feedback]');
        const selected = qEl.querySelector('input[type="radio"]:checked');
        const idx = selected ? Number(selected.value) : null;

        const isCorrect = idx === correct;
        if (isCorrect) score++;

        if (feedbackEl) {
          if (isCorrect) {
            feedbackEl.innerHTML = '<span style="color:#0ea5e9;">¡Excelente! 🐧</span>';
          } else {
            feedbackEl.innerHTML = '<span style="color:#f59e0b;">Sigue aprendiendo 🧠</span>';
          }
        }
      });

      const total = qEls.length;
      if (score === total) resultEl.innerHTML = `🌟 Puntuación Perfecta: ${score}/${total}. ¡SysAdmin Pro!`;
      else if (score > total / 2) resultEl.innerHTML = `👍 Bien hecho: ${score}/${total} aciertos.`;
      else resultEl.innerHTML = `📚 Intenta repasar las clases: ${score}/${total}.`;
    }

    document.addEventListener('click', (e) => {
      const target = e.target;

      const startBtn = target instanceof Element ? target.closest('.linux-quiz__start') : null;
      if (startBtn) {
        e.preventDefault();
        const root = startBtn.closest('.linux-quiz');
        const modal = root?.querySelector('.linux-quiz__modal') || null;
        openModal(modal);
        if (modal) shuffleQuestions(modal);
        return;
      }

      const closeBtn = target instanceof Element ? target.closest('[data-linux-quiz-close]') : null;
      if (closeBtn) {
        const root = closeBtn.closest('.linux-quiz');
        const modal = root?.querySelector('.linux-quiz__modal') || null;
        closeModal(modal);
        return;
      }

      const submitBtn = target instanceof Element ? target.closest('[data-linux-quiz-submit]') : null;
      if (submitBtn) {
        const root = submitBtn.closest('.linux-quiz');
        const modal = root?.querySelector('.linux-quiz__modal') || null;
        if (modal) gradeModal(modal);
        return;
      }

      const restartBtn = target instanceof Element ? target.closest('[data-linux-quiz-restart]') : null;
      if (restartBtn) {
        const root = restartBtn.closest('.linux-quiz');
        const modal = root?.querySelector('.linux-quiz__modal') || null;
        if (!modal) return;
        const resultEl = modal.querySelector('.linux-quiz__result');
        if (resultEl) resultEl.textContent = '';
        modal.querySelectorAll('input[type="radio"]').forEach((r) => {
          r.checked = false;
        });
        modal.querySelectorAll('[data-linux-quiz-feedback]').forEach((el) => {
          el.textContent = '';
        });
        return;
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll('.linux-quiz__modal.is-open').forEach((m) => closeModal(m));
    });
  })();
</script>

<style>
  .linux-quiz {
    margin: 2.5rem 0 2rem;
  }

  /* Color Ámbar (#f59e0b) para Linux Distros */
  .linux-quiz__start {
    width: 100%;
    max-width: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.9rem 1.1rem;
    border-radius: 12px;
    border: 3px solid var(--border);
    background: #f59e0b; 
    color: white;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 5px 5px 0px var(--border);
    transition: transform 0.1s, box-shadow 0.1s;
    margin: 0 auto;
  }

  .linux-quiz__start:hover {
    transform: translateY(-2px);
    box-shadow: 7px 7px 0px var(--border);
  }
  
  .linux-quiz__start:active {
    transform: translateY(2px);
    box-shadow: 3px 3px 0px var(--border);
  }

  .linux-quiz__modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: none;
  }

  .linux-quiz__modal.is-open {
    display: block;
  }

  .linux-quiz__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .linux-quiz__panel {
    position: relative;
    max-width: 860px;
    margin: 6vh auto 0;
    background: #fff;
    border: 3px solid var(--border);
    border-radius: 20px;
    box-shadow: 0 28px 90px rgba(245, 158, 11, 0.2);
    overflow: hidden;
  }

  .linux-quiz__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-bottom: 3px solid var(--border);
    background: #fff9ea; 
  }

  .linux-quiz__title {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.15rem;
    color: #b45309;
  }

  .linux-quiz__title-badge {
    background: #f59e0b;
    color: white;
    border: 2px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  .linux-quiz__close {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 2px solid var(--border);
    background: white;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 900;
  }

  .linux-quiz__body {
    padding: 1.5rem;
    max-height: 68vh;
    overflow: auto;
  }

  .linux-quiz__intro {
    margin: 0 0 1.5rem;
    color: var(--text-secondary);
    font-weight: 800;
  }

  .linux-quiz__q {
    padding: 1.25rem;
    border: 2px solid #eee;
    border-radius: 16px;
    background: #fdfdfd;
    margin-bottom: 1.5rem;
  }

  .linux-quiz__q-title {
    margin: 0 0 1rem;
    font-weight: 900;
    color: var(--text-primary);
  }

  .linux-quiz__q-num { color: #f59e0b; }

  .linux-quiz__options {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.7rem;
  }

  .linux-quiz__opt {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    cursor: pointer;
    font-weight: 750;
    color: var(--text-secondary);
    line-height: 1.4;
    padding: 0.4rem;
    border-radius: 10px;
  }

  .linux-quiz__opt:hover {
    background: #fff9ea;
  }

  .linux-quiz__opt input {
    margin-top: 4px;
    accent-color: #f59e0b;
  }

  .linux-quiz__footer {
    padding: 1.25rem 1.5rem;
    border-top: 3px solid var(--border);
    background: #fff9ea;
  }

  .linux-quiz__result {
    min-height: 1.25rem;
    margin-bottom: 0.75rem;
    font-weight: 900;
    color: #b45309;
    font-family: 'Nunito', sans-serif;
  }

  .linux-quiz__feedback {
    margin-top: 0.75rem;
    font-weight: 900;
    font-size: 0.95rem;
  }

  .linux-quiz__actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
  }

  .linux-quiz__submit {
    border: 3px solid var(--border);
    background: #f59e0b;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 14px;
    font-weight: 900;
    font-family: 'Nunito', sans-serif;
    cursor: pointer;
    box-shadow: 4px 4px 0px var(--border);
  }

  .linux-quiz__restart {
    border: 3px solid var(--border);
    background: white;
    color: #f59e0b;
    padding: 0.75rem 1.5rem;
    border-radius: 14px;
    font-weight: 900;
    font-family: 'Nunito', sans-serif;
    cursor: pointer;
    box-shadow: 4px 4px 0px var(--border);
  }
</style>
