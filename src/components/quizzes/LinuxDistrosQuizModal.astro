---
import QuizModal from './QuizModal.astro';

type Props = {
  quizKey: string;
};

const { quizKey } = Astro.props as Props;
---

<QuizModal
  courseSlug="linux-distros"
  quizKey={quizKey}
  title="Sistemas Linux Quiz"
  brandingColor="#f59e0b"
  brandingBg="#ffffff"
  brandingText="#ffffff"
  logo="🐧"
/>
