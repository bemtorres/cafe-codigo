---
import QuizModal from './QuizModal.astro';

type Props = {
  quizKey: string;
};

const { quizKey } = Astro.props as Props;
---

<QuizModal
  courseSlug="javascript"
  quizKey={quizKey}
  title="JavaScript Quiz"
  brandingColor="#f1c40f"
  brandingBg="#ffffff"
  brandingText="#1e1210"
  logo="💛"
/>
