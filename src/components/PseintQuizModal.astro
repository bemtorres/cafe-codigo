---
import { pseintQuizBank } from '../data/pseintQuizBank';

type Props = {
  quizKey: string;
};

const { quizKey } = Astro.props as Props;
const quiz = pseintQuizBank[quizKey];

if (!quiz) {
  throw new Error(`PseintQuizModal: no existe quizKey "${quizKey}" en pseintQuizBank.`);
}

const modalId = `pseint-quiz-modal-${quizKey}`;
const openBtnId = `pseint-quiz-open-${quizKey}`;
const closeBtnId = `pseint-quiz-close-${quizKey}`;
const resultId = `pseint-quiz-result-${quizKey}`;
const radiosNamePrefix = `pseint_quiz_${quizKey}_q_`;
---

<div class="pseint-quiz" data-course-slug="pseint" data-quiz-key={quizKey}>
  <p class="pseint-quiz__hint" data-pseint-quiz-hint></p>
  <button id={openBtnId} type="button" class="pseint-quiz__start" data-pseint-quiz-open>
    Comenzar examen
  </button>

  <div id={modalId} class="pseint-quiz__modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="pseint-quiz__overlay" data-pseint-quiz-close></div>

    <div class="pseint-quiz__panel">
      <div class="pseint-quiz__header">
        <div class="pseint-quiz__title">
          <span class="pseint-quiz__title-badge">Desafío</span>
          <span>{quiz.title}</span>
        </div>

        <button
          id={closeBtnId}
          type="button"
          class="pseint-quiz__close"
          data-pseint-quiz-close
          aria-label="Cerrar"
        >
          ✕
        </button>
      </div>

      <div class="pseint-quiz__body">
        <p class="pseint-quiz__intro">
          Son <strong>{quiz.questions.length}</strong> preguntas de opción múltiple sobre lo que viste en esta lección.
          Elegí una alternativa por pregunta.
        </p>

        <form class="pseint-quiz__form" onsubmit="return false;">
          {quiz.questions.map((q, i) => (
            <section
              class="pseint-quiz__q"
              data-pseint-quiz-q={i}
              data-correct-index={q.correctIndex}
            >
              <h4 class="pseint-quiz__q-title">
                <span class="pseint-quiz__q-num">{i + 1}</span>. {q.prompt}
              </h4>

              <div class="pseint-quiz__options">
                {q.options.map((opt, idx) => {
                  const name = `${radiosNamePrefix}${i}`;
                  const value = String(idx);
                  const id = `${radiosNamePrefix}${i}_${idx}`;
                  return (
                    <label class="pseint-quiz__opt" for={id}>
                      <input
                        id={id}
                        type="radio"
                        name={name}
                        value={value}
                        data-pseint-quiz-answer={i}
                      />
                      <span>{opt}</span>
                    </label>
                  );
                })}
              </div>

              <div
                class="pseint-quiz__feedback"
                data-pseint-quiz-feedback={i}
                aria-live="polite"
              ></div>
            </section>
          ))}
        </form>
      </div>

      <div class="pseint-quiz__footer">
        <div id={resultId} class="pseint-quiz__result" aria-live="polite"></div>
        <p class="pseint-quiz__sync" data-pseint-quiz-sync></p>
        <div class="pseint-quiz__actions">
          <button type="button" class="pseint-quiz__submit" data-pseint-quiz-submit>
            Finalizar
          </button>
          <button type="button" class="pseint-quiz__restart" data-pseint-quiz-restart>
            Reiniciar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { initPseintQuizModals } from '../lib/pseint/pseintQuizModal';
  initPseintQuizModals();
</script>

<style>
  .pseint-quiz {
    margin: 2.5rem 0 1rem;
  }

  .pseint-quiz__hint {
    margin: 0 0 0.75rem;
    font-size: 0.88rem;
    font-weight: 800;
    color: var(--text-secondary);
    line-height: 1.45;
    font-family: 'Nunito', sans-serif;
    min-height: 1.25rem;
  }

  .pseint-quiz__sync {
    margin: 0 0 0.65rem;
    font-size: 0.82rem;
    font-weight: 800;
    color: var(--success);
    font-family: 'Nunito', sans-serif;
    min-height: 1rem;
  }

  .pseint-quiz__sync.pseint-quiz__sync--err {
    color: #b91c1c;
  }

  .pseint-quiz__start {
    width: 100%;
    max-width: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.9rem 1.1rem;
    border-radius: 18px;
    border: 3px solid var(--border);
    background: var(--success);
    color: white;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 5px 5px 0px var(--border);
    transition: transform 0.1s, background 0.1s;
    margin: 0 auto; /* centra el botón */
  }

  .pseint-quiz__start:hover {
    transform: translateY(-2px);
    background: #05c290;
  }

  .pseint-quiz__modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: none;
  }

  .pseint-quiz__modal.is-open {
    display: block;
  }

  .pseint-quiz__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(4px);
  }

  .pseint-quiz__panel {
    position: relative;
    max-width: 860px;
    margin: 6vh auto 0;
    background: white;
    border: 3px solid var(--border);
    border-radius: 22px;
    box-shadow: 0 28px 90px rgba(30, 18, 16, 0.25);
    overflow: hidden;
  }

  .pseint-quiz__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 3px solid var(--border);
    background: var(--bg-tertiary);
  }

  .pseint-quiz__title {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    color: var(--info);
  }

  .pseint-quiz__title-badge {
    background: var(--warning);
    color: var(--text-primary);
    border: 3px solid var(--border);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: 0.95rem;
    box-shadow: 3px 3px 0px var(--border);
  }

  .pseint-quiz__close {
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 2px solid var(--border);
    background: rgba(255, 255, 255, 0.9);
    cursor: pointer;
    font-size: 1.05rem;
    font-weight: 900;
  }

  .pseint-quiz__body {
    padding: 1rem 1.25rem;
    max-height: 68vh;
    overflow: auto;
  }

  .pseint-quiz__intro {
    margin: 0 0 1rem;
    color: var(--text-secondary);
    font-weight: 700;
    line-height: 1.5;
  }

  .pseint-quiz__q {
    padding: 0.85rem 0.85rem 1rem;
    border: 2px dashed rgba(30, 18, 16, 0.25);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.9rem;
  }

  .pseint-quiz__q-title {
    margin: 0 0 0.75rem;
    font-weight: 900;
    color: var(--text-primary);
    font-family: 'Nunito', sans-serif;
  }

  .pseint-quiz__options {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.55rem;
  }

  .pseint-quiz__opt {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    cursor: pointer;
    font-weight: 750;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .pseint-quiz__opt input {
    margin-top: 2px;
    width: 18px;
    height: 18px;
    accent-color: var(--success);
  }

  .pseint-quiz__footer {
    padding: 0.95rem 1.25rem;
    border-top: 3px solid var(--border);
    background: rgba(255, 255, 255, 0.85);
  }

  .pseint-quiz__result {
    min-height: 1.25rem;
    margin-bottom: 0.75rem;
    font-weight: 900;
    color: var(--info);
    font-family: 'Nunito', sans-serif;
  }

  .pseint-quiz__feedback {
    margin-top: 0.65rem;
    font-weight: 900;
    line-height: 1.4;
    font-family: 'Nunito', sans-serif;
  }

  .pseint-quiz__actions {
    display: flex;
    gap: 0.8rem;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  .pseint-quiz__submit {
    border: 3px solid var(--border);
    background: var(--info);
    color: white;
    padding: 0.65rem 1rem;
    border-radius: 14px;
    font-weight: 900;
    font-family: 'Nunito', sans-serif;
    cursor: pointer;
    box-shadow: 4px 4px 0px var(--border);
  }

  .pseint-quiz__restart {
    border: 3px solid var(--border);
    background: white;
    color: var(--text-primary);
    padding: 0.65rem 1rem;
    border-radius: 14px;
    font-weight: 900;
    font-family: 'Nunito', sans-serif;
    cursor: pointer;
    box-shadow: 4px 4px 0px var(--border);
  }

  @media (max-width: 650px) {
    .pseint-quiz__panel {
      margin-top: 4vh;
      width: calc(100% - 1.2rem);
    }
    .pseint-quiz__actions {
      justify-content: stretch;
    }
    .pseint-quiz__submit,
    .pseint-quiz__restart {
      width: 100%;
      justify-content: center;
    }
  }
</style>

