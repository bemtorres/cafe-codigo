---
import '../styles/global.css';
import '../styles/code-themes.css';
import CodeThemeSelector from '../components/CodeThemeSelector.astro';
import { courses } from '../data/courses';
import logoCafeycodigo from '../assets/images/cafeycodigo.png';
import logoPseint from '../assets/images/pseint.png';
import ogLogo from '../assets/images/logo-cafecodigo.png';
import arkBg from '../assets/images/modelo_4_1/1_modelo.png';

interface Props {
  title: string;
  description?: string;
  courseSlug?: string;
}

const { title, description = "Aprende a programar gratis con cursos paso a paso", courseSlug } = Astro.props;
const currentCourse = courseSlug ? courses.find((c) => c.slug === courseSlug) : null;
const currentPath = Astro.url.pathname;

const KO_FI_URL = 'https://ko-fi.com/cafeycodigo';
const KO_FI_LOGO_URL = 'https://storage.ko-fi.com/cdn/kofi3.png?v=3';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={logoCafeycodigo.src} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Eagle+Lake&display=swap" rel="stylesheet">
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogLogo.src} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogLogo.src} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | cafeycodigo</title>
    <script is:inline>
      try {
        const t = localStorage.getItem('theme');
        if (t) document.documentElement.dataset.theme = t;
      } catch {}
    </script>
  </head>
  <body
    class="min-h-screen text-textPrimary font-quicksand antialiased"
    data-course={courseSlug}
    style={courseSlug === 'arch'
      ? `background-color: #F4EBD0; --arch-bg: url('${arkBg.src}');`
      : `background-color: var(--bg-primary); background-image: url('/images/fondo2.png'); background-repeat: repeat;`
    }
  >
    
    <header class="sticky top-2 z-50 mx-4">
      <nav class="max-w-7xl mx-auto px-4 py-3 bg-white/85 border border-black/15 rounded-full shadow-[0_16px_40px_rgba(30,18,16,0.1)] backdrop-blur-md grid grid-cols-[1fr_auto] sm:grid-cols-[auto_1fr_auto] gap-4 items-center">
        
        <div class="flex items-center gap-4">
          <a href="/" class="flex items-center gap-2 text-accent font-nunito font-extrabold text-[1.5rem] no-underline hover:-translate-y-0.5 transition-transform">
            <img class="shrink-0 w-10 h-10 object-contain rounded-xl" src={logoCafeycodigo.src} alt="" width="42" height="42" decoding="async" />
            <span class="leading-none">café y código</span>
          </a>
        </div>

        <div class="col-span-full sm:col-span-1 flex justify-start sm:justify-center min-w-0 mt-1 sm:mt-0">
          {!currentCourse?.lessons?.length ? (
            <div class="flex items-center gap-5">
              <button type="button" class="bg-white/70 border border-black/10 rounded-full px-4 py-2 font-nunito font-extrabold text-textPrimary shadow-[0_14px_34px_rgba(30,18,16,0.08)] hover:-translate-y-0.5 hover:bg-white/95 transition-all outline-none" data-open-modal="langs" aria-haspopup="dialog" aria-controls="langsModal">
                Aprende
              </button>
              <a href="/ejercicios/" class="bg-white/70 border border-black/10 rounded-full px-4 py-2 font-nunito font-extrabold text-textPrimary shadow-[0_14px_34px_rgba(30,18,16,0.08)] hover:-translate-y-0.5 hover:bg-white/95 transition-all no-underline">Ejercicios</a>
            </div>
          ) : currentCourse?.slug === 'pseint' ? (
            <span class="inline-flex items-center gap-1.5 bg-tertiary text-info border-2 border-info px-3 py-1 rounded-full text-sm font-extrabold font-nunito">
              <img class="shrink-0 w-5 h-5 object-contain rounded" src={logoPseint.src} alt="" width="22" height="22" decoding="async" />
              PSeInt
            </span>
          ) : null}
        </div>

        <div class="flex items-center justify-end gap-4 row-start-1 sm:row-auto col-start-2 sm:col-auto">
          <button class="w-10 h-10 rounded-full border border-black/15 bg-white/90 shadow-[0_10px_24px_rgba(30,18,16,0.1)] font-black font-nunito leading-none hover:-translate-y-0.5 transition-transform" type="button" aria-label="Cambiar tema">
            ☾
          </button>

          <div class="flex items-center gap-4">
            <CodeThemeSelector />
            {currentCourse && (
              <div class="flex items-center">
                {currentCourse.slug === 'pseint' && (
                  <a href="/pseint/simulador/" class="bg-warning text-textPrimary px-3 py-1.5 rounded-full font-extrabold text-sm font-nunito border-2 border-border shadow-[2px_2px_0px_#1E1210] hover:-translate-y-0.5 hover:bg-[#ffdb4d] active:translate-y-0.5 active:translate-x-0.5 active:shadow-[0px_0px_0px_#1E1210] transition-all no-underline">▶ Simulador</a>
                )}
                {currentCourse.slug !== 'pseint' && (
                  <span class="inline-flex items-center gap-1.5 bg-tertiary text-info border-2 border-info px-3 py-1 rounded-full text-sm font-extrabold font-nunito hidden md:inline-flex">
                    {currentCourse.name}
                  </span>
                )}
              </div>
            )}
            {!currentCourse && (
              <a class="inline-flex items-center gap-2 bg-white/90 border border-black/15 rounded-full px-3 py-1.5 font-nunito font-extrabold text-textPrimary shadow-[0_10px_24px_rgba(30,18,16,0.1)] hover:bg-white hover:-translate-y-0.5 active:translate-y-0 transition-all outline-none" href="https://github.com/bemtorres/cafe-codigo" target="_blank" rel="noreferrer">
                GitHub
              </a>
            )}
          </div>
        </div>
      </nav>
    </header>

    {!currentCourse?.lessons?.length && (
      <div id="langsModal" class="fixed inset-0 z-[1000] hidden [&.is-open]:block" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="absolute inset-0 bg-black/35 backdrop-blur-sm" data-close-modal="langs"></div>
        <div class="relative max-w-lg mx-auto mt-[10vh] max-md:mt-[6vh] max-md:w-[90%] bg-white border-4 border-border rounded-3xl p-5 shadow-[0_28px_80px_rgba(30,18,16,0.25)]">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl text-info font-nunito font-black m-0">Elegí un lenguaje</h3>
            <button type="button" class="w-10 h-10 rounded-full border-2 border-border bg-white text-lg font-black cursor-pointer hover:bg-gray-100" data-close-modal="langs" aria-label="Cerrar modal">✕</button>
          </div>

          <div class="mb-6">
            <h4 class="text-xs font-extrabold uppercase tracking-widest text-textSecondary mb-2 font-nunito ml-1">Nivel 0: Conceptos</h4>
            <div class="grid grid-cols-2 gap-3">
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-[#ef476f] shadow-neo hover:-translate-y-0.5 transition-transform" href="/ecosistemas/">Ecosistemas Pro</a>
            </div>
          </div>

          <div class="mb-6">
            <h4 class="text-xs font-extrabold uppercase tracking-widest text-textSecondary mb-2 font-nunito ml-1">Lenguajes</h4>
            <div class="grid grid-cols-2 gap-3">
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-textPrimary shadow-neo hover:-translate-y-0.5 transition-transform" href="/pseint/">
                <img class="w-5 h-5 rounded" src={logoPseint.src} alt="" />PSeInt
              </a>
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-textPrimary shadow-neo hover:-translate-y-0.5 transition-transform" href="/csharp/">C#</a>
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-textPrimary shadow-neo hover:-translate-y-0.5 transition-transform" href="/java/">Java</a>
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-textPrimary shadow-neo hover:-translate-y-0.5 transition-transform" href="/python/">Python</a>
            </div>
          </div>

          <div class="mb-6">
            <h4 class="text-xs font-extrabold uppercase tracking-widest text-textSecondary mb-2 font-nunito ml-1">Frontend</h4>
            <div class="grid grid-cols-2 gap-3">
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-[#ff4d00] shadow-neo hover:-translate-y-0.5 transition-transform" href="/html/">HTML5</a>
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-[#264de4] shadow-neo hover:-translate-y-0.5 transition-transform" href="/css/">CSS3</a>
            </div>
          </div>

          <div class="mb-6">
            <h4 class="text-xs font-extrabold uppercase tracking-widest text-textSecondary mb-2 font-nunito ml-1">Base de Datos</h4>
            <div class="grid grid-cols-2 gap-3">
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-[#16a085] shadow-neo hover:-translate-y-0.5 transition-transform" href="/modelamiento-db/">Modelamiento</a>
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-[#2980b9] shadow-neo hover:-translate-y-0.5 transition-transform" href="/consultas-sql/">Consultas SQL</a>
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-[#e67e22] shadow-neo hover:-translate-y-0.5 transition-transform" href="/programacion-db/">PL/SQL</a>
            </div>
          </div>

          <div class="mb-2">
            <h4 class="text-xs font-extrabold uppercase tracking-widest text-textSecondary mb-2 font-nunito ml-1">Herramientas</h4>
            <div class="grid grid-cols-2 gap-3">
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-textPrimary shadow-neo hover:-translate-y-0.5 transition-transform" href="/terminal/">Terminal</a>
              <a class="inline-flex items-center justify-center gap-2 py-3 px-4 rounded-2xl border-4 border-border bg-tertiary font-nunito font-black text-[#f59e0b] shadow-neo hover:-translate-y-0.5 transition-transform" href="/linux-distros/">Linux</a>
            </div>
          </div>

        </div>
      </div>
    )}

    <div class="max-w-[1400px] mx-auto flex flex-col lg:flex-row gap-8 py-8 px-4 items-start">
      <!-- SIDEBAR LATERAL -->
      {currentCourse?.lessons?.length && (
        <aside class="w-full lg:w-[250px] flex-shrink-0">
          <div class="sticky top-[6.5rem] bg-white border-[3px] border-border rounded-xl p-6 shadow-neo">
            <h3 class="flex items-center gap-2 text-[1.2rem] text-info font-nunito font-black mb-4 pb-2 border-b-2 border-dashed border-border">
              {currentCourse.slug === 'pseint' ? (
                <>
                  <img class="shrink-0 w-8 h-8 object-contain rounded-lg" src={logoPseint.src} alt="" width="32" height="32" />
                  <span>Contenido</span>
                </>
              ) : (
                <>🎯 Contenido</>
              )}
            </h3>
            <ul class="flex flex-row lg:flex-col flex-wrap gap-2.5 m-0 p-0 overflow-hidden">
              {currentCourse.lessons.filter(lesson => !lesson.href.includes('simulador')).map((lesson) => (
                <li class="w-auto lg:w-full">
                  <a href={lesson.href} class={`block px-4 py-2 bg-primary text-textPrimary no-underline font-bold text-[0.95rem] rounded-xl border-2 border-border hover:-translate-y-0.5 hover:shadow-[2px_2px_0px_#1E1210] hover:bg-secondary active:translate-x-0.5 active:translate-y-0.5 active:shadow-none transition-all ${currentPath === lesson.href ? 'bg-success text-white' : ''}`}>
                    {lesson.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )}

      <!-- CONTENIDO PRINCIPAL -->
      <main class="flex-1 min-w-0 w-full">
        <slot />
      </main>
    </div>

    <section class="max-w-[1400px] mx-auto mt-10 mb-8 px-4" aria-label="Donaciones">
      <div class="bg-white/80 border border-black/10 rounded-3xl p-6 shadow-[0_18px_44px_rgba(30,18,16,0.08)] flex flex-col md:flex-row gap-4 items-center justify-between">
        <div class="flex items-center gap-4">
          <img class="w-12 h-12 object-contain rounded-xl border border-black/10 bg-white" src={KO_FI_LOGO_URL} alt="Ko-fi" loading="lazy" decoding="async" />
          <div>
            <div class="font-extrabold font-nunito text-[1.15rem]">Donaciones</div>
            <div class="text-textSecondary font-[650] leading-relaxed">Apoyá cafeycodigo con un café en Ko-fi.</div>
          </div>
        </div>

        <a class="bg-[#2b1d1b] text-white py-3 px-5 rounded-full font-black font-nunito border border-black/10 shadow-soft hover:-translate-y-0.5 transition-transform" href={KO_FI_URL} target="_blank" rel="noreferrer noopener">
          Ir a Ko-fi →
        </a>
      </div>
    </section>

    <script is:inline>
      (function () {
        const btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        const apply = (t) => {
          if (!t) { document.documentElement.removeAttribute('data-theme'); return; }
          document.documentElement.dataset.theme = t;
        };
        btn.addEventListener('click', () => {
          const cur = document.documentElement.dataset.theme;
          const next = cur === 'dark' ? 'light' : 'dark';
          apply(next);
          try { localStorage.setItem('theme', next); } catch {}
        });
      })();

      (function () {
        const modal = document.getElementById('langsModal');
        if (!modal) return;
        const openBtn = document.querySelector('[data-open-modal="langs"]');
        const closeBtns = modal.querySelectorAll('[data-close-modal="langs"]');
        const open = () => { modal.setAttribute('aria-hidden', 'false'); modal.classList.add('is-open'); document.documentElement.style.overflow = 'hidden'; };
        const close = () => { modal.setAttribute('aria-hidden', 'true'); modal.classList.remove('is-open'); document.documentElement.style.overflow = ''; };
        if (openBtn) openBtn.addEventListener('click', open);
        closeBtns.forEach((b) => b.addEventListener('click', close));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      })();
    </script>
    
    <style is:global>
      /* --- ESTILO EGIPCIO (Curso Ark 4+1) mantenido --- */
      body[data-course="arch"] {
        --bg-primary: #F4EBD0; 
        --bg-secondary: #E9D5A2;
        --bg-tertiary: #C5A059;
        --text-primary: #1E1210;
        --text-secondary: #3D2B1F;
        --accent: #B8860B; 
        --info: #008B8B; 
        --border: #4A3B22;

        background-image: 
          radial-gradient(circle at 10% 20%, rgba(212, 175, 55, 0.05) 0%, transparent 20%),
          radial-gradient(circle at 90% 80%, rgba(212, 175, 55, 0.05) 0%, transparent 20%);
      }

      body[data-course="arch"] h1,
      body[data-course="arch"] h2,
      body[data-course="arch"] h3 {
        font-family: 'Cinzel', serif;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      body[data-course="arch"] .content-section {
        border: 4px double var(--border);
        box-shadow: 6px 6px 0px var(--accent);
        background: #FDF5E6;
      }
      body[data-course="arch"] ::-webkit-scrollbar-track { background: #E9D5A2; }
      body[data-course="arch"] ::-webkit-scrollbar-thumb { background: #C5A059; border: 2px solid #F4EBD0; }
    </style>
  </body>
</html>
