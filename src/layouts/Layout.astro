---
import '../styles/global.css';
import '../styles/code-themes.css';
import CodeThemeSelector from '../components/CodeThemeSelector.astro';
import WelcomeModal from '../components/WelcomeModal.astro';
import PasswordProtect from '../components/PasswordProtect.astro';
import { courses } from '../data/courses';
import { COURSE_PATH_PREFIX, courseHomePath } from '../lib/coursePaths';
import logoCafeycodigo from '../assets/images/cafeycodigo.png';
import logoPseint from '../assets/images/pseint.png';
import ogLogo from '../assets/images/logo-cafecodigo.png';
import arkBg from '../assets/images/modelo_4_1/1_modelo.png';
import kofiLogo from '../assets/images/kofi.png';
import HeaderAuth from '../components/auth/HeaderAuth';
import CafeDelDiaNavBtn from '../components/CafeDelDiaNavBtn';
import CoffeeTimerWidget from '../components/CoffeeTimerWidget';
import ShareEmbedButton from '../components/ShareEmbedButton';
import MobileNavProfile from '../components/auth/MobileNavProfile';
import LessonBookmarkToggle from '../components/auth/LessonBookmarkToggle';
import CourseFavoriteButton from '../components/auth/CourseFavoriteButton';
import CourseLoginUnlock from '../components/auth/CourseLoginUnlock';
import LanguageCuriosity from '../components/LanguageCuriosity.astro';
import LayoutEmbedPdfHead from './LayoutEmbedPdfHead.astro';

const KO_FI_URL = 'https://ko-fi.com/cafeycodigo';

interface Props {
  title: string;
  description?: string;
  courseSlug?: string;
}

const { title, description = "Aprende a programar gratis con cursos paso a paso", courseSlug } = Astro.props;
const currentCourse = courseSlug ? courses.find((c) => c.slug === courseSlug) : null;
/** Lenguajes en el modal «Elige un curso», orden cronológico por año de lanzamiento público */
const menuLanguageCourses = [...courses.filter((c) => c.category === 'language')].sort(
  (a, b) => (a.communityReleaseYear ?? 0) - (b.communityReleaseYear ?? 0),
);
const pseintCourse = courses.find((c) => c.slug === 'pseint');
const currentPath = Astro.url.pathname;
const normalizedPath = currentPath.replace(/\/$/, '');
/** Banner “café y programemos” solo en la portada */
const showHomeCoffeeBanner = normalizedPath === '' || normalizedPath === '/';
/** Selector de tema de código solo en páginas de cursos (/course/…), no en inicio ni resto del sitio */
const showCodeThemeSelector =
  normalizedPath === COURSE_PATH_PREFIX || normalizedPath.startsWith(`${COURSE_PATH_PREFIX}/`);

// Navegación de lecciones para mobile
const lessons = currentCourse?.lessons ?? [];
const currentLessonIdx = lessons.findIndex(l => {
  const lessonPath = `${COURSE_PATH_PREFIX}/${currentCourse?.slug}/${l.slug}`.replace(/\/$/, '');
  return normalizedPath === lessonPath || normalizedPath.startsWith(lessonPath);
});
const prevLesson = currentLessonIdx > 0 ? lessons[currentLessonIdx - 1] : null;
const nextLesson = currentLessonIdx >= 0 && currentLessonIdx < lessons.length - 1 ? lessons[currentLessonIdx + 1] : null;
const isInsideLesson = lessons.length > 0 && currentLessonIdx >= 0;
const currentLesson = currentLessonIdx >= 0 ? lessons[currentLessonIdx] : null;
/** Portada del curso: /course/slug/ — no es una lección concreta */
const isCourseHome =
  !!currentCourse &&
  (normalizedPath === `${COURSE_PATH_PREFIX}/${currentCourse.slug}` ||
    normalizedPath === `${COURSE_PATH_PREFIX}/${currentCourse.slug}/`);
/** Pie «dato curioso» en cursos de lenguaje: portada y lecciones, no en introducción */
const isLanguageCourse = currentCourse?.category === 'language';
const isIntroLesson = currentLesson?.slug === 'introduccion';
const showLanguageCuriosity =
  Boolean(
    currentCourse &&
      isLanguageCourse &&
      (isCourseHome || (isInsideLesson && !isIntroLesson)),
  );
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={logoCafeycodigo.src} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Eagle+Lake&display=swap" rel="stylesheet">
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogLogo.src} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogLogo.src} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | cafeycodigo</title>
    <script is:inline>
      try {
        const t = localStorage.getItem('theme');
        if (t) document.documentElement.dataset.theme = t;
      } catch {}
    </script>
    <LayoutEmbedPdfHead />
  </head>
  <body
    class="min-h-screen text-textPrimary font-quicksand antialiased"
    data-course={courseSlug}
    style={courseSlug === 'arch'
      ? `background-color: #F4EBD0; --arch-bg: url('${arkBg.src}');`
      : `background-color: var(--bg-primary); background-image: url('/images/fondo2.png'); background-repeat: repeat;`
    }
  >
    {showHomeCoffeeBanner && (
      <div
        class="embed-hide w-full border-b-2 border-border bg-[#2b1d1b] text-center py-2 px-3 sm:py-2.5 shadow-[0_2px_0_#1E1210]"
        role="note"
      >
        <p class="m-0 inline-flex max-w-[min(100%,40rem)] flex-wrap items-center justify-center gap-x-2 gap-y-0.5 font-nunito text-[0.8rem] font-black uppercase tracking-[0.06em] text-[#FFF9C4] sm:text-sm sm:tracking-[0.08em]">
          <span class="text-base sm:text-lg" aria-hidden="true">☕</span>
          <span>Tomate un café y programemos juntos 💖</span>
        </p>
      </div>
    )}

    <!-- Modal de bienvenida -->
    <div class="pdf-hide"><WelcomeModal /></div>
    {currentCourse?.requiresPassword && (
      <>
        <PasswordProtect courseSlug={currentCourse.slug} />
        <CourseLoginUnlock client:load courseSlug={currentCourse.slug} />
      </>
    )}
    
    <!-- Mini header solo mobile -->
    <header class="embed-hide pdf-hide sm:hidden sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b-2 border-[#1E1210]/10 px-4 py-3 flex items-center justify-between gap-3">
      <a href="/" class="flex items-center gap-2 no-underline shrink-0">
        <img src={logoCafeycodigo.src} alt="" class="w-8 h-8 object-contain rounded-lg" />
        <span class="font-nunito font-black text-[1.1rem] text-[#EF476F] leading-none">Café y Código</span>
      </a>
      {currentCourse && (
        <button
          type="button"
          id="mobileContentsBtn"
          class="flex-1 flex items-center justify-between gap-2 bg-white border-2 border-[#45B3E0] text-[#45B3E0] font-nunito font-extrabold text-[0.82rem] px-3 py-1.5 rounded-full cursor-pointer shadow-[1px_1px_0px_#45B3E0] hover:-translate-y-0.5 transition-all"
          aria-haspopup="dialog"
          aria-controls="mobileContentsModal"
        >
          <span class="truncate">{currentCourse.name}</span>
          <span class="shrink-0">&#9776;</span>
        </button>
      )}
    </header>

    <!-- Modal de lecciones (mobile) -->
    {currentCourse?.lessons?.length && (
      <div id="mobileContentsModal" class="embed-hide pdf-hide fixed inset-0 z-[1100] hidden [&.is-open]:flex flex-col" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="mobileContentsOverlay"></div>
        <div class="relative mt-auto w-full bg-white rounded-t-3xl border-t-4 border-[#1E1210] shadow-[0_-8px_32px_rgba(30,18,16,0.2)] max-h-[80vh] flex flex-col">
          <!-- Handle + header -->
          <div class="flex items-center justify-between px-5 pt-4 pb-3 border-b-2 border-dashed border-[#E5E5E5] shrink-0">
            <div class="flex items-center gap-2">
              <span class="text-lg">🎯</span>
              <h3 class="font-nunito font-black text-[1.1rem] text-[#1E1210] m-0">Contenido</h3>
              <span class="text-xs font-nunito font-extrabold text-[#45B3E0] bg-[#E0F7FA] border border-[#45B3E0] px-2 py-0.5 rounded-full">{currentCourse.name}</span>
            </div>
            <button id="mobileContentsClose" class="w-9 h-9 rounded-full border-2 border-[#1E1210] bg-white font-black text-[#1E1210] cursor-pointer hover:bg-gray-100 flex items-center justify-center">✕</button>
          </div>
          <!-- Lista de lecciones scrolleable -->
          <ul class="overflow-y-auto px-4 py-4 flex flex-col gap-2 m-0 list-none">
            {currentCourse.lessons.filter(l => !l.href.includes('simulador')).map((lesson) => (
              <li>
                <a
                  href={lesson.href}
                  class={`flex items-center gap-3 px-4 py-3 rounded-2xl border-2 font-nunito font-extrabold text-[0.95rem] no-underline transition-all ${
                    currentPath === lesson.href
                      ? 'bg-[#06D6A0] text-white border-[#1E1210] shadow-[2px_2px_0px_#1E1210]'
                      : 'bg-[#F8F8F8] text-[#1E1210] border-[#E5E5E5] hover:border-[#45B3E0] hover:bg-[#E0F7FA]'
                  }`}
                >
                  {currentPath === lesson.href && <span class="shrink-0">▶</span>}
                  {lesson.title}
                </a>
              </li>
            ))}
          </ul>
          <div class="h-safe-bottom pb-4"></div>
        </div>
      </div>
    )}

    <script is:inline>
      (function() {
        const btn   = document.getElementById('mobileContentsBtn');
        const modal = document.getElementById('mobileContentsModal');
        const close = document.getElementById('mobileContentsClose');
        const overlay = document.getElementById('mobileContentsOverlay');
        if (!btn || !modal) return;
        const open  = () => { modal.classList.add('is-open'); modal.setAttribute('aria-hidden','false'); document.documentElement.style.overflow = 'hidden'; };
        const shut  = () => { modal.classList.remove('is-open'); modal.setAttribute('aria-hidden','true'); document.documentElement.style.overflow = ''; };
        btn.addEventListener('click', open);
        close?.addEventListener('click', shut);
        overlay?.addEventListener('click', shut);
        document.addEventListener('keydown', e => { if (e.key === 'Escape') shut(); });
      })();
    </script>

    <!-- Header completo (solo desktop) -->
    <header class="embed-hide pdf-hide hidden sm:block sticky top-2 z-50 mx-4">
      <nav class="max-w-7xl mx-auto px-4 py-3 bg-white/85 border border-black/15 rounded-full shadow-[0_16px_40px_rgba(30,18,16,0.1)] backdrop-blur-md grid grid-cols-[1fr_auto] sm:grid-cols-[auto_1fr_auto] gap-4 items-center">
        
        <div class="flex items-center gap-4">
          <a href="/" class="flex items-center gap-2 text-accent font-nunito font-extrabold text-[1.5rem] no-underline hover:-translate-y-0.5 transition-transform">
            <img class="shrink-0 w-10 h-10 object-contain rounded-xl" src={logoCafeycodigo.src} alt="" width="42" height="42" decoding="async" />
            <span class="leading-none"><span class="text-textPrimary">Café y</span> <span class="text-[#b06d63]"> Código</span></span>
          </a>
        </div>

        <div class="col-span-full sm:col-span-1 flex justify-start sm:justify-center min-w-0 mt-1 sm:mt-0">
          {!currentCourse?.lessons?.length ? (
            <div class="flex items-center gap-5">
              <button type="button" class="bg-white/70 border border-black/10 rounded-full px-4 py-2 font-nunito font-extrabold text-textPrimary shadow-[0_14px_34px_rgba(30,18,16,0.08)] hover:-translate-y-0.5 hover:bg-white/95 transition-all outline-none" data-open-modal="langs" aria-haspopup="dialog" aria-controls="langsModal">
                Aprende
              </button>
              <a href="/ejercicios/" class="bg-white/70 border border-black/10 rounded-full px-4 py-2 font-nunito font-extrabold text-textPrimary shadow-[0_14px_34px_rgba(30,18,16,0.08)] hover:-translate-y-0.5 hover:bg-white/95 transition-all no-underline">Ejercicios</a>
              {/* <a href="/academia/" class="bg-white/70 border border-black/10 rounded-full px-4 py-2 font-nunito font-extrabold text-textPrimary shadow-[0_14px_34px_rgba(30,18,16,0.08)] hover:-translate-y-0.5 hover:bg-white/95 transition-all no-underline">Academia</a> */}
              {/* <a href="/colaboradores/" class="bg-white/70 border border-black/10 rounded-full px-4 py-2 font-nunito font-extrabold text-textPrimary shadow-[0_14px_34px_rgba(30,18,16,0.08)] hover:-translate-y-0.5 hover:bg-white/95 transition-all no-underline">Colaboradores</a> */}
              <CafeDelDiaNavBtn client:load />
            </div>
          ) : currentCourse?.slug === 'pseint' ? (
            <span class="inline-flex items-center gap-1.5 bg-tertiary text-info border-2 border-info px-3 py-1 rounded-full text-sm font-extrabold font-nunito">
              <img class="shrink-0 w-5 h-5 object-contain rounded" src={logoPseint.src} alt="" width="22" height="22" decoding="async" />
              PSeInt
            </span>
          ) : null}
        </div>

        <div class="flex items-center justify-end gap-4 row-start-1 sm:row-auto col-start-2 sm:col-auto">
          <!-- <button class="w-10 h-10 rounded-full border border-black/15 bg-white/90 shadow-[0_10px_24px_rgba(30,18,16,0.1)] font-black font-nunito leading-none hover:-translate-y-0.5 transition-transform" type="button" aria-label="Cambiar tema">
            ☾
          </button> -->

          <div class="flex items-center gap-4">
           
            <HeaderAuth client:load />
            {currentCourse && (
              <div class="flex items-center">
                {currentCourse.slug === 'pseint' && (
                  <a href="/course/pseint/simulador/" class="bg-warning text-textPrimary px-3 py-1.5 rounded-full font-extrabold text-sm font-nunito border-2 border-border shadow-[2px_2px_0px_#1E1210] hover:-translate-y-0.5 hover:bg-[#ffdb4d] active:translate-y-0.5 active:translate-x-0.5 active:shadow-[0px_0px_0px_#1E1210] transition-all no-underline">▶ Simulador</a>
                )}
                {currentCourse.slug !== 'pseint' && (
                  <span class="inline-flex items-center gap-1.5 bg-tertiary text-info border-2 border-info px-3 py-1 rounded-full text-sm font-extrabold font-nunito hidden md:inline-flex">
                    {currentCourse.name}
                  </span>
                )}
              </div>
            )}
            {showCodeThemeSelector && <CodeThemeSelector />}
            <!-- {!currentCourse && (
              <a class="inline-flex items-center gap-2 bg-white/90 border border-black/15 rounded-full px-3 py-1.5 font-nunito font-extrabold text-textPrimary shadow-[0_10px_24px_rgba(30,18,16,0.1)] hover:bg-white hover:-translate-y-0.5 active:translate-y-0 transition-all outline-none" href="https://github.com/bemtorres/cafe-codigo" target="_blank" rel="noreferrer">
                GitHub
              </a>
            )} -->
          </div>
        </div>
      </nav>
    </header>

    <!-- Modal de lenguajes -->
    <div id="langsModal" class="embed-hide pdf-hide fixed inset-0 z-[1000] hidden [&.is-open]:flex flex-col items-end sm:items-start justify-end sm:justify-center sm:pt-[6vh]" role="dialog" aria-modal="true" aria-hidden="true">
      <!-- Overlay -->
      <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" data-close-modal="langs"></div>

      <!-- Panel — bottom sheet en mobile, card en desktop -->
      <div class="relative w-full sm:w-[92%] sm:max-w-2xl sm:mx-auto bg-white border-t-4 sm:border-4 border-border rounded-t-3xl sm:rounded-3xl shadow-[0_-8px_40px_rgba(30,18,16,0.2)] sm:shadow-[0_28px_80px_rgba(30,18,16,0.25)] flex flex-col max-h-[88vh]">

        <!-- Handle visual solo en mobile -->
        <div class="sm:hidden flex justify-center pt-3 pb-1 shrink-0">
          <div class="w-10 h-1.5 rounded-full bg-[#D0C8C5]"></div>
        </div>

        <!-- Header fijo -->
        <div class="flex justify-between items-center px-6 py-4 border-b-2 border-border shrink-0">
          <h3 class="text-xl text-info font-nunito font-black m-0">📚 Elige un curso</h3>
          <button type="button" class="w-10 h-10 rounded-full border-2 border-border bg-white text-lg font-black cursor-pointer hover:bg-gray-100" data-close-modal="langs" aria-label="Cerrar modal">✕</button>
        </div>

        <!-- Contenido scrolleable — modo lista -->
        <div class="overflow-y-auto px-4 py-4 flex flex-col gap-1 pb-safe">

          <!-- Nivel 0: Conceptos -->
          <p class="px-2 pt-1 pb-1 text-[0.65rem] font-extrabold uppercase tracking-widest text-textMuted font-nunito">Conceptos base</p>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/ecosistemas/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#ef476f"></span>
            <span class="flex-1 text-sm">Ecosistemas Pro</span>
            <span class="text-textMuted text-sm">→</span>
          </a>

          <!-- Lenguajes -->
          <p class="px-2 pt-3 pb-1 text-[0.65rem] font-extrabold uppercase tracking-widest text-textMuted font-nunito">Lenguajes</p>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/pseint/">
            <img class="h-3 w-3 shrink-0 rounded-sm object-contain" src={logoPseint.src} alt="" />
            <span class="flex-1 text-sm">PSeInt</span>
            {pseintCourse?.communityReleaseYear != null && (
              <span class="text-[0.6rem] font-bold text-textMuted">{pseintCourse.communityReleaseYear}</span>
            )}
            <span class="text-textMuted text-sm">→</span>
          </a>
          {menuLanguageCourses.map((c) => (
            <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href={courseHomePath(c.slug)}>
              <span class="h-3 w-3 shrink-0 rounded-full" style={`background:${c.color}`}></span>
              <span class="flex-1 text-sm" style={`color:${c.color}`}>{c.name}</span>
              {c.communityReleaseYear != null && (
                <span class="text-[0.6rem] font-bold text-textMuted">{c.communityReleaseYear}</span>
              )}
              <span class="text-textMuted text-sm">→</span>
            </a>
          ))}

          <!-- Test -->
          <p class="px-2 pt-3 pb-1 text-[0.65rem] font-extrabold uppercase tracking-widest text-textMuted font-nunito">Test</p>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/javaunit/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#0891b2"></span>
            <span class="flex-1 text-sm" style="color:#0891b2">JUnit</span>
            <span class="text-textMuted text-sm">→</span>
          </a>

          <!-- Frontend -->
          <p class="px-2 pt-3 pb-1 text-[0.65rem] font-extrabold uppercase tracking-widest text-textMuted font-nunito">Frontend (web)</p>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/html/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#ff4d00"></span>
            <span class="flex-1 text-sm" style="color:#ff4d00">HTML5</span>
            <span class="text-textMuted text-sm">→</span>
          </a>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/css/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#264de4"></span>
            <span class="flex-1 text-sm" style="color:#264de4">CSS3</span>
            <span class="text-textMuted text-sm">→</span>
          </a>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/javascript/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#f1c40f"></span>
            <span class="flex-1 text-sm" style="color:#c8a000">JavaScript</span>
            <span class="text-textMuted text-sm">→</span>
          </a>

          <!-- Ingeniería -->
          <p class="px-2 pt-3 pb-1 text-[0.65rem] font-extrabold uppercase tracking-widest text-textMuted font-nunito">Ingeniería y calidad</p>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/arch/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#475569"></span>
            <span class="flex-1 text-sm" style="color:#475569">Ark (4+1)</span>
            <span class="text-textMuted text-sm">→</span>
          </a>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/c4/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#1a5ebd"></span>
            <span class="flex-1 text-sm" style="color:#1a5ebd">🔒 Modelo C4</span>
            <span class="text-textMuted text-sm">→</span>
          </a>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/vision-producto/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#8b5cf6"></span>
            <span class="flex-1 text-sm" style="color:#8b5cf6">Visión Producto</span>
            <span class="text-textMuted text-sm">→</span>
          </a>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/analisis-backlog/">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background:#3b82f6"></span>
            <span class="flex-1 text-sm" style="color:#3b82f6">Análisis Backlog</span>
            <span class="text-textMuted text-sm">→</span>
          </a>
          <a class="flex items-center gap-3 rounded-xl border-2 border-border bg-white px-3 py-2.5 font-nunito font-bold text-textPrimary no-underline shadow-neo transition-all hover:-translate-y-0.5 hover:bg-tertiary/30" href="/course/scrum-prototipado/">
