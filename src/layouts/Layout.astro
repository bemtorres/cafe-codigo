          <!-- Inicio -->
          <a href="/" id="mbnHome" class="mobile-nav-item flex flex-col items-center justify-center gap-0.5 flex-1 no-underline text-[#4A3A37] hover:text-[#EF476F] transition-colors" aria-label="Inicio">
            <span class="text-[22px] leading-none">🏠</span>
            <span class="text-[10px] font-nunito font-extrabold tracking-wide">Inicio</span>
          </a>

          <!-- Aprende -->
          <button type="button" id="mbnLearn" data-open-modal="langs" class="mobile-nav-item flex flex-col items-center justify-center gap-0.5 flex-1 text-[#4A3A37] hover:text-[#45B3E0] transition-colors bg-transparent border-none cursor-pointer" aria-label="Aprende" aria-haspopup="dialog">
            <span class="text-[22px] leading-none">📚</span>
            <span class="text-[10px] font-nunito font-extrabold tracking-wide">Aprende</span>
          </button>

          <!-- Botón central destacado → Café del día -->
          <div class="flex items-center justify-center flex-1">
            <a
              href="/cafe-del-dia/"
              class="flex flex-col items-center justify-center w-14 h-14 -mt-5 rounded-full bg-[#2b1d1b] border-[3px] border-[#1E1210] shadow-[0_4px_0px_#1E1210] hover:-translate-y-1 transition-transform active:translate-y-0 active:shadow-none no-underline"
              aria-label="Café del día"
            >
              <span class="text-[26px] leading-none">☕</span>
            </a>
          </div>

          <!-- Ko-fi -->
          <button type="button" id="btnKofiModal" class="mobile-nav-item flex flex-col items-center justify-center gap-0.5 flex-1 text-[#FF5E5B] hover:text-[#d94343] transition-colors bg-transparent border-none cursor-pointer" aria-label="Apóyanos en Ko-fi">
            <img src={kofiLogo.src} alt="" class="w-[22px] h-[22px] object-contain rounded-full" />
            <span class="text-[10px] font-nunito font-extrabold tracking-wide">Ko-fi</span>
          </button>

          <MobileNavProfile client:load />

        </div>
      )}
    </nav>

    <!-- ══════════════════════════════════════
         MODAL DE APOYO KO-FI
         ══════════════════════════════════════ -->
    <div
      id="kofiSupportModal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="kofiModalTitle"
      aria-hidden="true"
      class="embed-hide pdf-hide fixed inset-0 z-[9999] flex items-end justify-center pointer-events-none opacity-0 transition-opacity duration-300"
    >
      <!-- Overlay -->
      <div id="kofiModalOverlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm" data-close-kofi></div>

      <!-- Card -->
      <div class="relative w-full max-w-sm mx-4 mb-28 rounded-3xl border-[3px] border-[#1E1210] bg-white shadow-[6px_6px_0px_#1E1210] overflow-hidden
                  translate-y-8 transition-transform duration-300" id="kofiModalCard">

        <!-- Header decorativo -->
        <div class="bg-gradient-to-br from-[#FF5E5B] to-[#EF476F] px-6 pt-6 pb-8 text-center relative overflow-hidden">
          <!-- Burbujas decorativas -->
          <div class="absolute top-2 left-4 text-white/20 text-5xl select-none">☕</div>
          <div class="absolute bottom-0 right-6 text-white/10 text-6xl select-none">❤️</div>

          <!-- Logo Ko-fi -->
          <div class="relative flex items-center justify-center w-20 h-20 mx-auto mb-3 rounded-full bg-white border-[3px] border-[#1E1210] shadow-[3px_3px_0px_#1E1210]">
            <img src={kofiLogo.src} alt="Ko-fi" class="w-14 h-14 object-contain rounded-full" />
          </div>

          <h2 id="kofiModalTitle" class="text-white font-nunito font-black text-xl leading-tight">
            ¡Hecho con mucho cariño! ☕
          </h2>
        </div>

        <!-- Cuerpo -->
        <div class="px-6 py-5 text-center">
          <p class="font-nunito text-[#3D2B1F] text-[0.95rem] leading-relaxed mb-1">
            Este proyecto nació de la pasión por la enseñanza y el deseo de hacer la programación
            <strong>accesible para todos</strong>.
          </p>
          <p class="font-nunito text-[#3D2B1F] text-[0.95rem] leading-relaxed mb-2">
            Si te ha sido útil, puedes colaborar con <strong>una taza de café</strong> ☕ para seguir creando contenido gratuito.
          </p>
          <p class="font-nunito text-[#3D2B1F] text-[0.9rem] leading-relaxed mb-5">
            <a href="/colaboradores/" class="font-black text-[#118AB2] underline decoration-2 underline-offset-2">Programa de colaboradores</a>
            · insignia, muro y zona exclusiva.
          </p>

          <!-- Corazones decorativos -->
          <div class="flex justify-center gap-1 text-lg mb-5 select-none" aria-hidden="true">
            <span class="animate-pulse">❤️</span>
            <span class="animate-pulse [animation-delay:0.2s]">☕</span>
            <span class="animate-pulse [animation-delay:0.4s]">❤️</span>
          </div>

          <!-- Botón Ko-fi -->
          <a
            href={KO_FI_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-3 px-6 rounded-2xl bg-[#FF5E5B] border-[3px] border-[#1E1210] shadow-[3px_3px_0px_#1E1210] font-nunito font-black text-white text-[1rem] no-underline hover:-translate-y-0.5 hover:shadow-[3px_5px_0px_#1E1210] transition-all active:translate-y-0 active:shadow-[1px_1px_0px_#1E1210]"
          >
            <img src={kofiLogo.src} alt="" class="w-5 h-5 object-contain rounded-full" />
            Invitar un café en Ko-fi
          </a>

          <!-- Cerrar -->
          <button
            type="button"
            data-close-kofi
            class="mt-3 w-full py-2.5 rounded-2xl border-[2px] border-[#BDC3C7] font-nunito font-bold text-[0.85rem] text-[#888] bg-transparent hover:bg-[#F5F5F5] transition-colors cursor-pointer"
          >
            Quizás después
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const path = window.location.pathname;
        const homeBtn = document.getElementById('mbnHome');
        if (homeBtn && path === '/') homeBtn.classList.add('text-[#EF476F]');
      })();
    </script>

    <script is:inline>
      // ── Modal Ko-fi ───────────────────────────────────────────
      (function () {
        const modal   = document.getElementById('kofiSupportModal');
        const card    = document.getElementById('kofiModalCard');
        const openBtn = document.getElementById('btnKofiModal');
        if (!modal || !card || !openBtn) return;

        const openModal = () => {
          modal.setAttribute('aria-hidden', 'false');
          modal.classList.remove('opacity-0', 'pointer-events-none');
          modal.classList.add('opacity-100', 'pointer-events-auto');
          card.classList.remove('translate-y-8');
          card.classList.add('translate-y-0');
          document.documentElement.style.overflow = 'hidden';
        };
        const closeModal = () => {
          modal.setAttribute('aria-hidden', 'true');
          modal.classList.add('opacity-0', 'pointer-events-none');
          modal.classList.remove('opacity-100', 'pointer-events-auto');
          card.classList.add('translate-y-8');
          card.classList.remove('translate-y-0');
          document.documentElement.style.overflow = '';
        };

        openBtn.addEventListener('click', openModal);
        modal.querySelectorAll('[data-close-kofi]').forEach(el => el.addEventListener('click', closeModal));
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
      })();
    </script>

    {/* Widget flotante del temporizador del café */}
    <div class="embed-hide pdf-hide"><CoffeeTimerWidget client:load /></div>

    {courseSlug === 'unity-prototipado' && (
      <>
        <canvas id="matrixCanvas" class="fixed inset-0 pointer-events-none z-[-2] w-full h-full" style="display: none; background: #000; opacity: 0.35;"></canvas>
        <div id="unityCheatConsole" class="embed-hide pdf-hide fixed bottom-4 right-4 z-[999] bg-[#0b0914]/95 border-2 border-[#ff007f] rounded-xl p-3 shadow-[0_0_15px_rgba(255,0,127,0.4)] max-w-xs font-mono text-xs text-white">
          <div class="flex items-center gap-1.5 mb-1.5 font-bold text-[#00ffff] uppercase tracking-wider select-none">
            <span>🎮 CONSOLA DE SKIN</span>
            <span class="animate-pulse">●</span>
          </div>
          <div class="text-[0.68rem] text-slate-400 mb-2 select-none">Comandos: matrix, minecraft, pacman, default</div>
          <div class="flex items-center gap-1">
            <span class="text-[#ff007f] font-bold select-none">&gt;</span>
            <input 
              type="text" 
              id="cheatInput" 
              class="bg-black/60 border border-slate-700 rounded px-1.5 py-0.5 text-white outline-none focus:border-[#00ffff] w-full text-xs font-mono"
              placeholder="Escribe comando..."
              autocomplete="off"
            />
          </div>
        </div>

        <script is:inline>
          (function() {
            const input = document.getElementById('cheatInput');
            const canvas = document.getElementById('matrixCanvas');
            if (!input) return;

            let matrixInterval = null;

            function startMatrix() {
              if (!canvas) return;
              canvas.style.display = 'block';
              const ctx = canvas.getContext('2d');
              
              const resize = () => {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
              };
              resize();
              window.addEventListener('resize', resize);

              const katakana = 'ｱｲｳｴｵｶｷｸｹｺｻｼｽｾｿﾀﾁﾂﾃﾄﾅﾆﾇﾈﾉﾊﾋﾌﾍﾎﾏﾐﾑﾒﾓﾔﾕﾖﾗﾘﾙﾚﾛﾜﾝ1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZ';
              const alphabet = katakana.split('');
              const fontSize = 16;
              let columns = canvas.width / fontSize;
              let rainDrops = Array.from({ length: columns }).map(() => 1);

              const draw = () => {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = '#0F0';
                ctx.font = fontSize + 'px monospace';

                for (let i = 0; i < rainDrops.length; i++) {
                  const text = alphabet[Math.floor(Math.random() * alphabet.length)];
                  ctx.fillText(text, i * fontSize, rainDrops[i] * fontSize);

                  if (rainDrops[i] * fontSize > canvas.height && Math.random() > 0.975) {
                    rainDrops[i] = 0;
                  }
                  rainDrops[i]++;
                }
              };

              if (matrixInterval) clearInterval(matrixInterval);
              matrixInterval = setInterval(draw, 30);
            }

            function stopMatrix() {
              if (matrixInterval) {
                clearInterval(matrixInterval);
                matrixInterval = null;
              }
              if (canvas) {
                canvas.style.display = 'none';
              }
            }

            function applySkin(skin) {
              const s = (skin || '').trim().toLowerCase();
              document.body.setAttribute('data-game-skin', s);
              localStorage.setItem('unity-game-skin', s);

              if (s === 'matrix') {
                startMatrix();
              } else {
                stopMatrix();
              }
            }

            // Load initial skin
            const initialSkin = localStorage.getItem('unity-game-skin') || 'default';
            applySkin(initialSkin);

            input.addEventListener('keydown', function(e) {
              if (e.key === 'Enter') {
                const cmd = input.value.trim().toLowerCase();
                if (['matrix', 'minecraft', 'pacman', 'default'].includes(cmd)) {
                  applySkin(cmd);
                  input.value = '';
                } else {
                  // command not found feedback
                  input.style.borderColor = 'red';
                  setTimeout(() => input.style.borderColor = '', 1000);
                }
              }
            });
          })();
        </script>
      </>
    )}
  </body>
</html>
