          <!-- Logo Ko-fi -->
          <div class="relative flex items-center justify-center w-20 h-20 mx-auto mb-3 rounded-full bg-white border-[3px] border-[#1E1210] shadow-[3px_3px_0px_#1E1210]">
            <img src={kofiLogo.src} alt="Ko-fi" class="w-14 h-14 object-contain rounded-full" />
          </div>

          <h2 id="kofiModalTitle" class="text-white font-nunito font-black text-xl leading-tight">
            ¡Hecho con mucho cariño! ☕
          </h2>
        </div>

        <!-- Cuerpo -->
        <div class="px-6 py-5 text-center">
          <p class="font-nunito text-[#3D2B1F] text-[0.95rem] leading-relaxed mb-1">
            Este proyecto nació de la pasión por la enseñanza y el deseo de hacer la programación
            <strong>accesible para todos</strong>.
          </p>
          <p class="font-nunito text-[#3D2B1F] text-[0.95rem] leading-relaxed mb-2">
            Si te ha sido útil, puedes colaborar con <strong>una taza de café</strong> ☕ para seguir creando contenido gratuito.
          </p>
          <p class="font-nunito text-[#3D2B1F] text-[0.9rem] leading-relaxed mb-5">
            <a href="/colaboradores/" class="font-black text-[#118AB2] underline decoration-2 underline-offset-2">Programa de colaboradores</a>
            · insignia, muro y zona exclusiva.
          </p>

          <!-- Corazones decorativos -->
          <div class="flex justify-center gap-1 text-lg mb-5 select-none" aria-hidden="true">
            <span class="animate-pulse">❤️</span>
            <span class="animate-pulse [animation-delay:0.2s]">☕</span>
            <span class="animate-pulse [animation-delay:0.4s]">❤️</span>
          </div>

          <!-- Botón Ko-fi -->
          <a
            href={KO_FI_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-3 px-6 rounded-2xl bg-[#FF5E5B] border-[3px] border-[#1E1210] shadow-[3px_3px_0px_#1E1210] font-nunito font-black text-white text-[1rem] no-underline hover:-translate-y-0.5 hover:shadow-[3px_5px_0px_#1E1210] transition-all active:translate-y-0 active:shadow-[1px_1px_0px_#1E1210]"
          >
            <img src={kofiLogo.src} alt="" class="w-5 h-5 object-contain rounded-full" />
            Invitar un café en Ko-fi
          </a>

          <!-- Cerrar -->
          <button
            type="button"
            data-close-kofi
            class="mt-3 w-full py-2.5 rounded-2xl border-[2px] border-[#BDC3C7] font-nunito font-bold text-[0.85rem] text-[#888] bg-transparent hover:bg-[#F5F5F5] transition-colors cursor-pointer"
          >
            Quizás después
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const path = window.location.pathname;
        const homeBtn = document.getElementById('mbnHome');
        if (homeBtn && path === '/') homeBtn.classList.add('text-[#EF476F]');
      })();
    </script>

    <script is:inline>
      // ── Modal Ko-fi ───────────────────────────────────────────
      (function () {
        const modal   = document.getElementById('kofiSupportModal');
        const card    = document.getElementById('kofiModalCard');
        const openBtn = document.getElementById('btnKofiModal');
        if (!modal || !card || !openBtn) return;

        const openModal = () => {
          modal.setAttribute('aria-hidden', 'false');
          modal.classList.remove('opacity-0', 'pointer-events-none');
          modal.classList.add('opacity-100', 'pointer-events-auto');
          card.classList.remove('translate-y-8');
          card.classList.add('translate-y-0');
          document.documentElement.style.overflow = 'hidden';
        };
        const closeModal = () => {
          modal.setAttribute('aria-hidden', 'true');
          modal.classList.add('opacity-0', 'pointer-events-none');
          modal.classList.remove('opacity-100', 'pointer-events-auto');
          card.classList.add('translate-y-8');
          card.classList.remove('translate-y-0');
          document.documentElement.style.overflow = '';
        };

        openBtn.addEventListener('click', openModal);
        modal.querySelectorAll('[data-close-kofi]').forEach(el => el.addEventListener('click', closeModal));
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
      })();
    </script>

    {/* Widget flotante del temporizador del café */}
    <div class="embed-hide pdf-hide"><CoffeeTimerWidget client:load /></div>
  </body>
</html>
