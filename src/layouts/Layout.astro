    <script is:inline>
      (function () {
        const btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        const apply = (t) => {
          if (!t) { document.documentElement.removeAttribute('data-theme'); return; }
          document.documentElement.dataset.theme = t;
        };
        btn.addEventListener('click', () => {
          const cur = document.documentElement.dataset.theme;
          const next = cur === 'dark' ? 'light' : 'dark';
          apply(next);
          try { localStorage.setItem('theme', next); } catch {}
        });
      })();

      (function () {
        const collapseBtn = document.getElementById('asideCollapseBtn');
        const restoreBtn = document.getElementById('asideRestoreBtn');
        const aside = document.querySelector('.main-content-wrapper aside');
        if (!aside) return;

        const updateState = (isCollapsed) => {
          if (isCollapsed) {
            aside.style.setProperty('display', 'none', 'important');
            if (restoreBtn) {
              restoreBtn.style.setProperty('display', 'flex', 'important');
              restoreBtn.classList.remove('hidden');
            }
          } else {
            aside.style.display = '';
            if (restoreBtn) {
              restoreBtn.style.setProperty('display', 'none', 'important');
            }
          }
        };

        // Cargar estado inicial
        try {
          const collapsed = localStorage.getItem('sidebar-collapsed') === 'true';
          updateState(collapsed);
        } catch (e) {}

        collapseBtn?.addEventListener('click', () => {
          updateState(true);
          try { localStorage.setItem('sidebar-collapsed', 'true'); } catch (e) {}
        });

        restoreBtn?.addEventListener('click', () => {
          updateState(false);
          try { localStorage.setItem('sidebar-collapsed', 'false'); } catch (e) {}
        });
      })();

      (function () {
        const modal = document.getElementById('langsModal');
        if (!modal) return;
        const closeBtns = modal.querySelectorAll('[data-close-modal="langs"]');
        const open = () => { modal.setAttribute('aria-hidden', 'false'); modal.classList.add('is-open'); document.documentElement.style.overflow = 'hidden'; };
        const close = () => { modal.setAttribute('aria-hidden', 'true'); modal.classList.remove('is-open'); document.documentElement.style.overflow = ''; };

        // Event delegation
        document.addEventListener('click', (e) => {
          if (e.target.closest('[data-open-modal="langs"]')) open();
        });

        closeBtns.forEach((b) => b.addEventListener('click', close));
        modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      })();
    </script>
    
