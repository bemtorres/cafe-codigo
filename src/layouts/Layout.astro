    <script is:inline>
      (function () {
        const btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        const apply = (t) => {
          if (!t) { document.documentElement.removeAttribute('data-theme'); return; }
          document.documentElement.dataset.theme = t;
        };
        btn.addEventListener('click', () => {
          const cur = document.documentElement.dataset.theme;
          const next = cur === 'dark' ? 'light' : 'dark';
          apply(next);
          try { localStorage.setItem('theme', next); } catch {}
        });
      })();

      (function () {
        const modal = document.getElementById('langsModal');
        if (!modal) return;
        const closeBtns = modal.querySelectorAll('[data-close-modal="langs"]');
        const open = () => { modal.setAttribute('aria-hidden', 'false'); modal.classList.add('is-open'); document.documentElement.style.overflow = 'hidden'; };
        const close = () => { modal.setAttribute('aria-hidden', 'true'); modal.classList.remove('is-open'); document.documentElement.style.overflow = ''; };

        // Event delegation: funciona sin importar cuándo se rendericen los botones
        document.addEventListener('click', (e) => {
          if (e.target.closest('[data-open-modal="langs"]')) open();
        });

        closeBtns.forEach((b) => b.addEventListener('click', close));
        modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      })();
    </script>
    
